    <Style Selector="NumericUpDown.combo-like /template/ RepeatButton#PART_DecreaseButton /template/ ContentPresenter">
        <Setter Property="TextElement.Foreground" Value="{DynamicResource FP.Text.Secondary}"/>
    </Style>
    <Style Selector="NumericUpDown.combo-like /template/ RepeatButton#PART_IncreaseButton /template/ ContentPresenter">
        <Setter Property="TextElement.Foreground" Value="{DynamicResource FP.Text.Secondary}"/>
    </Style>
    <Style Selector="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Primary}"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ComboBoxItem /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource FP.Text.Primary}"/>
    </Style>
    <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Hover}"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource FP.Text.Primary}"/>
    </Style>
    <Style Selector="ComboBoxItem:pointerover /template/ Border">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Hover}"/>
    </Style>
    <Style Selector="ComboBoxItem:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Hover}"/>
    </Style>
    <Style Selector="ComboBoxItem:pointerover">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Hover}"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Primary}"/>
    </Style>
    <Style Selector="ComboBoxItem:pressed">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Bg}"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Primary}"/>
    </Style>
    <Style Selector="ComboBoxItem:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Bg}"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource FP.Text.Primary}"/>
    </Style>
    <Style Selector="ComboBoxItem:pressed /template/ Border">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Bg}"/>
    </Style>
    <Style Selector="ComboBoxItem:pressed /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Bg}"/>
    </Style>
    <Style Selector="ComboBoxItem:pointerover:pressed">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Hover}"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Primary}"/>
    </Style>
    <Style Selector="ComboBoxItem:pointerover:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Hover}"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource FP.Text.Primary}"/>
    </Style>
    <Style Selector="ComboBoxItem:pointerover:pressed /template/ Border">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Hover}"/>
    </Style>
    <Style Selector="ComboBoxItem:pointerover:pressed /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Hover}"/>
    </Style>
    <Style Selector="ComboBoxItem:selected">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Bg}"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Primary}"/>
    </Style>
    <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Bg}"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource FP.Text.Primary}"/>
    </Style>
    <Style Selector="ComboBoxItem:selected /template/ Border">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Bg}"/>
    </Style>
    <Style Selector="ComboBoxItem:selected /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Bg}"/>
    </Style>
    <Style Selector="ComboBoxItem:selected:pointerover">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Hover}"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Primary}"/>
    </Style>
    <Style Selector="ComboBoxItem:selected:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Hover}"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource FP.Text.Primary}"/>
    </Style>
    <Style Selector="ComboBoxItem:selected:pointerover /template/ Border">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Hover}"/>
    </Style>
    <Style Selector="ComboBoxItem:selected:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Hover}"/>
    </Style>
    <Style Selector="ComboBoxItem:selected:pressed">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Hover}"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Primary}"/>
    </Style>
    <Style Selector="ComboBoxItem:selected:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Hover}"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource FP.Text.Primary}"/>
    </Style>
    <Style Selector="ComboBoxItem:selected:pressed /template/ Border">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Hover}"/>
    </Style>
    <Style Selector="ComboBoxItem:selected:pressed /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Hover}"/>
    </Style>
    <Style Selector="Popup Border">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Elevated}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Normal}"/>
    </Style>

    <Style Selector="Expander">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Content}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Normal}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="14,5,10,2"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Primary}"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <Grid RowDefinitions="Auto,Auto">
                        <ToggleButton Background="Transparent"
                                      BorderThickness="0"
                                      Padding="{TemplateBinding Padding}"
                                      MinHeight="28"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch"
                                      VerticalContentAlignment="Center"
                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                            <ContentPresenter Content="{TemplateBinding Header}"
                                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Stretch"
                                              Foreground="{TemplateBinding Foreground}"/>
                        </ToggleButton>
                        <ContentPresenter Grid.Row="1"
                                          IsVisible="{TemplateBinding IsExpanded}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Margin="{TemplateBinding Padding}"/>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="Expander /template/ ToggleButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Primary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Arrow"/>
    </Style>
    <Style Selector="Expander:pointerover /template/ ToggleButton">
        <Setter Property="Foreground" Value="{DynamicResource FP.Accent}"/>
    </Style>
    <Style Selector="Expander:pointerover /template/ ToggleButton ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource FP.Accent}"/>
    </Style>
    <Style Selector="Expander /template/ ToggleButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Expander /template/ ToggleButton:checked">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="Expander /template/ ToggleButton:checked /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Expander:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Accent}"/>
    </Style>
</Styles>
