        <Setter Property="Background" Value="{DynamicResource FP.Accent.Dark}"/>
    </Style>
    <Style Selector="Button.selection-badge.compact">
        <Setter Property="Width" Value="14"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="CornerRadius" Value="7"/>
    </Style>
    <Style Selector="Button.selection-badge:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Hover}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource FP.Text.Secondary}"/>
    </Style>
    <Style Selector="Button.selection-badge.active">
        <Setter Property="Background" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.selection-badge.active /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="TextElement.Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.selection-badge icons|SvgIcon.badge-glyph">
        <Setter Property="IconBrush" Value="{DynamicResource FP.Text.Secondary}"/>
    </Style>
    <Style Selector="Button.selection-badge.active icons|SvgIcon.badge-glyph">
        <Setter Property="IconBrush" Value="White"/>
    </Style>
    <Style Selector="Button.favorite-btn:pointerover icons|SvgIcon.fav-heart">
        <Setter Property="IconBrush" Value="{DynamicResource FP.Text.Primary}"/>
    </Style>
    <Style Selector="Button.favorite-btn:pointerover icons|SvgIcon.fav-heart.active">
        <Setter Property="IconBrush" Value="{DynamicResource FP.Accent.Light}"/>
    </Style>
    <Style Selector="Button.image-favorite-btn">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>
    <Style Selector="Button.image-favorite-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="icons|SvgIcon.fav-heart">
        <Setter Property="IconBrush" Value="{DynamicResource FP.Text.Secondary}"/>
    </Style>
    <Style Selector="icons|SvgIcon.fav-heart.active">
        <Setter Property="IconBrush" Value="{DynamicResource FP.Accent}"/>
    </Style>
    <!-- Bewertungssterne: SVG-basiert, aktiv in Akzentfarbe -->
    <Style Selector="Button.star-btn icons|SvgIcon.rating-star">
        <Setter Property="IconBrush" Value="#EAEFF5"/>
        <Setter Property="Opacity" Value="0.92"/>
        <Setter Property="Effect">
            <DropShadowEffect BlurRadius="0"
                              OffsetX="1"
                              OffsetY="1"
                              Color="#B0000000"/>
        </Setter>
    </Style>
    <Style Selector="Button.star-btn.active icons|SvgIcon.rating-star">
        <Setter Property="IconBrush" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>

    <!-- Ausgewählte Thumbnail-Karte: oranger Rahmen -->
    <Style Selector="ListBoxItem:selected Border.thumb-card">
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Input}"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Normal}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="MinHeight" Value="0"/>
    </Style>
    <Style Selector="ComboBox:pointerover /template/ Border#Background">
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Strong}"/>
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Elevated}"/>
    </Style>
    <Style Selector="ComboBox:pressed /template/ Border#Background">
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Strong}"/>
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Bg}"/>
    </Style>
    <Style Selector="ComboBox:focus /template/ Border#Background">
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Accent}"/>
    </Style>
    <Style Selector="ComboBox /template/ ToggleButton#DropDownButton:pressed">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Bg}"/>
    </Style>
    <Style Selector="ComboBox /template/ ToggleButton#DropDownButton:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Bg}"/>
    </Style>
    <Style Selector="ComboBox /template/ Popup#PART_Popup Border#PopupBorder">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Elevated}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Normal}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
    </Style>
    <Style Selector="ComboBox /template/ Popup#PART_Popup ScrollViewer">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Elevated}"/>
    </Style>

    <Style Selector="NumericUpDown.combo-like">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Input}"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Normal}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>
    <Style Selector="TextBox.combo-like">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Input}"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Normal}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>
    <Style Selector="TextBox.combo-like:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Strong}"/>
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Elevated}"/>
    </Style>
    <Style Selector="TextBox.combo-like:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Accent}"/>
    </Style>
    <Style Selector="NumericUpDown.combo-like:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Strong}"/>
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Elevated}"/>
    </Style>
    <Style Selector="NumericUpDown.combo-like:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Accent}"/>
    </Style>
    <!-- PART_TextBox ist selbst ein vollwertiges TextBox-Control mit eigenem Fokus-Erscheinungsbild
         (eigener Rahmen/Hintergrund im :focus-Zustand seines eigenen Templates) - ohne diese
         Overrides überdeckt das beim Reinklicken den feinen äußeren Rahmen des NumericUpDown mit der
         dunkleren Eingabefeld-Hintergrundfarbe. VerticalContentAlignment/HorizontalContentAlignment
         zentrieren den Text vertikal statt am oberen Rand kleben zu bleiben. -->
    <Style Selector="NumericUpDown.combo-like /template/ TextBox#PART_TextBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="NumericUpDown.combo-like /template/ TextBox#PART_TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="NumericUpDown.combo-like /template/ TextBox#PART_TextBox /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="NumericUpDown.combo-like /template/ RepeatButton#PART_DecreaseButton">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Input}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Normal}"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Secondary}"/>
    </Style>
    <Style Selector="NumericUpDown.combo-like /template/ RepeatButton#PART_IncreaseButton">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Input}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Normal}"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Secondary}"/>
    </Style>
    <Style Selector="NumericUpDown.combo-like /template/ RepeatButton#PART_DecreaseButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Hover}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Strong}"/>
    </Style>
    <Style Selector="NumericUpDown.combo-like /template/ RepeatButton#PART_IncreaseButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Hover}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Strong}"/>
    </Style>
    <Style Selector="NumericUpDown.combo-like /template/ RepeatButton#PART_DecreaseButton:pressed">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Bg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Strong}"/>
    </Style>
    <Style Selector="NumericUpDown.combo-like /template/ RepeatButton#PART_IncreaseButton:pressed">
