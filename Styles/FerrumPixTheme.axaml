<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:icons="clr-namespace:FerrumPix.Controls">

    <Styles.Resources>
        <SolidColorBrush x:Key="FP.Bg.Root" Color="#0B0E11"/>
        <SolidColorBrush x:Key="FP.Bg.Dark" Color="#0E1216"/>
        <SolidColorBrush x:Key="FP.Bg.Panel" Color="#11161B"/>
        <SolidColorBrush x:Key="FP.Bg.Content" Color="#141A20"/>
        <SolidColorBrush x:Key="FP.Bg.Elevated" Color="#192128"/>
        <SolidColorBrush x:Key="FP.Bg.Hover" Color="#1F2830"/>
        <SolidColorBrush x:Key="FP.Bg.Input" Color="#10161B"/>
        <SolidColorBrush x:Key="FP.Bg.Active" Color="#24303A"/>

        <SolidColorBrush x:Key="FP.Accent" Color="#F08A1A"/>
        <SolidColorBrush x:Key="FP.Accent.Light" Color="#FF9D2F"/>
        <SolidColorBrush x:Key="FP.Accent.Dark" Color="#BC6711"/>
        <SolidColorBrush x:Key="FP.Accent.Dim" Color="#2B1606"/>
        <SolidColorBrush x:Key="FP.Brand.Accent" Color="#F08A1A"/>

        <SolidColorBrush x:Key="FP.Text.Primary" Color="#E7ECF0"/>
        <SolidColorBrush x:Key="FP.Text.Secondary" Color="#A6AFB7"/>
        <SolidColorBrush x:Key="FP.Text.Muted" Color="#6C7780"/>
        <SolidColorBrush x:Key="FP.Text.Accent" Color="#F08A1A"/>

        <SolidColorBrush x:Key="FP.Border.Subtle" Color="#182028"/>
        <SolidColorBrush x:Key="FP.Border.Normal" Color="#26313B"/>
        <SolidColorBrush x:Key="FP.Border.Strong" Color="#34414C"/>

        <SolidColorBrush x:Key="FP.Sel.Bg" Color="#24303A"/>
        <SolidColorBrush x:Key="FP.Sel.Hover" Color="#2A3742"/>

        <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="#192128"/>
        <SolidColorBrush x:Key="ComboBoxDropDownBorderBrush" Color="#26313B"/>
        <SolidColorBrush x:Key="ComboBoxItemBackground" Color="Transparent"/>
        <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="#1F2830"/>
        <SolidColorBrush x:Key="ComboBoxItemBackgroundPressed" Color="#24303A"/>
        <SolidColorBrush x:Key="ComboBoxItemBackgroundSelected" Color="#24303A"/>
        <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPointerOver" Color="#2A3742"/>
        <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPressed" Color="#2A3742"/>
        <SolidColorBrush x:Key="ComboBoxItemForeground" Color="#E7ECF0"/>
        <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver" Color="#E7ECF0"/>
        <SolidColorBrush x:Key="ComboBoxItemForegroundSelected" Color="#E7ECF0"/>
        <SolidColorBrush x:Key="ComboBoxItemForegroundSelectedPointerOver" Color="#E7ECF0"/>
        <SolidColorBrush x:Key="ComboBoxItemForegroundSelectedPressed" Color="#E7ECF0"/>
        <SolidColorBrush x:Key="ListBoxItemBackground" Color="Transparent"/>
        <SolidColorBrush x:Key="ListBoxItemBackgroundPointerOver" Color="#1F2830"/>
        <SolidColorBrush x:Key="ListBoxItemBackgroundPressed" Color="#24303A"/>
        <SolidColorBrush x:Key="ListBoxItemBackgroundSelected" Color="#24303A"/>
        <SolidColorBrush x:Key="ListBoxItemBackgroundSelectedPointerOver" Color="#2A3742"/>
        <SolidColorBrush x:Key="ListBoxItemBackgroundSelectedPressed" Color="#2A3742"/>
        <SolidColorBrush x:Key="ListBoxItemForeground" Color="#E7ECF0"/>
        <SolidColorBrush x:Key="ListBoxItemForegroundPointerOver" Color="#E7ECF0"/>
        <SolidColorBrush x:Key="ListBoxItemForegroundSelected" Color="#E7ECF0"/>
        <SolidColorBrush x:Key="ListBoxItemForegroundSelectedPointerOver" Color="#E7ECF0"/>
        <SolidColorBrush x:Key="ListBoxItemForegroundSelectedPressed" Color="#E7ECF0"/>

        <SolidColorBrush x:Key="SystemControlHighlightListAccentLowBrush" Color="#24303A"/>
        <SolidColorBrush x:Key="SystemControlHighlightListAccentMediumBrush" Color="#2A3742"/>
        <SolidColorBrush x:Key="SystemControlHighlightListAccentHighBrush" Color="#34414C"/>
        <SolidColorBrush x:Key="SystemControlHighlightListLowBrush" Color="#1F2830"/>
        <SolidColorBrush x:Key="SystemControlHighlightListMediumBrush" Color="#24303A"/>
        <SolidColorBrush x:Key="SystemControlHighlightListHighBrush" Color="#2A3742"/>
        <SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="#F08A1A"/>
        <SolidColorBrush x:Key="SystemControlHighlightAltLowBrush" Color="#24303A"/>
        <SolidColorBrush x:Key="SystemControlHighlightAltMediumBrush" Color="#2A3742"/>
        <SolidColorBrush x:Key="SystemControlHighlightAltHighBrush" Color="#34414C"/>
        <SolidColorBrush x:Key="ComboBoxItemRevealBackgroundPointerOver" Color="#1F2830"/>
        <SolidColorBrush x:Key="ComboBoxItemRevealBackgroundPressed" Color="#24303A"/>
        <SolidColorBrush x:Key="ComboBoxItemRevealBackgroundSelected" Color="#24303A"/>
        <SolidColorBrush x:Key="ComboBoxItemRevealBackgroundSelectedPointerOver" Color="#2A3742"/>
        <SolidColorBrush x:Key="ComboBoxItemRevealBackgroundSelectedPressed" Color="#2A3742"/>
        <SolidColorBrush x:Key="ComboBoxItemRevealBorderBrushPointerOver" Color="#34414C"/>
        <SolidColorBrush x:Key="ComboBoxItemRevealBorderBrushPressed" Color="#34414C"/>
        <SolidColorBrush x:Key="ComboBoxItemRevealBorderBrushSelected" Color="#34414C"/>
        <SolidColorBrush x:Key="ComboBoxItemRevealBorderBrushSelectedPointerOver" Color="#34414C"/>
        <SolidColorBrush x:Key="ComboBoxItemRevealBorderBrushSelectedPressed" Color="#34414C"/>
    </Styles.Resources>

    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Root}"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Primary}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Cantarell, DejaVu Sans, sans-serif"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Primary}"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style Selector="TextBlock.secondary">
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Secondary}"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>
    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Muted}"/>
        <Setter Property="FontSize" Value="10"/>
    </Style>
    <Style Selector="TextBlock.section-header">
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Muted}"/>
        <Setter Property="FontSize" Value="9"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="10,10,10,4"/>
        <Setter Property="LetterSpacing" Value="1.3"/>
    </Style>
    <Style Selector="TextBlock.brand">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Primary}"/>
    </Style>
    <Style Selector="TextBlock.brand-accent">
        <Setter Property="Foreground" Value="{DynamicResource FP.Brand.Accent}"/>
    </Style>

    <Style Selector="icons|SvgIcon">
        <Setter Property="IconBrush" Value="{DynamicResource FP.Text.Secondary}"/>
    </Style>

    <Style Selector="Button">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Elevated}"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Normal}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <!-- Icon+Text-Buttons packen ihren Inhalt in ein horizontales StackPanel - darin wird das
         (kürzere) TextBlock per Default auf die Höhe des (höheren) Icons gestreckt und rendert den
         Text dann oben statt vertikal zentriert. -->
    <Style Selector="Button StackPanel[Orientation=Horizontal] > TextBlock">
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Hover}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Strong}"/>
    </Style>
    <Style Selector="UserControl.settings-view Button:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="UserControl.editor-view Button:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Button:pressed /template/ ContentPresenter">
        <Setter Property="Opacity" Value="0.8"/>
    </Style>
    <Style Selector="Button:disabled /template/ ContentPresenter">
        <Setter Property="Opacity" Value="0.35"/>
    </Style>
    <Style Selector="Button.accent">
        <Setter Property="Background" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button.accent /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="TextElement.Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="TextElement.Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.accent icons|SvgIcon">
        <Setter Property="IconBrush" Value="White"/>
    </Style>
    <Style Selector="Button.ghost">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Normal}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="11,6"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Secondary}"/>
        <Setter Property="CornerRadius" Value="8"/>
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Elevated}"/>
    </Style>
    <Style Selector="Button.insert-option-btn">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Input}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Normal}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="46"/>
        <Setter Property="Margin" Value="0,0,6,6"/>
    </Style>
    <Style Selector="Button.insert-option-btn.compact">
        <Setter Property="Width" Value="34"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Margin" Value="0,0,4,4"/>
    </Style>
    <Style Selector="Button.insert-option-btn /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Input}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Normal}"/>
    </Style>
    <Style Selector="Button.insert-option-btn.active">
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Elevated}"/>
    </Style>
    <Style Selector="Button.insert-option-btn.active /template/ ContentPresenter">
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Elevated}"/>
    </Style>
    <Style Selector="Button.insert-option-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Hover}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Strong}"/>
    </Style>
    <Style Selector="Button.insert-option-btn.active:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Elevated}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Accent}"/>
    </Style>
    <Style Selector="Button.insert-option-btn.selected-kind icons|SvgIcon">
        <Setter Property="IconBrush" Value="{DynamicResource FP.Accent}"/>
    </Style>
    <Style Selector="Button.info-tab">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0,0,0,2"/>
        <Setter Property="Padding" Value="0,0,0,8"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Secondary}"/>
    </Style>
    <Style Selector="Button.info-tab:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="Button.info-tab.active">
        <Setter Property="Foreground" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Accent}"/>
    </Style>
    <Style Selector="Button.info-tab.active TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button.dropdown-btn">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Input}"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Normal}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="MinHeight" Value="0"/>
    </Style>
    <Style Selector="Button.dropdown-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Elevated}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Strong}"/>
    </Style>
    <Style Selector="Button.dropdown-btn:pressed">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Bg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Strong}"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="Button.dropdown-btn:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Bg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Strong}"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="Button.dropdown-btn:pressed /template/ Border">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Bg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Strong}"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="Button.dropdown-item">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Primary}"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="MinWidth" Value="220"/>
    </Style>
    <Style Selector="Button.dropdown-item:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Hover}"/>
    </Style>
    <Style Selector="Button.dropdown-item:pointerover /template/ Border">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Hover}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="Button.dropdown-item:pressed">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Bg}"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="Button.dropdown-item:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Bg}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource FP.Text.Primary}"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="Button.dropdown-item:pressed /template/ Border">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Bg}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="Button.dropdown-item:pointerover:pressed">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Hover}"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="Button.dropdown-item:pointerover:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Hover}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource FP.Text.Primary}"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="Button.dropdown-item:pointerover:pressed /template/ Border">
        <Setter Property="Background" Value="{DynamicResource FP.Sel.Hover}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="Button.dropdown-item TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Primary}"/>
    </Style>
    <Style Selector="Button.dropdown-item:pressed TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Primary}"/>
    </Style>
    <!-- Ghost-Buttons in der Toolbar ohne Rahmen -->
    <Style Selector="Border.toolbar Button.ghost">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="Button.ghost.active">
        <Setter Property="Foreground" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Button.ghost.active icons|SvgIcon">
        <Setter Property="IconBrush" Value="{DynamicResource FP.Accent}"/>
    </Style>
    <Style Selector="Button.icon-btn">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Secondary}"/>
    </Style>
    <Style Selector="Button.icon-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Elevated}"/>
    </Style>
    <Style Selector="Button.icon-btn.active">
        <Setter Property="Foreground" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Button.icon-btn.active icons|SvgIcon">
        <Setter Property="IconBrush" Value="{DynamicResource FP.Accent}"/>
    </Style>
    <Style Selector="Button.anchor-dot">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Width" Value="24"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.anchor-dot:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Elevated}"/>
    </Style>
    <Style Selector="Button.anchor-dot Grid">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="Border.anchor-dot-idle">
        <Setter Property="Width" Value="10"/>
        <Setter Property="Height" Value="10"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="Background" Value="{DynamicResource FP.Border.Strong}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="Border.anchor-dot-active">
        <Setter Property="Width" Value="18"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="Background" Value="{DynamicResource FP.Text.Primary}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="ToggleButton.layer-eye">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="ToggleButton.layer-eye /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="ToggleButton.layer-eye:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="ToggleButton.layer-eye:checked /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="ToggleButton.layer-eye icons|SvgIcon">
        <Setter Property="IconBrush" Value="{DynamicResource FP.Text.Muted}"/>
    </Style>
    <Style Selector="ToggleButton.layer-eye:checked icons|SvgIcon">
        <Setter Property="IconBrush" Value="{DynamicResource FP.Accent}"/>
    </Style>
    <Style Selector="Button.tool-btn">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Secondary}"/>
    </Style>
    <Style Selector="Button.tool-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Elevated}"/>
    </Style>
    <Style Selector="Button.tool-btn.active">
        <Setter Property="Foreground" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Button.tool-btn-row">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{DynamicResource FP.Text.Secondary}"/>
    </Style>
    <Style Selector="Button.tool-btn-row:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Elevated}"/>
    </Style>
    <Style Selector="Button.tool-btn-row.active">
        <Setter Property="Foreground" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Button.tool-btn-row.active icons|SvgIcon">
        <Setter Property="IconBrush" Value="{DynamicResource FP.Accent}"/>
    </Style>
    <Style Selector="Button.winchr">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="#A0A8AF"/>
        <Setter Property="Width" Value="44"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.winchr:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#24303A"/>
        <Setter Property="TextElement.Foreground" Value="#EDF2F7"/>
    </Style>
    <Style Selector="Button.winchr.close:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#BE3A2B"/>
        <Setter Property="TextElement.Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.theme-choice">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Content}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Normal}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="Button.theme-choice:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource FP.Bg.Elevated}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Border.Strong}"/>
    </Style>
    <Style Selector="Button.theme-choice.active">
        <Setter Property="BorderBrush" Value="{DynamicResource FP.Accent}"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>
    <Style Selector="Button.swatch">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Padding" Value="0"/>
