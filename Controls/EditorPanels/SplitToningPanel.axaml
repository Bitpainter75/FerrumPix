<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:FerrumPix.Controls"
             x:Class="FerrumPix.Controls.EditorPanels.SplitToningPanel">
    <Expander Header="Split-Toning" IsExpanded="True">
        <Expander.HeaderTemplate>
            <DataTemplate>
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                VerticalAlignment="Center">
                        <icons:SvgIcon
                            Source="avares://FerrumPix/Assets/Icons/outline/color-filter.svg"
                            Width="14" Height="14" />
                        <TextBlock Text="{Binding}" FontWeight="SemiBold" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Classes="icon-btn"
                            Width="28"
                            Height="28"
                            Padding="0"
                            Command="{Binding DataContext.ResetSplitToningCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            ToolTip.Tip="Split-Toning zurücksetzen">
                        <icons:SvgIcon
                            Source="avares://FerrumPix/Assets/Icons/outline/rotate-clockwise.svg"
                            Width="14" Height="14" />
                    </Button>
                </Grid>
            </DataTemplate>
        </Expander.HeaderTemplate>
        <StackPanel Spacing="2" Margin="0,8,0,0">
            <Grid ColumnDefinitions="92,*,44" VerticalAlignment="Center">
                <TextBlock Text="Lichter Ton" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
                <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="360"
                                   Value="{Binding SplitToningHighlightHue}" Margin="0,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding SplitToningHighlightHue, Mode=TwoWay}" Minimum="0" Maximum="360" />
            </Grid>
            <Grid ColumnDefinitions="92,*,44" VerticalAlignment="Center">
                <TextBlock Text="Lichter Sätt." Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
                <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                                   Value="{Binding SplitToningHighlightSaturation}" Margin="0,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding SplitToningHighlightSaturation, Mode=TwoWay}" Minimum="0" Maximum="100" />
            </Grid>
            <Grid ColumnDefinitions="92,*,44" VerticalAlignment="Center">
                <TextBlock Text="Schatten Ton" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
                <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="360"
                                   Value="{Binding SplitToningShadowHue}" Margin="0,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding SplitToningShadowHue, Mode=TwoWay}" Minimum="0" Maximum="360" />
            </Grid>
            <Grid ColumnDefinitions="92,*,44" VerticalAlignment="Center">
                <TextBlock Text="Schatten Sätt." Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
                <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                                   Value="{Binding SplitToningShadowSaturation}" Margin="0,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding SplitToningShadowSaturation, Mode=TwoWay}" Minimum="0" Maximum="100" />
            </Grid>
            <Grid ColumnDefinitions="92,*,44" VerticalAlignment="Center">
                <TextBlock Text="Balance" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
                <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100"
                                   Value="{Binding SplitToningBalance}" Margin="0,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding SplitToningBalance, Mode=TwoWay}" Minimum="-100" Maximum="100" />
            </Grid>
        </StackPanel>
    </Expander>
</UserControl>
