<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:FerrumPix.Controls"
             x:Class="FerrumPix.Controls.EditorPanels.HslPanel">
    <Expander Header="Farbmischer" icons:ExpanderState.Key="hsl">
        <Expander.HeaderTemplate>
            <DataTemplate>
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <icons:SvgIcon
                            Source="avares://FerrumPix/Assets/Icons/outline/color-filter.svg"
                            Width="14" Height="14" />
                        <TextBlock Text="{Binding}" FontWeight="SemiBold" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Classes="icon-btn group-reset"
                            Width="28"
                            Height="28"
                            Padding="0"
                            Command="{Binding DataContext.ResetHslCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            ToolTip.Tip="Farbmischer zurücksetzen">
                        <icons:SvgIcon
                            Source="avares://FerrumPix/Assets/Icons/outline/rotate-clockwise.svg"
                            Width="14" Height="14" />
                    </Button>
                </Grid>
            </DataTemplate>
        </Expander.HeaderTemplate>
        <StackPanel Spacing="8" Margin="0,8,0,0">
            <icons:HslWheelPicker SelectedBand="{Binding SelectedHslBand, Mode=TwoWay}"
                                  Width="150" Height="150"
                                  HorizontalAlignment="Center" />
            <TextBlock Text="{Binding SelectedHslBandLabel}"
                       FontWeight="SemiBold"
                       FontSize="{DynamicResource FP.Font.Body}"
                       HorizontalAlignment="Center" />
            <!-- Die Regler stehen enger beieinander als Rad und Beschriftung darüber - wie in den
                 übrigen Anpassungs-Panels. -->
            <StackPanel Spacing="2">
                <Grid ColumnDefinitions="92,*,44" VerticalAlignment="Center">
                    <TextBlock Text="Farbton" Foreground="{DynamicResource FP.Text.Secondary}"
                               VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
                    <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100"
                                       DefaultValue="0"
                                       Value="{Binding ActiveHslHue}" Margin="0,0" />
                    <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                             Value="{Binding ActiveHslHue, Mode=TwoWay}"
                                             Minimum="-100" Maximum="100" Increment="1"
                                             FormatString="F0" />
                </Grid>
                <Grid ColumnDefinitions="92,*,44" VerticalAlignment="Center">
                    <TextBlock Text="Sättigung"
                               Foreground="{DynamicResource FP.Text.Secondary}"
                               VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
                    <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100"
                                       DefaultValue="0"
                                       Value="{Binding ActiveHslSaturation}" Margin="0,0" />
                    <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                             Value="{Binding ActiveHslSaturation, Mode=TwoWay}"
                                             Minimum="-100" Maximum="100" Increment="1"
                                             FormatString="F0" />
                </Grid>
                <Grid ColumnDefinitions="92,*,44" VerticalAlignment="Center">
                    <TextBlock Text="Luminanz"
                               Foreground="{DynamicResource FP.Text.Secondary}"
                               VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
                    <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100"
                                       DefaultValue="0"
                                       Value="{Binding ActiveHslLuminance}" Margin="0,0" />
                    <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                             Value="{Binding ActiveHslLuminance, Mode=TwoWay}"
                                             Minimum="-100" Maximum="100" Increment="1"
                                             FormatString="F0" />
                </Grid>
            </StackPanel>
        </StackPanel>
    </Expander>
</UserControl>
