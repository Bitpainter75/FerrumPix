<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:FerrumPix.Controls"
             x:Class="FerrumPix.Controls.EditorPanels.SharpnessPanel">
    <Expander Header="Schärfe" IsExpanded="True">
        <Expander.HeaderTemplate>
            <DataTemplate>
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <icons:SvgIcon
                            Source="avares://FerrumPix/Assets/Icons/outline/adjustments.svg"
                            Width="14" Height="14" />
                        <TextBlock Text="{Binding}" FontWeight="SemiBold" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Classes="icon-btn"
                            Width="28"
                            Height="28"
                            Padding="0"
                            Command="{Binding DataContext.ResetDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            ToolTip.Tip="Details zurücksetzen: Klarheit, Schärfe, Weichzeichnen, Körnung und Methode">
                        <icons:SvgIcon
                            Source="avares://FerrumPix/Assets/Icons/outline/rotate-clockwise.svg"
                            Width="14" Height="14" />
                    </Button>
                </Grid>
            </DataTemplate>
        </Expander.HeaderTemplate>
        <StackPanel Spacing="2" Margin="0,8,0,0">
            <Grid ColumnDefinitions="74,*,44" VerticalAlignment="Center">
                <TextBlock Text="Stärke" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="11" />
                <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                                   Value="{Binding Sharpness}" Margin="0,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding Sharpness, Mode=TwoWay}" Minimum="0" Maximum="100" />
            </Grid>
        </StackPanel>
    </Expander>
</UserControl>
