<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:FerrumPix.Controls"
             x:Class="FerrumPix.Controls.EditorPanels.AnnotationGlowPanel">
    <Expander Header="Glühen" IsExpanded="True">
        <StackPanel Spacing="2" Margin="0,8,0,0">
            <CheckBox Content="Aktiv" IsChecked="{Binding AnnotationGlowEnabled}"
                      FontSize="11" />
            <StackPanel Spacing="2" IsVisible="{Binding AnnotationGlowEnabled}">
                <Grid ColumnDefinitions="74,*" VerticalAlignment="Top">
                    <TextBlock Text="Farbe" Foreground="{DynamicResource FP.Text.Secondary}"
                               VerticalAlignment="Center" FontSize="11" />
                    <icons:ColorPickerButton Grid.Column="1"
                                             SelectedColor="{Binding AnnotationGlowColorValue, Mode=TwoWay}" />
                </Grid>
                <Grid ColumnDefinitions="74,*,44" VerticalAlignment="Center">
                    <TextBlock Text="Größe"
                               Foreground="{DynamicResource FP.Text.Secondary}"
                               VerticalAlignment="Center" FontSize="11" TextWrapping="Wrap" />
                    <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                                       DefaultValue="10"
                                       Value="{Binding AnnotationGlowBlur}" Margin="0,0" />
                    <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                             Value="{Binding AnnotationGlowBlur, Mode=TwoWay}"
                                             Minimum="0" Maximum="100" Increment="1"
                                             FormatString="F0" />
                </Grid>
                <Grid ColumnDefinitions="74,*,44" VerticalAlignment="Center">
                    <TextBlock Text="Stärke" Foreground="{DynamicResource FP.Text.Secondary}"
                               VerticalAlignment="Center" FontSize="11" />
                    <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                                       DefaultValue="100"
                                       Value="{Binding AnnotationGlowStrength}" Margin="0,0" />
                    <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                             Value="{Binding AnnotationGlowStrength, Mode=TwoWay}"
                                             Minimum="0" Maximum="100" Increment="1"
                                             FormatString="F0" />
                </Grid>
            </StackPanel>
        </StackPanel>
    </Expander>
</UserControl>
