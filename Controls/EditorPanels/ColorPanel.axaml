<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:FerrumPix.Controls"
             x:Class="FerrumPix.Controls.EditorPanels.ColorPanel">
    <Expander Header="Farbe" IsExpanded="True">
        <Expander.HeaderTemplate>
            <DataTemplate>
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                VerticalAlignment="Center">
                        <icons:SvgIcon
                            Source="avares://FerrumPix/Assets/Icons/outline/color-filter.svg"
                            Width="14" Height="14" />
                        <TextBlock Text="{Binding}" FontWeight="SemiBold" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Classes="icon-btn"
                            Width="28"
                            Height="28"
                            Padding="0"
                            Command="{Binding DataContext.ResetColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            ToolTip.Tip="Farbe zurücksetzen">
                        <icons:SvgIcon
                            Source="avares://FerrumPix/Assets/Icons/outline/rotate-clockwise.svg"
                            Width="14" Height="14" />
                    </Button>
                </Grid>
            </DataTemplate>
        </Expander.HeaderTemplate>
        <StackPanel Spacing="2" Margin="0,8,0,0">
            <Grid ColumnDefinitions="74,*" VerticalAlignment="Center">
                <TextBlock Text="Weißabgleich"
                           Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="11" TextWrapping="NoWrap" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding WhiteBalanceOptions}"
                          SelectedItem="{Binding WhiteBalance}"
                          HorizontalAlignment="Stretch"
                          FontSize="11"
                          Margin="6,0,0,0"
                          DropDownOpened="OnMatchWidthDropDownOpened" />
            </Grid>
            <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                <TextBlock Text="Temperatur"
                           Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="11" />
                <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100"
                                   Value="{Binding Temperature}" Margin="6,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding Temperature, Mode=TwoWay}" Minimum="-100" Maximum="100" />
            </Grid>
            <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                <TextBlock Text="Farbton" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="11" />
                <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100"
                                   Value="{Binding Tint}" Margin="6,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding Tint, Mode=TwoWay}" Minimum="-100" Maximum="100" />
            </Grid>
            <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                <TextBlock Text="Dynamik" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="11" />
                <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100"
                                   Value="{Binding Vibrance}" Margin="6,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding Vibrance, Mode=TwoWay}" Minimum="-100" Maximum="100" />
            </Grid>
            <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                <TextBlock Text="Sättigung"
                           Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="11" />
                <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100"
                                   Value="{Binding Saturation}" Margin="6,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding Saturation, Mode=TwoWay}" Minimum="-100" Maximum="100" />
            </Grid>
        </StackPanel>
    </Expander>
</UserControl>
