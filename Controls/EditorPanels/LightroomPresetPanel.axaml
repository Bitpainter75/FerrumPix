<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:FerrumPix.Controls"
             x:Class="FerrumPix.Controls.EditorPanels.LightroomPresetPanel">
    <Expander Header="Lightroom-Preset" IsExpanded="True">
        <Expander.HeaderTemplate>
            <DataTemplate>
                <Grid ColumnDefinitions="*,Auto,Auto" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <icons:SvgIcon
                            Source="avares://FerrumPix/Assets/Icons/outline/filter.svg"
                            Width="14" Height="14" />
                        <TextBlock Text="{Binding}" FontWeight="SemiBold" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Classes="icon-btn group-reset"
                            Width="28"
                            Height="28"
                            Padding="0"
                            Command="{Binding DataContext.ResetLightroomPresetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            ToolTip.Tip="Preset entfernen und Regler zurücksetzen">
                        <icons:SvgIcon
                            Source="avares://FerrumPix/Assets/Icons/outline/rotate-clockwise.svg"
                            Width="14" Height="14" />
                    </Button>
                    <Button Grid.Column="2"
                            Classes="icon-btn"
                            Width="28"
                            Height="28"
                            Padding="0"
                            Click="OnLoadLightroomPresetClick"
                            ToolTip.Tip="XMP laden">
                        <icons:SvgIcon
                            Source="avares://FerrumPix/Assets/Icons/outline/circle-plus.svg"
                            Width="14" Height="14" />
                    </Button>
                </Grid>
            </DataTemplate>
        </Expander.HeaderTemplate>
        <StackPanel Spacing="6" Margin="0,8,0,0">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                <Button Grid.Column="0" Classes="ghost" Padding="8,5"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        BorderBrush="{DynamicResource FP.Accent}"
                        Click="OnLoadLightroomPresetClick">
                    <TextBlock Text="XMP laden" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
                <Button Grid.Column="1" Classes="ghost" Padding="8,5"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        BorderBrush="{DynamicResource FP.Accent}"
                        Click="OnLoadLightroomFolderClick">
                    <TextBlock Text="Ordner laden" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
            </Grid>
            <ItemsControl ItemsSource="{Binding SavedLightroomPresets}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Classes="look-pill"
                                Classes.active="{Binding IsLastApplied}"
                                CornerRadius="12"
                                Background="{DynamicResource FP.Bg.Input}"
                                BorderBrush="{DynamicResource FP.Border.Normal}"
                                BorderThickness="1"
                                Margin="0,0,6,6"
                                Padding="8,4">
                            <Grid ColumnDefinitions="Auto,Auto">
                                <Button Grid.Column="0"
                                        Classes="ghost"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        Click="OnApplySavedLightroomPresetClick">
                                    <TextBlock Text="{Binding Name}" FontSize="{DynamicResource FP.Font.Small}" />
                                </Button>
                                <Button Grid.Column="1"
                                        Classes="ghost"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="4,0,0,0"
                                        Click="OnRemoveSavedLightroomPresetClick"
                                        ToolTip.Tip="Preset entfernen">
                                    <TextBlock Text="×" FontSize="{DynamicResource FP.Glyph.Large}"
                                               Foreground="{DynamicResource FP.Text.Muted}" />
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Expander>
</UserControl>
