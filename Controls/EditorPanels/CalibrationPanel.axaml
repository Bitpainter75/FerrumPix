<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:FerrumPix.Controls"
             x:Class="FerrumPix.Controls.EditorPanels.CalibrationPanel">
    <!-- Kamerakalibrierung wie in Lightroom: dreht und sättigt die drei PRIMÄRFARBEN und wirkt
         damit vor Weißabgleich und Sättigung. Sie macht einen guten Teil des charakteristischen
         Farbstichs vieler Presets aus - ohne sie kam ein importiertes Preset unvollständig an. -->
    <Expander Header="Kalibrierung" IsExpanded="True">
        <Expander.HeaderTemplate>
            <DataTemplate>
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <icons:SvgIcon
                            Source="avares://FerrumPix/Assets/Icons/outline/color-filter.svg"
                            Width="14" Height="14" />
                        <TextBlock Text="{Binding}" FontWeight="SemiBold" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Classes="icon-btn group-reset"
                            Width="28"
                            Height="28"
                            Padding="0"
                            Command="{Binding DataContext.ResetCalibrationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            ToolTip.Tip="Kalibrierung zurücksetzen">
                        <icons:SvgIcon
                            Source="avares://FerrumPix/Assets/Icons/outline/rotate-clockwise.svg"
                            Width="14" Height="14" />
                    </Button>
                </Grid>
            </DataTemplate>
        </Expander.HeaderTemplate>
        <StackPanel Spacing="2" Margin="0,8,0,0">
            <Grid ColumnDefinitions="92,*,44" VerticalAlignment="Center">
                <TextBlock Text="Tiefen Tönung" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" TextWrapping="Wrap" />
                <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100" DefaultValue="0"
                                   Value="{Binding CalibrationShadowTint}" Margin="0,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding CalibrationShadowTint, Mode=TwoWay}" Minimum="-100" Maximum="100" />
            </Grid>
            <Grid ColumnDefinitions="92,*,44" VerticalAlignment="Center">
                <TextBlock Text="Rot Farbton" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" TextWrapping="Wrap" />
                <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100" DefaultValue="0"
                                   Value="{Binding CalibrationRedHue}" Margin="0,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding CalibrationRedHue, Mode=TwoWay}" Minimum="-100" Maximum="100" />
            </Grid>
            <Grid ColumnDefinitions="92,*,44" VerticalAlignment="Center">
                <TextBlock Text="Rot Sättigung" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" TextWrapping="Wrap" />
                <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100" DefaultValue="0"
                                   Value="{Binding CalibrationRedSaturation}" Margin="0,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding CalibrationRedSaturation, Mode=TwoWay}" Minimum="-100" Maximum="100" />
            </Grid>
            <Grid ColumnDefinitions="92,*,44" VerticalAlignment="Center">
                <TextBlock Text="Grün Farbton" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" TextWrapping="Wrap" />
                <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100" DefaultValue="0"
                                   Value="{Binding CalibrationGreenHue}" Margin="0,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding CalibrationGreenHue, Mode=TwoWay}" Minimum="-100" Maximum="100" />
            </Grid>
            <Grid ColumnDefinitions="92,*,44" VerticalAlignment="Center">
                <TextBlock Text="Grün Sättigung" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" TextWrapping="Wrap" />
                <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100" DefaultValue="0"
                                   Value="{Binding CalibrationGreenSaturation}" Margin="0,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding CalibrationGreenSaturation, Mode=TwoWay}" Minimum="-100" Maximum="100" />
            </Grid>
            <Grid ColumnDefinitions="92,*,44" VerticalAlignment="Center">
                <TextBlock Text="Blau Farbton" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" TextWrapping="Wrap" />
                <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100" DefaultValue="0"
                                   Value="{Binding CalibrationBlueHue}" Margin="0,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding CalibrationBlueHue, Mode=TwoWay}" Minimum="-100" Maximum="100" />
            </Grid>
            <Grid ColumnDefinitions="92,*,44" VerticalAlignment="Center">
                <TextBlock Text="Blau Sättigung" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" TextWrapping="Wrap" />
                <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100" DefaultValue="0"
                                   Value="{Binding CalibrationBlueSaturation}" Margin="0,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding CalibrationBlueSaturation, Mode=TwoWay}" Minimum="-100" Maximum="100" />
            </Grid>
        </StackPanel>
    </Expander>
</UserControl>
