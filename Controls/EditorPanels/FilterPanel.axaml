<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:FerrumPix.Controls"
             x:Class="FerrumPix.Controls.EditorPanels.FilterPanel">
    <Expander Header="Filter" IsExpanded="True">
        <Expander.HeaderTemplate>
            <DataTemplate>
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <icons:SvgIcon
                            Source="avares://FerrumPix/Assets/Icons/outline/filter.svg"
                            Width="14" Height="14" />
                        <TextBlock Text="{Binding}" FontWeight="SemiBold" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Classes="icon-btn"
                            Width="28"
                            Height="28"
                            Padding="0"
                            Command="{Binding DataContext.ResetFilterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            ToolTip.Tip="Filter zurücksetzen">
                        <icons:SvgIcon
                            Source="avares://FerrumPix/Assets/Icons/outline/rotate-clockwise.svg"
                            Width="14" Height="14" />
                    </Button>
                </Grid>
            </DataTemplate>
        </Expander.HeaderTemplate>
        <StackPanel Spacing="2" Margin="0,8,0,0">
            <ComboBox ItemsSource="{Binding FilterPresetOptions}"
                      SelectedItem="{Binding FilterPreset}"
                      HorizontalAlignment="Stretch"
                      FontSize="{DynamicResource FP.Font.Small}"
                      DropDownOpened="OnMatchWidthDropDownOpened" />
            <Grid ColumnDefinitions="74,*,44" VerticalAlignment="Center">
                <TextBlock Text="Stärke" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
                <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                                   DefaultValue="100"
                                   Value="{Binding FilterStrength}" Margin="0,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding FilterStrength, Mode=TwoWay}"
                                         Minimum="0" Maximum="100" Increment="1"
                                         FormatString="F0" />
            </Grid>
            <WrapPanel>
                <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                        Classes.active="{Binding LastAppliedFilterPresetName, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Keine}"
                        Command="{Binding SetFilterPresetCommand}" CommandParameter="Keine">
                    <TextBlock Text="Keine" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
                <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                        Classes.active="{Binding LastAppliedFilterPresetName, Converter={StaticResource StringEqualsConverter}, ConverterParameter=S/W}"
                        Command="{Binding SetFilterPresetCommand}" CommandParameter="S/W">
                    <TextBlock Text="S/W" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
                <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                        Classes.active="{Binding LastAppliedFilterPresetName, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Warm}"
                        Command="{Binding SetFilterPresetCommand}" CommandParameter="Warm">
                    <TextBlock Text="Warm" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
                <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                        Classes.active="{Binding LastAppliedFilterPresetName, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Kühl}"
                        Command="{Binding SetFilterPresetCommand}" CommandParameter="Kühl">
                    <TextBlock Text="Kühl" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
                <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                        Classes.active="{Binding LastAppliedFilterPresetName, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Fade}"
                        Command="{Binding SetFilterPresetCommand}" CommandParameter="Fade">
                    <TextBlock Text="Fade" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
                <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                        Classes.active="{Binding LastAppliedFilterPresetName, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Kontrast}"
                        Command="{Binding SetFilterPresetCommand}"
                        CommandParameter="Kontrast">
                    <TextBlock Text="Kontrast" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
                <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                        Classes.active="{Binding LastAppliedFilterPresetName, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Sepia}"
                        Command="{Binding SetFilterPresetCommand}" CommandParameter="Sepia">
                    <TextBlock Text="Sepia" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
                <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                        Classes.active="{Binding LastAppliedFilterPresetName, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Matt}"
                        Command="{Binding SetFilterPresetCommand}" CommandParameter="Matt">
                    <TextBlock Text="Matt" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
                <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                        Classes.active="{Binding LastAppliedFilterPresetName, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Cross}"
                        Command="{Binding SetFilterPresetCommand}" CommandParameter="Cross">
                    <TextBlock Text="Cross" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
                <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                        Classes.active="{Binding LastAppliedFilterPresetName, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Dramatisch}"
                        Command="{Binding SetFilterPresetCommand}"
                        CommandParameter="Dramatisch">
                    <TextBlock Text="Dramatisch" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
                <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                        Classes.active="{Binding LastAppliedFilterPresetName, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Weich}"
                        Command="{Binding SetFilterPresetCommand}" CommandParameter="Weich">
                    <TextBlock Text="Weich" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
                <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                        Classes.active="{Binding LastAppliedFilterPresetName, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Noir}"
                        Command="{Binding SetFilterPresetCommand}" CommandParameter="Noir">
                    <TextBlock Text="Noir" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
                <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                        Classes.active="{Binding LastAppliedFilterPresetName, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Duoton}"
                        Command="{Binding SetFilterPresetCommand}"
                        CommandParameter="Duoton">
                    <TextBlock Text="Duoton" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
                <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                        Classes.active="{Binding LastAppliedFilterPresetName, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Polaroid}"
                        Command="{Binding SetFilterPresetCommand}"
                        CommandParameter="Polaroid">
                    <TextBlock Text="Polaroid" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
                <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                        Classes.active="{Binding LastAppliedFilterPresetName, Converter={StaticResource StringEqualsConverter}, ConverterParameter=VHS}"
                        Command="{Binding SetFilterPresetCommand}" CommandParameter="VHS">
                    <TextBlock Text="VHS" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
                <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                        Classes.active="{Binding LastAppliedFilterPresetName, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Alt}"
                        Command="{Binding SetFilterPresetCommand}" CommandParameter="Alt">
                    <TextBlock Text="Alt" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
            </WrapPanel>
        </StackPanel>
    </Expander>
</UserControl>
