<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:FerrumPix.Controls"
             x:Class="FerrumPix.Controls.EditorPanels.CropPanel">
    <Expander Header="Zuschneiden" icons:ExpanderState.Key="crop">
        <Expander.HeaderTemplate>
            <DataTemplate>
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <icons:SvgIcon
                            Source="avares://FerrumPix/Assets/Icons/outline/crop.svg"
                            Width="14" Height="14" />
                        <TextBlock Text="{Binding}" FontWeight="SemiBold" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Classes="icon-btn group-reset"
                            Width="28"
                            Height="28"
                            Padding="0"
                            Command="{Binding DataContext.ResetCropCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            ToolTip.Tip="Ausschnitt zurücksetzen">
                        <icons:SvgIcon
                            Source="avares://FerrumPix/Assets/Icons/outline/rotate-clockwise.svg"
                            Width="14" Height="14" />
                    </Button>
                </Grid>
            </DataTemplate>
        </Expander.HeaderTemplate>
        <StackPanel Spacing="8" Margin="0,8,0,0">
            <Grid ColumnDefinitions="92,*,62" VerticalAlignment="Center">
                <TextBlock Text="Links" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
                <icons:RoundSlider Grid.Column="1" Minimum="0"
                                   Maximum="{Binding CropMaxHorizontalPixels}"
                                   DefaultValue="0"
                                   Value="{Binding CropLeftPixels}" Margin="0,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding CropLeftPixels, Mode=TwoWay}"
                                         Minimum="0" Maximum="{Binding CropMaxHorizontalPixels}"
                                         Increment="1" FormatString="F0"
                                         ToolTip.Tip="Pixel, die links abgeschnitten werden" />
            </Grid>
            <Grid ColumnDefinitions="92,*,62" VerticalAlignment="Center">
                <TextBlock Text="Oben" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
                <icons:RoundSlider Grid.Column="1" Minimum="0"
                                   Maximum="{Binding CropMaxVerticalPixels}"
                                   DefaultValue="0"
                                   Value="{Binding CropTopPixels}" Margin="0,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding CropTopPixels, Mode=TwoWay}"
                                         Minimum="0" Maximum="{Binding CropMaxVerticalPixels}"
                                         Increment="1" FormatString="F0"
                                         ToolTip.Tip="Pixel, die oben abgeschnitten werden" />
            </Grid>
            <Grid ColumnDefinitions="92,*,62" VerticalAlignment="Center">
                <TextBlock Text="Rechts" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
                <icons:RoundSlider Grid.Column="1" Minimum="0"
                                   Maximum="{Binding CropMaxHorizontalPixels}"
                                   DefaultValue="0"
                                   Value="{Binding CropRightPixels}" Margin="0,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding CropRightPixels, Mode=TwoWay}"
                                         Minimum="0" Maximum="{Binding CropMaxHorizontalPixels}"
                                         Increment="1" FormatString="F0"
                                         ToolTip.Tip="Pixel, die rechts abgeschnitten werden" />
            </Grid>
            <Grid ColumnDefinitions="92,*,62" VerticalAlignment="Center">
                <TextBlock Text="Unten" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
                <icons:RoundSlider Grid.Column="1" Minimum="0"
                                   Maximum="{Binding CropMaxVerticalPixels}"
                                   DefaultValue="0"
                                   Value="{Binding CropBottomPixels}" Margin="0,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding CropBottomPixels, Mode=TwoWay}"
                                         Minimum="0" Maximum="{Binding CropMaxVerticalPixels}"
                                         Increment="1" FormatString="F0"
                                         ToolTip.Tip="Pixel, die unten abgeschnitten werden" />
            </Grid>
            <Grid ColumnDefinitions="92,*,Auto" VerticalAlignment="Center">
                <TextBlock Text="Breite" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
                <NumericUpDown Classes="combo-like" Grid.Column="1"
                               Value="{Binding CropWidthPixels}" Minimum="1"
                               Maximum="50000" Increment="1" Margin="6,0,0,0" FontSize="{DynamicResource FP.Font.Small}" />
                <TextBlock Grid.Column="2" Text="px"
                           Foreground="{DynamicResource FP.Text.Secondary}"
                           Margin="8,0,0,0" VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
            </Grid>
            <Grid ColumnDefinitions="92,*,Auto" VerticalAlignment="Center">
                <TextBlock Text="Höhe" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
                <NumericUpDown Classes="combo-like" Grid.Column="1"
                               Value="{Binding CropHeightPixels}" Minimum="1"
                               Maximum="50000" Increment="1" Margin="6,0,0,0" FontSize="{DynamicResource FP.Font.Small}" />
                <TextBlock Grid.Column="2" Text="px"
                           Foreground="{DynamicResource FP.Text.Secondary}"
                           Margin="8,0,0,0" VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
            </Grid>
            <WrapPanel>
                <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                        Command="{Binding SetCropPresetCommand}"
                        CommandParameter="Original">
                    <TextBlock Text="Original" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
                <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                        Command="{Binding SetCropPresetCommand}" CommandParameter="1:1">
                    <TextBlock Text="1:1" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
                <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                        Command="{Binding SetCropPresetCommand}" CommandParameter="4:3">
                    <TextBlock Text="4:3" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
                <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                        Command="{Binding SetCropPresetCommand}" CommandParameter="3:2">
                    <TextBlock Text="3:2" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
                <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                        Command="{Binding SetCropPresetCommand}" CommandParameter="16:9">
                    <TextBlock Text="16:9" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
                <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                        Command="{Binding SetCropPresetCommand}" CommandParameter="9:16">
                    <TextBlock Text="9:16" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
            </WrapPanel>
            <Button Classes="accent"
                    HorizontalAlignment="Stretch"
                    Padding="10,6"
                    Command="{Binding ApplyCropCommand}"
                    IsEnabled="{Binding HasCropChanges}"
                    ToolTip.Tip="Ausschnitt auf die Vorschau anwenden">
                <StackPanel Orientation="Horizontal" Spacing="6"
                            HorizontalAlignment="Center">
                    <icons:SvgIcon
                        Source="avares://FerrumPix/Assets/Icons/outline/crop.svg"
                        Width="16" Height="16" />
                    <TextBlock Text="Zuschneiden anwenden" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Expander>
</UserControl>
