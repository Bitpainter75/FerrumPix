<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:FerrumPix.Controls"
             x:Class="FerrumPix.Controls.EditorPanels.EffectsPanel">
    <StackPanel Spacing="7">
        <Expander Header="Vignette" IsExpanded="True">
            <Expander.HeaderTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    VerticalAlignment="Center">
                            <icons:SvgIcon
                                Source="avares://FerrumPix/Assets/Icons/outline/frame.svg"
                                Width="14" Height="14" />
                            <TextBlock Text="{Binding}" FontWeight="SemiBold" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Classes="icon-btn"
                                Width="28"
                                Height="28"
                                Padding="0"
                                Command="{Binding DataContext.ResetEffectsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                ToolTip.Tip="Effekte zurücksetzen">
                            <icons:SvgIcon
                                Source="avares://FerrumPix/Assets/Icons/outline/rotate-clockwise.svg"
                                Width="14" Height="14" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </Expander.HeaderTemplate>
            <StackPanel Spacing="2" Margin="0,8,0,0">
                <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                    <TextBlock Text="Stärke" Foreground="{DynamicResource FP.Text.Secondary}"
                               VerticalAlignment="Center" FontSize="11" />
                    <icons:RoundSlider Grid.Column="1" Minimum="-150" Maximum="150"
                                       Value="{Binding Vignette}" Margin="6,0" />
                    <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                             Value="{Binding Vignette, Mode=TwoWay}" Minimum="-150" Maximum="150" />
                </Grid>
                <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                    <TextBlock Text="Übergang" Foreground="{DynamicResource FP.Text.Secondary}"
                               VerticalAlignment="Center" FontSize="11" />
                    <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                                       DefaultValue="55"
                                       Value="{Binding VignetteTransition}" Margin="6,0" />
                    <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                             Value="{Binding VignetteTransition, Mode=TwoWay}" Minimum="0" Maximum="100" />
                </Grid>
                <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                    <TextBlock Text="Rundheit" Foreground="{DynamicResource FP.Text.Secondary}"
                               VerticalAlignment="Center" FontSize="11" />
                    <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100"
                                       Value="{Binding VignetteRoundness}" Margin="6,0" />
                    <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                             Value="{Binding VignetteRoundness, Mode=TwoWay}" Minimum="-100" Maximum="100" />
                </Grid>
                <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                    <TextBlock Text="Weiche Kante" Foreground="{DynamicResource FP.Text.Secondary}"
                               VerticalAlignment="Center" FontSize="11" TextWrapping="Wrap" />
                    <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                                       DefaultValue="70"
                                       Value="{Binding VignetteFeather}" Margin="6,0" />
                    <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                             Value="{Binding VignetteFeather, Mode=TwoWay}" Minimum="0" Maximum="100" />
                </Grid>
                <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                    <TextBlock Text="Mitte X" Foreground="{DynamicResource FP.Text.Secondary}"
                               VerticalAlignment="Center" FontSize="11" />
                    <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                                       DefaultValue="50"
                                       Value="{Binding VignetteCenterX}" Margin="6,0" />
                    <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                             Value="{Binding VignetteCenterX, Mode=TwoWay}" Minimum="0" Maximum="100" />
                </Grid>
                <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                    <TextBlock Text="Mitte Y" Foreground="{DynamicResource FP.Text.Secondary}"
                               VerticalAlignment="Center" FontSize="11" />
                    <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                                       DefaultValue="50"
                                       Value="{Binding VignetteCenterY}" Margin="6,0" />
                    <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                             Value="{Binding VignetteCenterY, Mode=TwoWay}" Minimum="0" Maximum="100" />
                </Grid>
            </StackPanel>
        </Expander>

        <Expander Header="Rahmen" IsExpanded="True">
            <Expander.HeaderTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    VerticalAlignment="Center">
                            <icons:SvgIcon
                                Source="avares://FerrumPix/Assets/Icons/outline/frame.svg"
                                Width="14" Height="14" />
                            <TextBlock Text="{Binding}" FontWeight="SemiBold" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Classes="icon-btn"
                                Width="28"
                                Height="28"
                                Padding="0"
                                Command="{Binding DataContext.ResetEffectsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                ToolTip.Tip="Rahmen zurücksetzen">
                            <icons:SvgIcon
                                Source="avares://FerrumPix/Assets/Icons/outline/rotate-clockwise.svg"
                                Width="14" Height="14" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </Expander.HeaderTemplate>
            <StackPanel Spacing="2" Margin="0,8,0,0">
                <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                    <TextBlock Text="Größe" Foreground="{DynamicResource FP.Text.Secondary}"
                               VerticalAlignment="Center" FontSize="11" />
                    <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="25"
                                       Value="{Binding BorderSize}" Margin="6,0" />
                    <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                             Value="{Binding BorderSize, Mode=TwoWay}" Minimum="0" Maximum="25" />
                </Grid>
                <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                    <TextBlock Text="Rundung" Foreground="{DynamicResource FP.Text.Secondary}"
                               VerticalAlignment="Center" FontSize="11" />
                    <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                                       Value="{Binding BorderCornerRadius}" Margin="6,0" />
                    <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                             Value="{Binding BorderCornerRadius, Mode=TwoWay}" Minimum="0" Maximum="100" />
                </Grid>
                <Grid ColumnDefinitions="74,*" VerticalAlignment="Center">
                    <TextBlock Text="Rahmenart" Foreground="{DynamicResource FP.Text.Secondary}"
                               VerticalAlignment="Center" FontSize="11" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding BorderEffectOptions}"
                              SelectedItem="{Binding BorderEffect}"
                              FontSize="11"
                              Margin="6,0,0,0"
                              DropDownOpened="OnMatchWidthDropDownOpened" />
                </Grid>
                <Grid ColumnDefinitions="74,*" VerticalAlignment="Top">
                    <TextBlock Text="Farbe" Foreground="{DynamicResource FP.Text.Secondary}"
                               VerticalAlignment="Center" FontSize="11" />
                    <StackPanel Grid.Column="1" Margin="6,0,0,0" Spacing="6">
                        <icons:ColorPickerButton
                            SelectedColor="{Binding BorderColorValue, Mode=TwoWay}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Expander>
    </StackPanel>
</UserControl>
