<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:FerrumPix.Controls"
             x:Class="FerrumPix.Controls.EditorPanels.AnnotationPropertiesPanel">
    <!-- Kopfzeile benennt das Werkzeug bzw. den Objekttyp, dessen Eigenschaften hier stehen. -->
    <Expander Header="{Binding CurrentToolLabel}" IsExpanded="True">
        <Expander.HeaderTemplate>
            <DataTemplate>
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <icons:SvgIcon
                        Source="{Binding DataContext.CurrentToolIconSource, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Width="14" Height="14" />
                    <TextBlock Text="{Binding}" FontWeight="SemiBold" />
                </StackPanel>
            </DataTemplate>
        </Expander.HeaderTemplate>
        <StackPanel Spacing="10" Margin="0,8,0,0">
            <StackPanel Spacing="6" IsVisible="{Binding ShowWatermarkPresetControls}">
            <Grid ColumnDefinitions="92,*" VerticalAlignment="Center">
                <TextBlock Text="Vorlage" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
                <ComboBox Grid.Column="1"
                          Margin="6,0,0,0"
                          ItemsSource="{Binding WatermarkPresetNames}"
                          SelectedItem="{Binding SelectedWatermarkPresetName}"
                          FontSize="{DynamicResource FP.Font.Small}"
                          HorizontalAlignment="Stretch" />
            </Grid>
            <Grid ColumnDefinitions="92,*" VerticalAlignment="Center">
                <TextBlock Text="Name" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
                <TextBox Grid.Column="1"
                         Margin="6,0,0,0"
                         Text="{Binding WatermarkPresetNameDraft}"
                         HorizontalAlignment="Stretch"
                         FontSize="{DynamicResource FP.Font.Small}" />
            </Grid>
            <Grid ColumnDefinitions="92,*">
                <StackPanel Grid.Column="1" Margin="6,0,0,0" Orientation="Horizontal" Spacing="6">
                    <Button Classes="ghost" Padding="8,4" Click="OnWatermarkSavePresetClick">
                        <TextBlock Text="Speichern" FontSize="{DynamicResource FP.Font.Small}" />
                    </Button>
                    <Button Classes="ghost" Padding="8,4" Click="OnWatermarkDeletePresetClick">
                        <TextBlock Text="Löschen" FontSize="{DynamicResource FP.Font.Small}" />
                    </Button>
                </StackPanel>
            </Grid>
            <Grid ColumnDefinitions="92,*" VerticalAlignment="Center">
                <TextBlock Text="Quelle" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
                <StackPanel Grid.Column="1" Margin="6,0,0,0" Orientation="Horizontal" Spacing="6">
                    <Button Classes="ghost" Padding="8,4" Click="OnWatermarkChooseImageClick">
                        <TextBlock Text="Bild einfügen" FontSize="{DynamicResource FP.Font.Small}" />
                    </Button>
                    <Button Classes="ghost" Padding="8,4" Click="OnWatermarkClearImageClick">
                        <TextBlock Text="Text" FontSize="{DynamicResource FP.Font.Small}" />
                    </Button>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Bild-Werkzeug: derselbe Weg wie beim Wasserzeichen - Datei wählen, Objekt erscheint. -->
        <Grid ColumnDefinitions="92,*" VerticalAlignment="Center"
              IsVisible="{Binding ShowImageSourceControls}">
            <TextBlock Text="Quelle" Foreground="{DynamicResource FP.Text.Secondary}"
                       VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
            <Button Grid.Column="1" Margin="6,0,0,0" Classes="ghost" Padding="8,4"
                    HorizontalAlignment="Left"
                    Click="OnInsertImageClick">
                <TextBlock Text="Bild einfügen" FontSize="{DynamicResource FP.Font.Small}" />
            </Button>
        </Grid>
        <TextBox Text="{Binding AnnotationText}"
                 PlaceholderText="Text, QR-Inhalt oder Symbol eingeben"
                 FontSize="{DynamicResource FP.Font.Body}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MaxHeight="70"
                 IsVisible="{Binding ShowTextContentControls}" />
        <Grid ColumnDefinitions="92,*" VerticalAlignment="Center"
              IsVisible="{Binding ShowFontControls}">
            <TextBlock Text="Schrift" Foreground="{DynamicResource FP.Text.Secondary}"
                       VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding AnnotationFontOptions}"
                      SelectedItem="{Binding AnnotationFontFamily}"
                      FontSize="{DynamicResource FP.Font.Small}"
                      Margin="6,0,0,0"
                      HorizontalAlignment="Stretch"
                      DropDownOpened="OnMatchWidthDropDownOpened" />
        </Grid>
        <Grid ColumnDefinitions="92,*,44" VerticalAlignment="Center"
              IsVisible="{Binding ShowFontControls}">
            <TextBlock Text="Größe" Foreground="{DynamicResource FP.Text.Secondary}"
                       VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
            <icons:RoundSlider Grid.Column="1" Minimum="8" Maximum="5000"
                               DefaultValue="8"
                               Value="{Binding AnnotationFontSizePixels}" Margin="0,0" />
            <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                     Value="{Binding AnnotationFontSizePixels, Mode=TwoWay}"
                                     Minimum="8" Maximum="5000" Increment="1"
                                     FormatString="F0" />
        </Grid>
        <!-- Beim QR-Code werden Hintergrund und Vordergrund über den Farbmischer gesetzt. -->
        <Grid ColumnDefinitions="92,*" VerticalAlignment="Top"
              IsVisible="{Binding ShowFillColorPicker}">
            <TextBlock Text="{Binding FillColorLabel}"
                       Foreground="{DynamicResource FP.Text.Secondary}"
                       VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
            <StackPanel Grid.Column="1" Margin="6,0,0,0" Spacing="6">
                <icons:ColorPickerButton
                    SelectedColor="{Binding AnnotationFillColorValue, Mode=TwoWay}" />
            </StackPanel>
        </Grid>
        <Grid ColumnDefinitions="92,*" VerticalAlignment="Center"
              IsVisible="{Binding ShowFillColorControls}">
            <TextBlock Text="Füllart" Foreground="{DynamicResource FP.Text.Secondary}"
                       VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                        Margin="6,0,0,0">
                <Button Classes="ghost" Padding="8,4"
                        Command="{Binding SetAnnotationFillKindCommand}"
                        CommandParameter="Solid"
                        Classes.active="{Binding AnnotationFillKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Solid}">
                    <TextBlock Text="Vollfarbe" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
                <Button Classes="ghost" Padding="8,4"
                        Command="{Binding SetAnnotationFillKindCommand}"
                        CommandParameter="LinearGradient"
                        Classes.active="{Binding AnnotationFillKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=LinearGradient}">
                    <TextBlock Text="Verlauf" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
                <Button Classes="ghost" Padding="8,4"
                        Command="{Binding SetAnnotationFillKindCommand}"
                        CommandParameter="RadialGradient"
                        Classes.active="{Binding AnnotationFillKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=RadialGradient}">
                    <TextBlock Text="Radial" FontSize="{DynamicResource FP.Font.Small}" />
                </Button>
            </StackPanel>
        </Grid>
        <Grid ColumnDefinitions="92,*" VerticalAlignment="Top"
              IsVisible="{Binding ShowGradientFillControls}">
            <TextBlock Text="Verlauf bis" Foreground="{DynamicResource FP.Text.Secondary}"
                       VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
            <StackPanel Grid.Column="1" Margin="6,0,0,0" Spacing="6">
                <icons:ColorPickerButton
                    SelectedColor="{Binding AnnotationFillColor2Value, Mode=TwoWay}" />
            </StackPanel>
        </Grid>
        <Grid ColumnDefinitions="92,*,44" VerticalAlignment="Center"
              IsVisible="{Binding ShowLinearGradientAngleControl}">
            <TextBlock Text="Winkel" Foreground="{DynamicResource FP.Text.Secondary}"
                       VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
            <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="360"
                               DefaultValue="0"
                               Value="{Binding AnnotationGradientAngleDegrees}"
                               Margin="0,0" />
            <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                     Value="{Binding AnnotationGradientAngleDegrees, Mode=TwoWay}"
                                     Minimum="0" Maximum="360" Increment="1"
                                     FormatString="F0" />
        </Grid>
        <CheckBox Content="Verlauf invertieren"
                  IsChecked="{Binding AnnotationGradientInverted}" FontSize="{DynamicResource FP.Font.Small}"
                  IsVisible="{Binding ShowRadialGradientControl}" />
        <Grid ColumnDefinitions="92,*" VerticalAlignment="Top"
              IsVisible="{Binding ShowStrokeColorPicker}">
            <TextBlock Text="{Binding StrokeColorLabel}"
                       Foreground="{DynamicResource FP.Text.Secondary}"
                       VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
            <StackPanel Grid.Column="1" Margin="6,0,0,0" Spacing="6">
                <icons:ColorPickerButton
                    SelectedColor="{Binding AnnotationStrokeColorValue, Mode=TwoWay}" />
            </StackPanel>
        </Grid>
        <Grid ColumnDefinitions="92,*,44" VerticalAlignment="Center"
              IsVisible="{Binding ShowStrokeWidthControls}">
            <TextBlock Text="Konturbreite" Foreground="{DynamicResource FP.Text.Secondary}"
                       VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" TextWrapping="Wrap" />
            <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                               DefaultValue="0"
                               Value="{Binding AnnotationStrokeWidth}" Margin="0,0" />
            <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                     Value="{Binding AnnotationStrokeWidth, Mode=TwoWay}"
                                     Minimum="0" Maximum="100" Increment="1"
                                     FormatString="F0" />
        </Grid>
        <Grid ColumnDefinitions="92,*,44" VerticalAlignment="Center">
            <TextBlock Text="Deckkraft" Foreground="{DynamicResource FP.Text.Secondary}"
                       VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
            <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                               DefaultValue="100"
                               Value="{Binding AnnotationOpacity}" Margin="0,0" />
            <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                     Value="{Binding AnnotationOpacity, Mode=TwoWay}"
                                     Minimum="0" Maximum="100" Increment="1"
                                     FormatString="F0" />
        </Grid>
        <Grid ColumnDefinitions="92,*" VerticalAlignment="Center">
            <TextBlock Text="Mischen" Foreground="{DynamicResource FP.Text.Secondary}"
                       VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
            <ComboBox Grid.Column="1"
                      Margin="6,0,0,0"
                      ItemsSource="{Binding AnnotationBlendModeOptions}"
                      SelectedItem="{Binding SelectedAnnotationBlendModeOption, Mode=TwoWay}"
                      FontSize="{DynamicResource FP.Font.Small}"
                      HorizontalAlignment="Stretch" />
        </Grid>
        <Grid ColumnDefinitions="92,*,44" VerticalAlignment="Center">
            <TextBlock Text="Drehung" Foreground="{DynamicResource FP.Text.Secondary}"
                       VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
            <icons:RoundSlider Grid.Column="1" Minimum="-180" Maximum="180"
                               DefaultValue="0"
                               Value="{Binding AnnotationRotation}" WheelIncrement="0.01"
                               DragIncrement="0.01" Margin="0,0" />
            <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                     Value="{Binding AnnotationRotation, Mode=TwoWay}"
                                     Minimum="-180" Maximum="180" Increment="0.01"
                                     FormatString="F2" />
        </Grid>
        <Grid ColumnDefinitions="92,*" VerticalAlignment="Top"
              IsVisible="{Binding ShowWatermarkAnchorControls}">
            <TextBlock Text="Anker" Foreground="{DynamicResource FP.Text.Secondary}"
                       VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
            <Border Grid.Column="1"
                    HorizontalAlignment="Left"
                    BorderBrush="{DynamicResource FP.Border.Normal}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8"
                    Margin="6,0,0,0">
                <Grid Width="84" Height="84" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Row="0" Grid.Column="0" Classes="anchor-dot" Command="{Binding SetAnnotationAnchorCommand}" CommandParameter="TopLeft">
                        <Grid>
                            <Border Classes="anchor-dot-idle" />
                            <Border Classes="anchor-dot-active" IsVisible="{Binding AnnotationAnchor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=TopLeft}" />
                        </Grid>
                    </Button>
                    <Button Grid.Row="0" Grid.Column="1" Classes="anchor-dot" Command="{Binding SetAnnotationAnchorCommand}" CommandParameter="Top">
                        <Grid>
                            <Border Classes="anchor-dot-idle" />
                            <Border Classes="anchor-dot-active" IsVisible="{Binding AnnotationAnchor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Top}" />
                        </Grid>
                    </Button>
                    <Button Grid.Row="0" Grid.Column="2" Classes="anchor-dot" Command="{Binding SetAnnotationAnchorCommand}" CommandParameter="TopRight">
                        <Grid>
                            <Border Classes="anchor-dot-idle" />
                            <Border Classes="anchor-dot-active" IsVisible="{Binding AnnotationAnchor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=TopRight}" />
                        </Grid>
                    </Button>
                    <Button Grid.Row="1" Grid.Column="0" Classes="anchor-dot" Command="{Binding SetAnnotationAnchorCommand}" CommandParameter="Left">
                        <Grid>
                            <Border Classes="anchor-dot-idle" />
                            <Border Classes="anchor-dot-active" IsVisible="{Binding AnnotationAnchor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Left}" />
                        </Grid>
                    </Button>
                    <Button Grid.Row="1" Grid.Column="1" Classes="anchor-dot" Command="{Binding SetAnnotationAnchorCommand}" CommandParameter="Center">
                        <Grid>
                            <Border Classes="anchor-dot-idle" />
                            <Border Classes="anchor-dot-active" IsVisible="{Binding AnnotationAnchor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Center}" />
                        </Grid>
                    </Button>
                    <Button Grid.Row="1" Grid.Column="2" Classes="anchor-dot" Command="{Binding SetAnnotationAnchorCommand}" CommandParameter="Right">
                        <Grid>
                            <Border Classes="anchor-dot-idle" />
                            <Border Classes="anchor-dot-active" IsVisible="{Binding AnnotationAnchor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Right}" />
                        </Grid>
                    </Button>
                    <Button Grid.Row="2" Grid.Column="0" Classes="anchor-dot" Command="{Binding SetAnnotationAnchorCommand}" CommandParameter="BottomLeft">
                        <Grid>
                            <Border Classes="anchor-dot-idle" />
                            <Border Classes="anchor-dot-active" IsVisible="{Binding AnnotationAnchor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=BottomLeft}" />
                        </Grid>
                    </Button>
                    <Button Grid.Row="2" Grid.Column="1" Classes="anchor-dot" Command="{Binding SetAnnotationAnchorCommand}" CommandParameter="Bottom">
                        <Grid>
                            <Border Classes="anchor-dot-idle" />
                            <Border Classes="anchor-dot-active" IsVisible="{Binding AnnotationAnchor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Bottom}" />
                        </Grid>
                    </Button>
                    <Button Grid.Row="2" Grid.Column="2" Classes="anchor-dot" Command="{Binding SetAnnotationAnchorCommand}" CommandParameter="BottomRight">
                        <Grid>
                            <Border Classes="anchor-dot-idle" />
                            <Border Classes="anchor-dot-active" IsVisible="{Binding AnnotationAnchor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=BottomRight}" />
                        </Grid>
                    </Button>
                </Grid>
            </Border>
        </Grid>
        <StackPanel Spacing="6">
            <Grid ColumnDefinitions="92,*,44">
                <TextBlock Text="{Binding AnnotationXLabel}" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
                <icons:RoundSlider Grid.Column="1"
                                   Minimum="{Binding AnnotationXSliderMinimum}"
                                   Maximum="{Binding AnnotationXSliderMaximum}"
                                   Value="{Binding AnnotationXSliderValue}"
                                   DragIncrement="{Binding AnnotationSliderDragIncrement}"
                                   WheelIncrement="{Binding AnnotationSliderWheelIncrement}"
                                   Margin="0,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                             Value="{Binding AnnotationXPixels, Mode=TwoWay}"
                                             Minimum="{Binding AnnotationXSliderMinimum}"
                                             Maximum="{Binding AnnotationXSliderMaximum}"
                                             Increment="1"
                                             FormatString="F0" />
            </Grid>
            <Grid ColumnDefinitions="92,*,44">
                <TextBlock Text="{Binding AnnotationYLabel}" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
                <icons:RoundSlider Grid.Column="1"
                                   Minimum="{Binding AnnotationYSliderMinimum}"
                                   Maximum="{Binding AnnotationYSliderMaximum}"
                                   Value="{Binding AnnotationYSliderValue}"
                                   DragIncrement="{Binding AnnotationSliderDragIncrement}"
                                   WheelIncrement="{Binding AnnotationSliderWheelIncrement}"
                                   Margin="0,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                             Value="{Binding AnnotationYPixels, Mode=TwoWay}"
                                             Minimum="{Binding AnnotationYSliderMinimum}"
                                             Maximum="{Binding AnnotationYSliderMaximum}"
                                             Increment="1"
                                             FormatString="F0" />
            </Grid>
            <Grid ColumnDefinitions="92,*,44">
                <TextBlock Text="Breite" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
                <icons:RoundSlider Grid.Column="1"
                                   Minimum="{Binding AnnotationWidthSliderMinimum}"
                                   Maximum="{Binding AnnotationWidthSliderMaximum}"
                                   Value="{Binding AnnotationWidthPixels}"
                                   DragIncrement="{Binding AnnotationSliderDragIncrement}"
                                   WheelIncrement="{Binding AnnotationSliderWheelIncrement}"
                                   Margin="0,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding AnnotationWidthPixels, Mode=TwoWay}"
                                         Minimum="{Binding AnnotationWidthSliderMinimum}"
                                         Maximum="{Binding AnnotationWidthSliderMaximum}"
                                         Increment="1"
                                         FormatString="F0" />
            </Grid>
            <Grid ColumnDefinitions="92,*,44">
                <TextBlock Text="Höhe" Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
                <icons:RoundSlider Grid.Column="1"
                                   Minimum="{Binding AnnotationHeightSliderMinimum}"
                                   Maximum="{Binding AnnotationHeightSliderMaximum}"
                                   Value="{Binding AnnotationHeightPixels}"
                                   DragIncrement="{Binding AnnotationSliderDragIncrement}"
                                   WheelIncrement="{Binding AnnotationSliderWheelIncrement}"
                                   Margin="0,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding AnnotationHeightPixels, Mode=TwoWay}"
                                         Minimum="{Binding AnnotationHeightSliderMinimum}"
                                         Maximum="{Binding AnnotationHeightSliderMaximum}"
                                         Increment="1"
                                         FormatString="F0" />
            </Grid>
            </StackPanel>
        </StackPanel>
    </Expander>
</UserControl>
