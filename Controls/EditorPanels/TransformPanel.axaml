<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:FerrumPix.Controls"
             x:Class="FerrumPix.Controls.EditorPanels.TransformPanel">
    <Expander Header="Drehen" IsExpanded="True">
        <Expander.HeaderTemplate>
            <DataTemplate>
                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                VerticalAlignment="Center">
                        <icons:SvgIcon
                            Source="avares://FerrumPix/Assets/Icons/outline/frame.svg"
                            Width="14" Height="14" />
                        <TextBlock Text="{Binding}" FontWeight="SemiBold" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Classes="icon-btn"
                            Width="28"
                            Height="28"
                            Padding="0"
                            Command="{Binding DataContext.ResetTransformCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            ToolTip.Tip="Transformieren zurücksetzen">
                        <icons:SvgIcon
                            Source="avares://FerrumPix/Assets/Icons/outline/rotate-clockwise.svg"
                            Width="14" Height="14" />
                    </Button>
                </Grid>
            </DataTemplate>
        </Expander.HeaderTemplate>
        <StackPanel Spacing="2" Margin="0,8,0,0">
            <Grid ColumnDefinitions="*,*">
                <Button Classes="ghost" Padding="10,7" Margin="0,0,4,0"
                        Command="{Binding RotateLeftCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <icons:SvgIcon
                            Source="avares://FerrumPix/Assets/Icons/outline/rotate-2.svg"
                            Width="20" Height="20" />
                        <TextBlock Text="Links" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Classes="ghost" Padding="10,7" Margin="4,0,0,0"
                        Command="{Binding RotateRightCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <icons:SvgIcon
                            Source="avares://FerrumPix/Assets/Icons/outline/rotate-clockwise-2.svg"
                            Width="20" Height="20" />
                        <TextBlock Text="Rechts" />
                    </StackPanel>
                </Button>
            </Grid>
            <Grid ColumnDefinitions="74,*,44" VerticalAlignment="Center">
                <TextBlock Text="Ausrichten"
                           Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="11" />
                <icons:RoundSlider Grid.Column="1" Minimum="-180" Maximum="180"
                                   DefaultValue="0"
                                   Value="{Binding StraightenDegrees}" Margin="0,0" />
                <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                         Value="{Binding StraightenDegrees, Mode=TwoWay}"
                                         Minimum="-180" Maximum="180" Increment="0.01"
                                         FormatString="F2" />
            </Grid>
            <CheckBox Content="Leinwand automatisch vergrößern"
                      IsChecked="{Binding StraightenExpandCanvas}"
                      FontSize="11"
                      ToolTip.Tip="Vergrößert die Leinwand beim Ausrichten so, dass keine Bildecken abgeschnitten werden, statt das Bild zum Ausgleich hineinzuzoomen" />
            <Grid ColumnDefinitions="74,*" VerticalAlignment="Top"
                  IsVisible="{Binding StraightenExpandCanvas}">
                <TextBlock Text="Hintergrund"
                           Foreground="{DynamicResource FP.Text.Secondary}"
                           VerticalAlignment="Center" FontSize="11" />
                <icons:ColorPickerButton Grid.Column="1"
                                         SelectedColor="{Binding CanvasBackgroundColorValue, Mode=TwoWay}" />
            </Grid>
            <Grid ColumnDefinitions="*,*">
                <Button Classes="ghost" Padding="10,7" Margin="0,0,4,0"
                        Command="{Binding FlipHorizontalCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <icons:SvgIcon
                            Source="avares://FerrumPix/Assets/Icons/outline/flip-horizontal.svg"
                            Width="20" Height="20" />
                        <TextBlock Text="Horizontal" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" Classes="ghost" Padding="10,7" Margin="4,0,0,0"
                        Command="{Binding FlipVerticalCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <icons:SvgIcon
                            Source="avares://FerrumPix/Assets/Icons/outline/flip-vertical.svg"
                            Width="20" Height="20" />
                        <TextBlock Text="Vertikal" />
                    </StackPanel>
                </Button>
            </Grid>
            <Button Classes="accent"
                    HorizontalAlignment="Stretch"
                    Padding="10,6"
                    Margin="0,6,0,0"
                    Command="{Binding ApplyTransformCommand}"
                    IsEnabled="{Binding HasTransformChanges}"
                    ToolTip.Tip="Drehung auf die Vorschau anwenden">
                <StackPanel Orientation="Horizontal" Spacing="6"
                            HorizontalAlignment="Center">
                    <icons:SvgIcon
                        Source="avares://FerrumPix/Assets/Icons/outline/check.svg"
                        Width="16" Height="16" />
                    <TextBlock Text="Drehung annehmen" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Expander>
</UserControl>
