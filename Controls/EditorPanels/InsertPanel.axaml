<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:FerrumPix.Controls"
             xmlns:conv="clr-namespace:Avalonia.Data.Converters;assembly=Avalonia.Base"
             x:Class="FerrumPix.Controls.EditorPanels.InsertPanel">
    <StackPanel Spacing="7">
        <StackPanel Spacing="6" Margin="0,2,0,2">
            <!-- Ohne Expander-Kopf, wie der Farbmischer im Anpassen-Werkzeug: er steht ganz oben und
                 soll nicht wegklappbar sein.
                 Die Beschriftungen wechseln mit dem Objekttyp: beim QR-Code heißt die Füllfarbe
                 "Hintergrund" und die Konturfarbe "Vordergrund" (siehe FillColorLabel/StrokeColorLabel). -->
            <icons:ColorMixer FillColor="{Binding AnnotationFillColorValue, Mode=TwoWay}"
                              StrokeColor="{Binding AnnotationStrokeColorValue, Mode=TwoWay}"
                              SecondaryFillColor="{Binding AnnotationFillColor2Value, Mode=TwoWay}"
                              FillLabel="{Binding FillColorLabel}"
                              StrokeLabel="{Binding StrokeColorLabel}"
                              ShowFill="{Binding ShowFillColorControls}"
                              ShowSecondaryFill="{Binding ShowGradientFillControls}" />
        </StackPanel>

        <StackPanel Spacing="10">
            <!-- Text, Bild, QR und Wasserzeichen stehen einzeln in der Werkzeugleiste links. -->
            <Expander Header="Formen und Symbole" IsExpanded="True"
                      IsVisible="{Binding ShowShapeControls}">
                <Expander.HeaderTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <icons:SvgIcon
                                Source="avares://FerrumPix/Assets/Icons/outline/shape.svg"
                                Width="14" Height="14" />
                            <TextBlock Text="{Binding}" FontWeight="SemiBold" />
                        </StackPanel>
                    </DataTemplate>
                </Expander.HeaderTemplate>
                <ItemsRepeater ItemsSource="{Binding FixedShapeItems}" Margin="0,8,0,0">
                    <ItemsRepeater.Layout>
                        <WrapLayout />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Button Classes="ghost insert-option-btn compact"
                                    ToolTip.Tip="{Binding DisplayName}"
                                    Command="{Binding DataContext.SetPendingInsertKindCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding PendingKind}"
                                    Classes.active="{Binding IsPending}"
                                    Classes.selected-kind="{Binding IsSelectedKind}">
                                <icons:SvgIcon Source="{Binding IconPath}" Width="17"
                                               Height="17" />
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </Expander>

            <StackPanel Spacing="6" IsVisible="{Binding ShowSymbolControls}">
                <Grid>
                    <TextBox
                        Text="{Binding ShapeIconSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Symbol suchen…"
                        Padding="8,4,28,4"
                        FontSize="{DynamicResource FP.Font.Small}" />
                    <Button Classes="ghost"
                            Width="18"
                            Height="18"
                            Padding="0"
                            Margin="0,0,6,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Command="{Binding ClearShapeIconSearchCommand}"
                            IsVisible="{Binding ShapeIconSearchText, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}}"
                            ToolTip.Tip="Suche zurücksetzen">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/x.svg"
                                       Width="12"
                                       Height="12"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Opacity="0.75"/>
                    </Button>
                </Grid>
                <!-- Über viertausend Symbole: ein ItemsControl legt für jedes sofort einen Knopf an.
                     Der ItemsRepeater mit WrapLayout erzeugt nur die tatsächlich sichtbaren. -->
                <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">
                    <ItemsRepeater ItemsSource="{Binding FilteredShapeIcons}">
                        <ItemsRepeater.Layout>
                            <WrapLayout />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Button Classes="ghost insert-option-btn compact"
                                        ToolTip.Tip="{Binding DisplayName}"
                                        Command="{Binding DataContext.SetPendingInsertKindCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding PendingKind}"
                                        Classes.active="{Binding IsPending}"
                                        Classes.selected-kind="{Binding IsSelectedKind}">
                                    <icons:SvgIcon Source="{Binding IconPath}" Width="17"
                                                   Height="17" />
                                </Button>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>
