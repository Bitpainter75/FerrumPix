<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:FerrumPix.Controls"
             x:Class="FerrumPix.Controls.EditorPanels.SelectionPanel">
    <Expander Header="Auswahl" IsExpanded="True">
        <Expander.HeaderTemplate>
            <DataTemplate>
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <icons:SvgIcon
                        Source="avares://FerrumPix/Assets/Icons/outline/rectangle.svg"
                        Width="14" Height="14" />
                    <TextBlock Text="{Binding}" FontWeight="SemiBold" />
                </StackPanel>
            </DataTemplate>
        </Expander.HeaderTemplate>
        <StackPanel Spacing="8" Margin="0,8,0,0">

        <TextBlock Text="Werkzeug" Foreground="{DynamicResource FP.Text.Secondary}"
                   FontSize="{DynamicResource FP.Font.Small}" FontWeight="SemiBold" />
        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Stretch">
            <Button Classes="ghost" Padding="8,6"
                    Command="{Binding SetSelectionModeCommand}" CommandParameter="Move"
                    Classes.active="{Binding SelectionMode, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Move}"
                    ToolTip.Tip="Verschieben">
                <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/pointer.svg" Width="16" Height="16" />
            </Button>
            <Button Classes="ghost" Padding="8,6"
                    Command="{Binding SetSelectionModeCommand}" CommandParameter="Rectangle"
                    Classes.active="{Binding SelectionMode, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Rectangle}"
                    ToolTip.Tip="Rechteck aufziehen">
                <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/rectangle.svg" Width="16" Height="16" />
            </Button>
            <Button Classes="ghost" Padding="8,6"
                    Command="{Binding SetSelectionModeCommand}" CommandParameter="Ellipse"
                    Classes.active="{Binding SelectionMode, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Ellipse}"
                    ToolTip.Tip="Kreis/Ellipse aufziehen">
                <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/oval.svg" Width="16" Height="16" />
            </Button>
            <Button Classes="ghost" Padding="8,6"
                    Command="{Binding SetSelectionModeCommand}" CommandParameter="Lasso"
                    Classes.active="{Binding SelectionMode, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Lasso}"
                    ToolTip.Tip="Freihand-Auswahl (Lasso)">
                <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/lasso.svg" Width="16" Height="16" />
            </Button>
            <Button Classes="ghost" Padding="8,6"
                    Command="{Binding SetSelectionModeCommand}" CommandParameter="MagicWand"
                    Classes.active="{Binding SelectionMode, Converter={StaticResource StringEqualsConverter}, ConverterParameter=MagicWand}"
                    ToolTip.Tip="Zauberstab: zusammenhängende Farbfläche wählen">
                <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/wand.svg" Width="16" Height="16" />
            </Button>
        </StackPanel>

        <TextBlock Text="Modus" Foreground="{DynamicResource FP.Text.Secondary}"
                   FontSize="{DynamicResource FP.Font.Small}" FontWeight="SemiBold" />
        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Stretch">
            <Button Classes="ghost" Padding="8,6"
                    Command="{Binding SetSelectionCombineModeCommand}" CommandParameter="New"
                    Classes.active="{Binding IsSelectionCombineNew}"
                    ToolTip.Tip="Neue Auswahl erstellen">
                <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/square.svg" Width="16" Height="16" />
            </Button>
            <Button Classes="ghost" Padding="8,6"
                    Command="{Binding SetSelectionCombineModeCommand}" CommandParameter="Add"
                    Classes.active="{Binding IsSelectionCombineAdd}"
                    ToolTip.Tip="Zur bestehenden Auswahl hinzufügen">
                <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/square-plus.svg" Width="16" Height="16" />
            </Button>
            <Button Classes="ghost" Padding="8,6"
                    Command="{Binding SetSelectionCombineModeCommand}" CommandParameter="Subtract"
                    Classes.active="{Binding IsSelectionCombineSubtract}"
                    ToolTip.Tip="Von der bestehenden Auswahl abziehen">
                <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/square-minus.svg" Width="16" Height="16" />
            </Button>
            <Button Classes="ghost" Padding="8,6"
                    Command="{Binding SetSelectionCombineModeCommand}" CommandParameter="Intersect"
                    Classes.active="{Binding IsSelectionCombineIntersect}"
                    ToolTip.Tip="Schnittmenge mit bestehender Auswahl bilden">
                <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/squares.svg" Width="16" Height="16" />
            </Button>
            <Border Width="1"
                    Margin="4,4"
                    Background="{DynamicResource FP.Border.Normal}" />
            <Button Classes="ghost" Padding="8,6"
                    IsEnabled="{Binding HasActiveSelection}"
                    Command="{Binding InvertSelectionCommand}"
                    ToolTip.Tip="Auswahl umkehren">
                <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/arrows-exchange.svg" Width="16" Height="16" />
            </Button>
            <Button Classes="ghost" Padding="8,6"
                    IsEnabled="{Binding HasActiveSelection}"
                    Command="{Binding ClearSelectionCommand}"
                    ToolTip.Tip="Auswahl aufheben (Strg+D oder Esc)">
                <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/deselect.svg" Width="16" Height="16" />
            </Button>
        </StackPanel>

        <TextBlock Text="Auswahl im Bild erstellen, dann kopieren oder füllen."
                   Foreground="{DynamicResource FP.Text.Secondary}"
                   FontSize="{DynamicResource FP.Font.Small}"
                   TextWrapping="Wrap" />

        <!-- Zauberstab-Toleranz -->
        <Grid ColumnDefinitions="92,*,44" VerticalAlignment="Center"
              IsVisible="{Binding ShowMagicWandControls}">
            <TextBlock Text="Toleranz" Foreground="{DynamicResource FP.Text.Secondary}"
                       VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
            <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                               DefaultValue="15"
                               Value="{Binding SelectionTolerance}" Margin="0,0" />
            <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                     Value="{Binding SelectionTolerance, Mode=TwoWay}"
                                     Minimum="0" Maximum="100" Increment="1"
                                     FormatString="F0" />
        </Grid>
        <!-- Weiche Kante: wirkt auf Anpassungen in der Auswahl, auf Kopieren und auf Füllen. Die Maske
             selbst bleibt hart gespeichert, der Wert ist deshalb jederzeit nachträglich änderbar. -->
        <Grid ColumnDefinitions="92,*,44" VerticalAlignment="Center">
            <TextBlock Text="Weiche Kante" Foreground="{DynamicResource FP.Text.Secondary}"
                       VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}"
                       ToolTip.Tip="Lässt die Auswahlkante über die angegebene Anzahl Bildpixel weich auslaufen (0 = harte Kante)" />
            <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="200"
                               DefaultValue="0"
                               Value="{Binding SelectionFeather}" Margin="0,0" />
            <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                     Value="{Binding SelectionFeather, Mode=TwoWay}"
                                     Minimum="0" Maximum="200" Increment="1"
                                     FormatString="F0" />
        </Grid>
        <Button Classes="ghost"
                HorizontalAlignment="Stretch"
                Padding="10,6"
                IsEnabled="{Binding HasActiveSelection}"
                Command="{Binding CopySelectionCommand}"
                ToolTip.Tip="Auswahlinhalt als neues, frei verschiebbares Bild-Objekt kopieren">
            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/photo.svg"
                               Width="16" Height="16" />
                <TextBlock Text="Kopieren" />
            </StackPanel>
        </Button>

        <Border Height="1" Background="{DynamicResource FP.Border.Normal}" Margin="0,4,0,0" />
        <TextBlock Text="Füllen" Foreground="{DynamicResource FP.Text.Secondary}"
                   FontSize="{DynamicResource FP.Font.Small}" FontWeight="SemiBold" />
        <!-- WrapPanel statt StackPanel: die Beschriftungen sprengen sonst die Spaltenbreite.
             In der laengsten Sprache summieren sich "Vollfarbe|Verlauf|Radial" auf 28 Zeichen -
             im Deutschen passt es knapp, anderswo nicht. Umbruch statt fester Aufteilung, damit
             es sich nach der tatsaechlichen Breite richtet.
             Abstaende ueber Margin je Knopf, weil WrapPanel kein Spacing kennt. -->
        <WrapPanel Orientation="Horizontal">
            <Button Classes="ghost" Padding="8,4" Margin="0,0,6,4"
                    Command="{Binding SetAnnotationFillKindCommand}"
                    CommandParameter="Solid"
                    Classes.active="{Binding AnnotationFillKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Solid}">
                <TextBlock Text="Vollfarbe" FontSize="{DynamicResource FP.Font.Small}" />
            </Button>
            <Button Classes="ghost" Padding="8,4" Margin="0,0,6,4"
                    Command="{Binding SetAnnotationFillKindCommand}"
                    CommandParameter="LinearGradient"
                    Classes.active="{Binding AnnotationFillKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=LinearGradient}">
                <TextBlock Text="Verlauf" FontSize="{DynamicResource FP.Font.Small}" />
            </Button>
            <Button Classes="ghost" Padding="8,4" Margin="0,0,6,4"
                    Command="{Binding SetAnnotationFillKindCommand}"
                    CommandParameter="RadialGradient"
                    Classes.active="{Binding AnnotationFillKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=RadialGradient}">
                <TextBlock Text="Radial" FontSize="{DynamicResource FP.Font.Small}" />
            </Button>
        </WrapPanel>
        <Grid ColumnDefinitions="92,*" VerticalAlignment="Top">
            <TextBlock Text="Farbe 1" Foreground="{DynamicResource FP.Text.Secondary}"
                       VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
            <icons:ColorPickerButton Grid.Column="1"
                                     SelectedColor="{Binding AnnotationFillColorValue, Mode=TwoWay}" />
        </Grid>
        <Grid ColumnDefinitions="92,*" VerticalAlignment="Top"
              IsVisible="{Binding ShowGradientFillControls}">
            <TextBlock Text="Farbe 2" Foreground="{DynamicResource FP.Text.Secondary}"
                       VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
            <icons:ColorPickerButton Grid.Column="1"
                                     SelectedColor="{Binding AnnotationFillColor2Value, Mode=TwoWay}" />
        </Grid>
        <Grid ColumnDefinitions="92,*,44" VerticalAlignment="Center"
              IsVisible="{Binding ShowLinearGradientAngleControl}">
            <TextBlock Text="Winkel" Foreground="{DynamicResource FP.Text.Secondary}"
                       VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}" />
            <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="360"
                               DefaultValue="0"
                               Value="{Binding AnnotationGradientAngleDegrees}"
                               Margin="0,0" />
            <icons:SliderValueUpDown Grid.Column="2" Classes="slider-value"
                                     Value="{Binding AnnotationGradientAngleDegrees, Mode=TwoWay}"
                                     Minimum="0" Maximum="360" Increment="1"
                                     FormatString="F0" />
        </Grid>
        <CheckBox Content="Verlauf invertieren"
                  IsChecked="{Binding AnnotationGradientInverted}" FontSize="{DynamicResource FP.Font.Small}"
                  IsVisible="{Binding ShowRadialGradientControl}" />
        <Button Classes="accent"
                HorizontalAlignment="Stretch"
                Padding="10,6"
                IsEnabled="{Binding HasActiveSelection}"
                Command="{Binding FillSelectionCommand}"
                ToolTip.Tip="Auswahl mit der gewählten Füllung füllen">
            <TextBlock Text="Auswahl füllen" HorizontalAlignment="Center" />
        </Button>
        </StackPanel>
    </Expander>
</UserControl>
