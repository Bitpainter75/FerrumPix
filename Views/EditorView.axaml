<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:FerrumPix.Controls"
             xmlns:views="clr-namespace:FerrumPix.Views"
             xmlns:vm="clr-namespace:FerrumPix.ViewModels"
             xmlns:services="clr-namespace:FerrumPix.Services"
             xmlns:models="clr-namespace:FerrumPix.Models"
             xmlns:conv="clr-namespace:Avalonia.Data.Converters;assembly=Avalonia.Base"
             x:Class="FerrumPix.Views.EditorView"
             Classes="editor-view"
             Background="{DynamicResource FP.Bg.Root}"
             Focusable="True"
             FocusAdorner="{x:Null}"
             KeyDown="OnKeyDown"
             KeyUp="OnKeyUp"
             PointerReleased="OnGlobalPointerReleased">

    <Grid x:Name="EditorRootGrid" RowDefinitions="60,*,Auto" ColumnDefinitions="190,*,300,300">

        <Border Grid.Row="0" Grid.ColumnSpan="4" Classes="toolbar" Height="60" Padding="24,0">
            <Grid ColumnDefinitions="*,Auto,*" VerticalAlignment="Center">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Left">
                    <Button Classes="icon-btn" Width="38" Height="38"
                            Command="{Binding BackToViewerCommand}"
                            ToolTip.Tip="Zurück">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/01_Navigation/01_Home.svg"
                                       Width="20" Height="20" />
                    </Button>
                    <Button Classes="icon-btn" Width="38" Height="38"
                            Command="{Binding PreviousCommand}"
                            ToolTip.Tip="Vorheriges Bild">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/01_Navigation/02_Zurueck.svg"
                                       Width="20" Height="20" />
                    </Button>
                    <Button Classes="icon-btn" Width="38" Height="38"
                            Command="{Binding NextCommand}"
                            ToolTip.Tip="Nächstes Bild">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/01_Navigation/03_Vorwaerts.svg"
                                       Width="20" Height="20" />
                    </Button>
                    <StackPanel Margin="26,0,0,0" VerticalAlignment="Center" >
                        <TextBlock Text="{Binding CurrentFileName}" FontSize="14" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource FP.Text.Secondary}"
                                   FontSize="10" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="-110,0,0,0">
                    <Button Name="PanModeButton" Classes="ghost" Height="38" Padding="8,2"
                            Margin="0,0,0,0" ToolTip.Tip="Verschieben-Modus ein- oder ausschalten"
                            Focusable="False"
                            Click="OnPanModeToggleClick">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/07_Symbole/07_Pinnnadel.svg"
                                           Width="20" Height="20" />
                            <TextBlock Text="Verschieben" />
                        </StackPanel>
                    </Button>

                    <Button Classes="ghost"
                            Height="38"
                            Padding="8,2"
                            Margin="0,0,0,0"
                            IsEnabled="{Binding CanShowBeforeAfter}"
                            Classes.active="{Binding ShowBeforeImage}"
                            Click="OnToggleBeforeAfterClick"
                            ToolTip.Tip="Vergleich ein- oder ausblenden">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/07_Symbole/11_Auge.svg"
                                           Width="18" Height="18" />
                            <TextBlock Text="Vergleich" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                    
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Button Classes="icon-btn" Width="38" Height="38"
                            IsEnabled="{Binding CanUndo}"
                            Command="{Binding UndoCommand}"
                            ToolTip.Tip="Rückgängig">
                        <Canvas Width="20" Height="20">
                            <Path Stroke="{DynamicResource FP.Text.Secondary}"
                                  StrokeThickness="2"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round"
                                  Data="M 8 5 L 4 9 L 8 13 M 5 9 H 12 C 15 9 17 11 17 14 C 17 17 15 19 12 19 H 8" />
                        </Canvas>
                    </Button>
                    <Button Classes="icon-btn" Width="38" Height="38"
                            IsEnabled="{Binding CanRedo}"
                            Command="{Binding RedoCommand}"
                            ToolTip.Tip="Wiederholen">
                        <Canvas Width="20" Height="20">
                            <Path Stroke="{DynamicResource FP.Text.Secondary}"
                                  StrokeThickness="2"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round"
                                  Data="M 12 5 L 16 9 L 12 13 M 15 9 H 8 C 5 9 3 11 3 14 C 3 17 5 19 8 19 H 12" />
                        </Canvas>
                    </Button>
                    <Button Classes="accent" Height="38" Padding="16,7" Command="{Binding SaveCommand}"
                            IsEnabled="{Binding CanSaveInPlace}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/01_Navigation/09_Speichern.svg"
                                           Width="20" Height="20" />
                            <TextBlock Text="Speichern" />
                        </StackPanel>
                    </Button>
                    <Button Classes="ghost active" Height="38" Padding="12,7" Command="{Binding SaveAsCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/05_Dialoge/14_Speichern_unter.svg"
                                           Width="20" Height="20" />
                            <TextBlock Text="Speichern unter..." />
                        </StackPanel>
                    </Button>
                    <Button Classes="icon-btn"
                            Width="38" Height="38"
                            Command="{Binding DeleteCurrentCommand}"
                            ToolTip.Tip="Löschen">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/04_Viewer/35_Loeschen.svg"
                                       Width="18" Height="18" />
                    </Button>
                    <Button Classes="icon-btn"
                            Width="38" Height="38"
                            Click="OnToggleFilmstripClick"
                            Classes.active="{Binding ShowFilmstrip}"
                            ToolTip.Tip="Filmstreifen ein- oder ausblenden">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/07_Symbole/11_Auge.svg"
                                       Width="18" Height="18" />
                    </Button>
                    <Button Classes="icon-btn" Width="38" Height="38"
                            Classes.active="{Binding IsInfoSidebarVisible}"
                            Command="{Binding ToggleInfoSidebarCommand}"
                            ToolTip.Tip="Info-Seitenleiste">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/04_Viewer/01_Info.svg" Width="20"
                                       Height="20" />
                    </Button>
                    <Button Classes="icon-btn"
                            Width="38" Height="38"
                            Click="OnSettingsClick"
                            ToolTip.Tip="Einstellungen">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/01_Navigation/34_Einstellungen.svg"
                                       Width="18" Height="18" />
                    </Button>
                    <Button Classes="icon-btn" Width="38" Height="38"
                            Click="OnFullscreenClick"
                            ToolTip.Tip="Vollbild">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/01_Navigation/21_Vollbild.svg"
                                       Width="20" Height="20" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Classes="sidebar" Padding="8,8">
            <ScrollViewer VerticalScrollBarVisibility="Auto" FocusAdorner="{x:Null}">
                <StackPanel Spacing="2">
                    <TextBlock Text="TRANSFORMIEREN" Foreground="{DynamicResource FP.Text.Muted}" FontSize="10"
                               FontWeight="SemiBold" Margin="10,0,0,4" />
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Zuschneiden"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Crop"
                            Classes.active="{Binding CurrentTool, Converter={StaticResource EditorToolEqualsConverter}, ConverterParameter=Crop}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/03_Editor/01_Zuschneiden.svg"
                                           Width="18" Height="18" />
                            <TextBlock Text="Zuschneiden" FontSize="12" />
                        </StackPanel>
                    </Button>
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Bildgröße"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Resize"
                            Classes.active="{Binding CurrentTool, Converter={StaticResource EditorToolEqualsConverter}, ConverterParameter=Resize}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/04_Viewer/26_Seitenverhaeltnis.svg"
                                           Width="18" Height="18" />
                            <TextBlock Text="Bildgröße" FontSize="12" />
                        </StackPanel>
                    </Button>
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Drehen"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Rotate"
                            Classes.active="{Binding CurrentTool, Converter={StaticResource EditorToolEqualsConverter}, ConverterParameter=Rotate}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/03_Editor/03_Gerade_richten.svg"
                                           Width="18" Height="18" />
                            <TextBlock Text="Drehen" FontSize="12" />
                        </StackPanel>
                    </Button>

                    <TextBlock Text="ANPASSUNGEN" Foreground="{DynamicResource FP.Text.Muted}" FontSize="10"
                               FontWeight="SemiBold" Margin="10,10,0,4" />
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Anpassen"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Adjust"
                            Classes.active="{Binding CurrentTool, Converter={StaticResource EditorToolEqualsConverter}, ConverterParameter=Adjust}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/03_Editor/07_Belichtung.svg"
                                           Width="18" Height="18" />
                            <TextBlock Text="Anpassen" FontSize="12" />
                        </StackPanel>
                    </Button>
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Farbe"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Color"
                            Classes.active="{Binding CurrentTool, Converter={StaticResource EditorToolEqualsConverter}, ConverterParameter=Color}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/03_Editor/17_Farbmischer.svg"
                                           Width="18" Height="18" />
                            <TextBlock Text="Farbe" FontSize="12" />
                        </StackPanel>
                    </Button>

                    <TextBlock Text="DETAILS UND EFFEKTE" Foreground="{DynamicResource FP.Text.Muted}" FontSize="10"
                               FontWeight="SemiBold" Margin="10,10,0,4" />
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Details"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Effects"
                            Classes.active="{Binding CurrentTool, Converter={StaticResource EditorToolEqualsConverter}, ConverterParameter=Effects}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/03_Editor/24_Klarheit.svg"
                                           Width="18" Height="18" />
                            <TextBlock Text="Details" FontSize="12" />
                        </StackPanel>
                    </Button>
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Effekte und Rahmen"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Frame"
                            Classes.active="{Binding CurrentTool, Converter={StaticResource EditorToolEqualsConverter}, ConverterParameter=Frame}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/03_Editor/35_Rahmen.svg" Width="18"
                                           Height="18" />
                            <TextBlock Text="Effekte und Rahmen" FontSize="12" />
                        </StackPanel>
                    </Button>
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Filter"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Filters"
                            Classes.active="{Binding CurrentTool, Converter={StaticResource EditorToolEqualsConverter}, ConverterParameter=Filters}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/03_Editor/18_Color_Grading.svg"
                                           Width="18" Height="18" />
                            <TextBlock Text="Filter" FontSize="12" />
                        </StackPanel>
                    </Button>
                    <TextBlock Text="AUSWAHL" Foreground="{DynamicResource FP.Text.Muted}" FontSize="10"
                               FontWeight="SemiBold" Margin="10,10,0,4" />
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Auswahl"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Selection"
                            Classes.active="{Binding CurrentTool, Converter={StaticResource EditorToolEqualsConverter}, ConverterParameter=Selection}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/09_FormenSymbole/005_Rechteck.svg"
                                           Width="18" Height="18" />
                            <TextBlock Text="Auswahl" FontSize="12" />
                        </StackPanel>
                    </Button>

                    <TextBlock Text="EINFÜGEN" Foreground="{DynamicResource FP.Text.Muted}" FontSize="10"
                               FontWeight="SemiBold" Margin="10,10,0,4" />
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Text und Bild"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Text"
                            Classes.active="{Binding CurrentTool, Converter={StaticResource EditorToolEqualsConverter}, ConverterParameter=Text}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/03_Editor/34_Text.svg" Width="18"
                                           Height="18" />
                            <TextBlock Text="Text und Bild" FontSize="12" />
                        </StackPanel>
                    </Button>
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Malen"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Draw"
                            Classes.active="{Binding IsPaintToolSelected}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/03_Editor/39_Pinsel.svg" Width="18"
                                           Height="18" />
                            <TextBlock Text="Malen" FontSize="12" />
                        </StackPanel>
                    </Button>
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Formen und Symbole"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Insert"
                            Classes.active="{Binding CurrentTool, Converter={StaticResource EditorToolEqualsConverter}, ConverterParameter=Insert}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/09_FormenSymbole/032_Wuerfel.svg"
                                           Width="18" Height="18" />
                            <TextBlock Text="Formen und Symbole" FontSize="12" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource FP.Bg.Root}" Padding="2">
            <Grid>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10"
                            IsVisible="{Binding CurrentImage, Converter={x:Static ObjectConverters.IsNull}}">
                    <TextBlock Text="Kein Bild zum Bearbeiten" Foreground="{DynamicResource FP.Text.Muted}"
                               FontSize="14" HorizontalAlignment="Center" />
                    <TextBlock Text="Öffne ein Bild aus dem Betrachter" Foreground="{DynamicResource FP.Text.Muted}"
                               FontSize="11" HorizontalAlignment="Center" />
                </StackPanel>

                <Grid RowDefinitions="*,Auto"
                      IsVisible="{Binding CurrentImage, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <Canvas x:Name="PreviewCanvas"
                            PointerWheelChanged="OnCanvasWheelZoom"
                            Grid.Row="0"
                            ClipToBounds="True"
                            SizeChanged="OnPreviewCanvasSizeChanged"
                            PointerPressed="OnSliderPointerPressed"
                            PointerMoved="OnSliderPointerMoved"
                            PointerReleased="OnSliderPointerReleased"
                            PointerExited="OnPreviewCanvasPointerExited">
                        <Border x:Name="ImageBackgroundBorder"
                                Background="{Binding TransparencyBackgroundBrush}"
                                IsHitTestVisible="False" />
                        <Image x:Name="AfterImageControl"
                               Source="{Binding DisplayImage}"
                               Stretch="Fill"
                               RenderOptions.BitmapInterpolationMode="HighQuality" />
                        <Image x:Name="BeforeImageControl"
                               Source="{Binding BeforeDisplayImage}"
                               Stretch="Fill"
                               RenderOptions.BitmapInterpolationMode="HighQuality" />
                        <Border x:Name="ImageFrameBorder"
                                Background="Transparent"
                                BorderBrush="{DynamicResource FP.Border.Strong}"
                                BorderThickness="1"
                                IsHitTestVisible="False" />
                        <Border x:Name="SliderDivider"
                                Width="2"
                                Background="{DynamicResource FP.Accent}"
                                Opacity="0.9" />
                        <Border x:Name="SliderHandleCircle"
                                Width="36" Height="36"
                                Background="#F2F2F2"
                                CornerRadius="18"
                                BorderBrush="{DynamicResource FP.Border.Normal}"
                                BorderThickness="1"
                                Cursor="SizeWestEast">
                            <StackPanel Orientation="Horizontal" Spacing="3"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path Width="7" Height="12"
                                      Stretch="Uniform"
                                      Stroke="#1A1A1A"
                                      StrokeThickness="2"
                                      StrokeLineCap="Round"
                                      StrokeJoin="Round"
                                      Data="M 10 0 L 0 10 L 10 20" />
                                <Path Width="7" Height="12"
                                      Stretch="Uniform"
                                      Stroke="#1A1A1A"
                                      StrokeThickness="2"
                                      StrokeLineCap="Round"
                                      StrokeJoin="Round"
                                      Data="M 0 0 L 10 10 L 0 20" />
                            </StackPanel>
                        </Border>
                        <Border x:Name="BeforeLabel" Background="#262933" CornerRadius="6" Padding="10,5">
                            <TextBlock Text="Vorher" FontSize="11" Foreground="White" />
                        </Border>
                        <Border x:Name="AfterLabel" Background="#262933" CornerRadius="6" Padding="10,5">
                            <TextBlock Text="Nachher" FontSize="11" Foreground="White" />
                        </Border>
                        <Border x:Name="CropOverlay"
                                BorderThickness="0"
                                Background="Transparent"
                                Cursor="SizeAll"
                                IsVisible="False">
                            <Grid RowDefinitions="*,*,*" ColumnDefinitions="*,*,*">
                                <Rectangle Grid.RowSpan="3"
                                           Grid.ColumnSpan="3"
                                           Fill="#12008CFF"
                                           Stroke="{DynamicResource FP.Accent}"
                                           StrokeThickness="1.5"
                                           StrokeDashArray="5,3" />
                                <Border Grid.RowSpan="3" Grid.Column="1" Width="1" Background="#CCFFFFFF"
                                        HorizontalAlignment="Left" />
                                <Border Grid.RowSpan="3" Grid.Column="1" Width="1" Background="#CCFFFFFF"
                                        HorizontalAlignment="Right" />
                                <Border Grid.Row="1" Grid.ColumnSpan="3" Height="1" Background="#CCFFFFFF"
                                        VerticalAlignment="Top" />
                                <Border Grid.Row="1" Grid.ColumnSpan="3" Height="1" Background="#CCFFFFFF"
                                        VerticalAlignment="Bottom" />
                                <Border Grid.RowSpan="3" Grid.Column="1" Width="1" Background="#66000000"
                                        HorizontalAlignment="Left" Margin="1,0,0,0" />
                                <Border Grid.RowSpan="3" Grid.Column="1" Width="1" Background="#66000000"
                                        HorizontalAlignment="Right" Margin="0,0,1,0" />
                                <Border Grid.Row="1" Grid.ColumnSpan="3" Height="1" Background="#66000000"
                                        VerticalAlignment="Top" Margin="0,1,0,0" />
                                <Border Grid.Row="1" Grid.ColumnSpan="3" Height="1" Background="#66000000"
                                        VerticalAlignment="Bottom" Margin="0,0,0,1" />
                                <Border Grid.RowSpan="3"
                                        Grid.ColumnSpan="3"
                                        Background="#CC1A1D24"
                                        CornerRadius="4"
                                        Padding="6,3"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Margin="6,6,0,0">
                                    <TextBlock x:Name="CropSizeBadgeText"
                                               Text=""
                                               Foreground="White"
                                               FontSize="11"
                                               FontWeight="SemiBold" />
                                </Border>
                                <Border Width="16" Height="16" CornerRadius="8"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Top"
                                        Margin="-9,-9,0,0" />
                                <Border Grid.Column="1" Width="14" Height="14" CornerRadius="7"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top"
                                        Margin="0,-8,0,0" />
                                <Border Grid.Column="2" Width="16" Height="16" CornerRadius="8"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,-9,-9,0" />
                                <Border Grid.Row="1" Width="14" Height="14" CornerRadius="7"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Center"
                                        Margin="-8,0,0,0" />
                                <Border Grid.Row="1" Grid.Column="2" Width="14" Height="14" CornerRadius="7"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Margin="0,0,-8,0" />
                                <Border Grid.Row="2" Width="16" Height="16" CornerRadius="8"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                        Margin="-9,0,0,-9" />
                                <Border Grid.Row="2" Grid.Column="1" Width="14" Height="14" CornerRadius="7"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                        Margin="0,0,0,-8" />
                                <Border Grid.Row="2" Grid.Column="2" Width="16" Height="16" CornerRadius="8"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        Margin="0,0,-9,-9" />
                            </Grid>
                        </Border>
                        <Border x:Name="SelectionOverlay"
                                BorderThickness="0"
                                Background="Transparent"
                                IsHitTestVisible="False"
                                IsVisible="False">
                            <Rectangle Fill="{Binding SelectionFillPreviewBrush}"
                                       Opacity="0.55"
                                       Stroke="{DynamicResource FP.Accent}"
                                       StrokeThickness="1.5"
                                       StrokeDashArray="4,3" />
                        </Border>
                        <Border x:Name="TextOverlay"
                                BorderThickness="0"
                                Background="Transparent"
                                Cursor="SizeAll"
                                IsVisible="False"
                                PointerPressed="OnTextOverlayPointerPressed"
                                PointerMoved="OnTextOverlayPointerMoved"
                                PointerReleased="OnTextOverlayPointerReleased">
                            <Grid>
                                <Rectangle x:Name="TextOverlayFrame"
                                           Fill="Transparent"
                                           Stroke="{DynamicResource FP.Accent}"
                                           StrokeThickness="1.5"
                                           StrokeDashArray="5,3"
                                           IsHitTestVisible="False" />
                                <TextBox x:Name="TextOverlayEditor"
                                         Classes="overlay-editor"
                                         Text="{Binding AnnotationText}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0"
                                         VerticalContentAlignment="Top"
                                         IsHitTestVisible="False"
                                         FocusAdorner="{x:Null}" />
                                <Border x:Name="TextSizeBadge"
                                        IsVisible="False"
                                        IsHitTestVisible="False"
                                        Background="#CC1A1D24"
                                        CornerRadius="4"
                                        Padding="6,3"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Margin="0,-30,0,0">
                                    <TextBlock x:Name="TextSizeBadgeText" Text="" Foreground="White" FontSize="11"
                                               FontWeight="SemiBold" />
                                </Border>
                                <Border Width="1" Height="20" Background="{DynamicResource FP.Accent}"
                                        HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-20,0,0"
                                        IsHitTestVisible="False" />
                                <Border Width="16" Height="16" CornerRadius="8"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top"
                                        Margin="0,-36,0,0" IsHitTestVisible="False"
                                        ToolTip.Tip="Ziehen zum Drehen (Shift = 15°-Schritte)" />
                                <Border Width="14" Height="14" CornerRadius="7"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Top"
                                        Margin="-8,-8,0,0" IsHitTestVisible="False" />
                                <Border Width="12" Height="12" CornerRadius="6"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top"
                                        Margin="0,-7,0,0" IsHitTestVisible="False" />
                                <Border Width="14" Height="14" CornerRadius="7"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,-8,-8,0" IsHitTestVisible="False" />
                                <Border Width="12" Height="12" CornerRadius="6"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Center"
                                        Margin="-7,0,0,0" IsHitTestVisible="False" />
                                <Border Width="12" Height="12" CornerRadius="6"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Margin="0,0,-7,0" IsHitTestVisible="False" />
                                <Border Width="14" Height="14" CornerRadius="7"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                        Margin="-8,0,0,-8" IsHitTestVisible="False" />
                                <Border Width="12" Height="12" CornerRadius="6"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                        Margin="0,0,0,-7" IsHitTestVisible="False" />
                                <Border Width="14" Height="14" CornerRadius="7"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        Margin="0,0,-8,-8" IsHitTestVisible="False" />
                            </Grid>
                        </Border>
                        <Line x:Name="SnapGuideV" IsVisible="False" IsHitTestVisible="False" Stroke="#FFFF3B8D"
                              StrokeThickness="1" StrokeDashArray="4,3" />
                        <Line x:Name="SnapGuideH" IsVisible="False" IsHitTestVisible="False" Stroke="#FFFF3B8D"
                              StrokeThickness="1" StrokeDashArray="4,3" />
                        <Polyline x:Name="BrushPreviewLine"
                                  IsVisible="False"
                                  IsHitTestVisible="False"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round" />
                        <Ellipse x:Name="BrushCursorPreview"
                                 IsVisible="False"
                                 IsHitTestVisible="False"
                                 Stroke="{DynamicResource FP.Accent}"
                                 StrokeThickness="1.5" />
                    </Canvas>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="2" Classes="panel-right">
            <Grid RowDefinitions="Auto,Auto,*">
                <Grid Grid.Row="0" Margin="14,14,14,0">
                    <StackPanel Orientation="Horizontal" Spacing="18">
                        <Button Classes="info-tab" Command="{Binding SetLayersPanelTabCommand}" CommandParameter="Tool"
                                Classes.active="{Binding IsToolTabSelected}">
                            <TextBlock Text="{Binding CurrentToolLabel}" />
                        </Button>
                        <Button Classes="info-tab" Command="{Binding SetLayersPanelTabCommand}"
                                CommandParameter="Layers" Classes.active="{Binding IsLayersTabSelected}">
                            <TextBlock Text="Objekte" />
                        </Button>
                        <Button Classes="info-tab" Command="{Binding SetLayersPanelTabCommand}"
                                CommandParameter="History" Classes.active="{Binding IsHistoryTabSelected}"
                                IsVisible="False">
                            <TextBlock Text="Verlauf" />
                        </Button>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Height="1" Background="{DynamicResource FP.Border.Normal}" Margin="14,10,14,0" />

                <Grid Grid.Row="2">
                    <ScrollViewer HorizontalContentAlignment="Stretch"
                                  VerticalScrollBarVisibility="Auto"
                                  FocusAdorner="{x:Null}"
                                  IsVisible="{Binding IsToolTabSelected}">
                        <Grid x:Name="AdjustmentsStackPanel"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                              ColumnDefinitions="*"
                              Margin="14,10,14,10"
                              HorizontalAlignment="Stretch">
                            <Border Grid.Row="1" Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowDrawControls}">
                                <StackPanel Spacing="2">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/03_Editor/39_Pinsel.svg"
                                                       Width="14" Height="14" />
                                        <TextBlock Text="Malen" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <WrapPanel Margin="0,2,0,0">
                                        <Button Classes="ghost insert-option-btn" Width="46" Height="46" Padding="0"
                                                Margin="0,0,6,6"
                                                ToolTip.Tip="Pinsel"
                                                Command="{Binding SetPaintModeCommand}"
                                                CommandParameter="Brush"
                                                Classes.active="{Binding SelectedPaintMode, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Brush}">
                                            <icons:SvgIcon
                                                Source="avares://FerrumPix/Assets/Icons/03_Editor/39_Pinsel.svg"
                                                Width="22" Height="22" />
                                        </Button>
                                        <Button Classes="ghost insert-option-btn" Width="46" Height="46" Padding="0"
                                                Margin="0,0,6,6"
                                                ToolTip.Tip="Radiergummi"
                                                Command="{Binding SetPaintModeCommand}"
                                                CommandParameter="Eraser"
                                                Classes.active="{Binding SelectedPaintMode, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Eraser}">
                                            <icons:SvgIcon
                                                Source="avares://FerrumPix/Assets/Icons/09_FormenSymbole/108_X.svg"
                                                Width="22" Height="22" />
                                        </Button>
                                        <Button Classes="ghost insert-option-btn" Width="46" Height="46" Padding="0"
                                                Margin="0,0,6,6"
                                                ToolTip.Tip="Verwischen"
                                                Command="{Binding SetPaintModeCommand}"
                                                CommandParameter="Blur"
                                                Classes.active="{Binding SelectedPaintMode, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Blur}">
                                            <icons:SvgIcon
                                                Source="avares://FerrumPix/Assets/Icons/03_Editor/26_Retusche.svg"
                                                Width="22" Height="22" />
                                        </Button>
                                    </WrapPanel>
                                    <StackPanel Spacing="2"
                                                IsVisible="{Binding SelectedPaintMode, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Blur}">
                                        <Grid ColumnDefinitions="74,*,Auto,38" VerticalAlignment="Center">
                                            <TextBlock Text="Radius" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="0.2" Maximum="10"
                                                               Value="{Binding RetouchRadius}" Margin="6,0" />
                                            <Button Grid.Column="2"
                                                    Classes="icon-btn"
                                                    Width="28"
                                                    Height="28"
                                                    Padding="0"
                                                    Margin="6,0,6,0"
                                                    Command="{Binding ResetRetouchCommand}"
                                                    ToolTip.Tip="Verwischen zurücksetzen">
                                                <icons:SvgIcon
                                                    Source="avares://FerrumPix/Assets/Icons/01_Navigation/14_Aktualisieren.svg"
                                                    Width="14" Height="14" />
                                            </Button>
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding RetouchRadius, StringFormat={}{0:F1}%}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Spacing="2"
                                                IsVisible="{Binding SelectedPaintMode, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Brush}">
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Größe" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="0.2" Maximum="15"
                                                               Value="{Binding BrushSize}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding BrushSize, StringFormat={}{0:F1}%}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Härte" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                                                               Value="{Binding BrushHardness}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding BrushHardness, StringFormat={}{0:F0}%}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Deckkraft"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                                                               Value="{Binding BrushOpacity}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding BrushOpacity, StringFormat={}{0:F0}%}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*" VerticalAlignment="Top">
                                            <TextBlock Text="Farbe" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:ColorPickerButton Grid.Column="1"
                                                                     SelectedColor="{Binding AnnotationStrokeColorValue, Mode=TwoWay}" />
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="14" Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowLayerToolOptions}">
                                <StackPanel Spacing="2">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <icons:SvgIcon
                                            Source="avares://FerrumPix/Assets/Icons/09_FormenSymbole/141_Einfügen.svg"
                                            Width="14" Height="14" />
                                        <TextBlock Text="Einfügen" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <TextBlock
                                        Text="Wähle unten einen Objekttyp aus und klicke dann ins Bild, um ihn dort zu platzieren."
                                        Foreground="{DynamicResource FP.Text.Muted}"
                                        FontSize="11"
                                        TextWrapping="Wrap" />
                                    <StackPanel Spacing="10">
                                        <StackPanel Spacing="6" IsVisible="{Binding ShowTextInsertControls}">
                                            <TextBlock Text="Text und Bild"
                                                       Foreground="{DynamicResource FP.Text.Secondary}" FontSize="11"
                                                       FontWeight="SemiBold" />
                                            <WrapPanel>
                                                <Button Classes="ghost insert-option-btn" Width="46" Height="46"
                                                        Padding="0" Margin="0,0,6,6" ToolTip.Tip="Text"
                                                        Command="{Binding SetPendingInsertKindCommand}"
                                                        CommandParameter="Text"
                                                        Classes.active="{Binding PendingInsertKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Text}"
                                                        Classes.selected-kind="{Binding SelectedAnnotationKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Text}">
                                                    <icons:SvgIcon
                                                        Source="avares://FerrumPix/Assets/Icons/03_Editor/34_Text.svg"
                                                        Width="22" Height="22" />
                                                </Button>
                                                <Button Classes="ghost insert-option-btn" Width="46" Height="46"
                                                        Padding="0" Margin="0,0,6,6"
                                                        ToolTip.Tip="Bild"
                                                        Command="{Binding SetPendingInsertKindCommand}"
                                                        CommandParameter="Image"
                                                        Classes.active="{Binding PendingInsertKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Image}"
                                                        Classes.selected-kind="{Binding SelectedAnnotationKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Image}">
                                                    <icons:SvgIcon
                                                        Source="avares://FerrumPix/Assets/Icons/09_FormenSymbole/077_Bild.svg"
                                                        Width="22" Height="22" />
                                                </Button>
                                                <Button Classes="ghost insert-option-btn" Width="46" Height="46"
                                                        Padding="0" Margin="0,0,6,6" ToolTip.Tip="QR"
                                                        Command="{Binding SetPendingInsertKindCommand}"
                                                        CommandParameter="QR"
                                                        Classes.active="{Binding PendingInsertKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=QR}"
                                                        Classes.selected-kind="{Binding SelectedAnnotationKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=QR}">
                                                    <icons:SvgIcon
                                                        Source="avares://FerrumPix/Assets/Icons/03_Editor/37_QR_Code.svg"
                                                        Width="22" Height="22" />
                                                </Button>
                                            </WrapPanel>
                                        </StackPanel>
                                        <StackPanel Spacing="6" IsVisible="{Binding ShowGeometryControls}">
                                            <TextBlock Text="Formen und Symbole"
                                                       Foreground="{DynamicResource FP.Text.Secondary}" FontSize="11"
                                                       FontWeight="SemiBold" />
                                            <TextBox
                                                Text="{Binding ShapeIconSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Watermark="Symbol suchen…"
                                                FontSize="11" />
                                            <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding FilteredShapeIcons}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Classes="ghost insert-option-btn compact"
                                                                    ToolTip.Tip="{Binding DisplayName}"
                                                                    Command="{Binding DataContext.SetPendingInsertKindCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding PendingKind}"
                                                                    Classes.active="{Binding IsPending}"
                                                                    Classes.selected-kind="{Binding IsSelectedKind}">
                                                                <icons:SvgIcon Source="{Binding IconPath}" Width="16"
                                                                               Height="16" />
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </StackPanel>

                                </StackPanel>
                            </Border>

                            <Border Grid.Row="16" Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowAnnotationProperties}">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Eigenschaften" Foreground="{DynamicResource FP.Text.Secondary}"
                                               FontSize="11" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding AnnotationText}"
                                             Watermark="Text, QR-Inhalt oder Symbol eingeben"
                                             FontSize="12"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             MaxHeight="70"
                                             IsVisible="{Binding ShowTextContentControls}" />
                                    <Grid ColumnDefinitions="74,*" VerticalAlignment="Center"
                                          IsVisible="{Binding ShowFontControls}">
                                        <TextBlock Text="Schrift" Foreground="{DynamicResource FP.Text.Secondary}"
                                                   VerticalAlignment="Center" FontSize="11" />
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding AnnotationFontOptions}"
                                                  SelectedItem="{Binding AnnotationFontFamily}"
                                                  FontSize="11"
                                                  Margin="6,0,0,0"
                                                  HorizontalAlignment="Stretch"
                                                  DropDownOpened="OnMatchWidthDropDownOpened" />
                                    </Grid>
                                    <Grid ColumnDefinitions="74,*,44" VerticalAlignment="Center"
                                          IsVisible="{Binding ShowFontControls}">
                                        <TextBlock Text="Größe" Foreground="{DynamicResource FP.Text.Secondary}"
                                                   VerticalAlignment="Center" FontSize="11" />
                                        <icons:RoundSlider Grid.Column="1" Minimum="8" Maximum="500"
                                                           Value="{Binding AnnotationFontSizePixels}" Margin="6,0" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding AnnotationFontSizePixels, StringFormat={}{0}px}"
                                                   Foreground="{DynamicResource FP.Text.Secondary}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11" />
                                    </Grid>
                                    <Grid ColumnDefinitions="74,*" VerticalAlignment="Top"
                                          IsVisible="{Binding ShowFillColorControls}">
                                        <TextBlock Text="{Binding FillColorLabel}"
                                                   Foreground="{DynamicResource FP.Text.Secondary}"
                                                   VerticalAlignment="Center" FontSize="11" />
                                        <StackPanel Grid.Column="1" Margin="6,0,0,0" Spacing="6">
                                            <icons:ColorPickerButton
                                                SelectedColor="{Binding AnnotationFillColorValue, Mode=TwoWay}" />

                                        </StackPanel>
                                    </Grid>
                                    <Grid ColumnDefinitions="74,*" VerticalAlignment="Center"
                                          IsVisible="{Binding ShowFillColorControls}">
                                        <TextBlock Text="Füllart" Foreground="{DynamicResource FP.Text.Secondary}"
                                                   VerticalAlignment="Center" FontSize="11" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                                    Margin="6,0,0,0">
                                            <Button Classes="ghost" Padding="8,4"
                                                    Command="{Binding SetAnnotationFillKindCommand}"
                                                    CommandParameter="Solid"
                                                    Classes.active="{Binding AnnotationFillKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Solid}">
                                                <TextBlock Text="Vollfarbe" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,4"
                                                    Command="{Binding SetAnnotationFillKindCommand}"
                                                    CommandParameter="LinearGradient"
                                                    Classes.active="{Binding AnnotationFillKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=LinearGradient}">
                                                <TextBlock Text="Verlauf" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,4"
                                                    Command="{Binding SetAnnotationFillKindCommand}"
                                                    CommandParameter="RadialGradient"
                                                    Classes.active="{Binding AnnotationFillKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=RadialGradient}">
                                                <TextBlock Text="Radial" FontSize="11" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    <Grid ColumnDefinitions="74,*" VerticalAlignment="Top"
                                          IsVisible="{Binding ShowGradientFillControls}">
                                        <TextBlock Text="Verlauf bis" Foreground="{DynamicResource FP.Text.Secondary}"
                                                   VerticalAlignment="Center" FontSize="11" />
                                        <StackPanel Grid.Column="1" Margin="6,0,0,0" Spacing="6">
                                            <icons:ColorPickerButton
                                                SelectedColor="{Binding AnnotationFillColor2Value, Mode=TwoWay}" />

                                        </StackPanel>
                                    </Grid>
                                    <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center"
                                          IsVisible="{Binding ShowLinearGradientAngleControl}">
                                        <TextBlock Text="Winkel" Foreground="{DynamicResource FP.Text.Secondary}"
                                                   VerticalAlignment="Center" FontSize="11" />
                                        <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="360"
                                                           Value="{Binding AnnotationGradientAngleDegrees}"
                                                           Margin="6,0" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding AnnotationGradientAngleDegrees, StringFormat={}{0:F0}°}"
                                                   Foreground="{DynamicResource FP.Text.Secondary}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11" />
                                    </Grid>
                                    <CheckBox Content="Verlauf invertieren"
                                              IsChecked="{Binding AnnotationGradientInverted}" FontSize="11"
                                              IsVisible="{Binding ShowRadialGradientControl}" />
                                    <Grid ColumnDefinitions="74,*" VerticalAlignment="Top">
                                        <TextBlock Text="{Binding StrokeColorLabel}"
                                                   Foreground="{DynamicResource FP.Text.Secondary}"
                                                   VerticalAlignment="Center" FontSize="11" />
                                        <StackPanel Grid.Column="1" Margin="6,0,0,0" Spacing="6">
                                            <icons:ColorPickerButton
                                                SelectedColor="{Binding AnnotationStrokeColorValue, Mode=TwoWay}" />

                                        </StackPanel>
                                    </Grid>
                                    <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center"
                                          IsVisible="{Binding ShowStrokeWidthControls}">
                                        <TextBlock Text="Konturbreite" Foreground="{DynamicResource FP.Text.Secondary}"
                                                   VerticalAlignment="Center" FontSize="11" TextWrapping="Wrap" />
                                        <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="50"
                                                           Value="{Binding AnnotationStrokeWidth}" Margin="6,0" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding AnnotationStrokeWidth, StringFormat={}{0:F0}}"
                                                   Foreground="{DynamicResource FP.Text.Secondary}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11" />
                                    </Grid>
                                    <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                        <TextBlock Text="Deckkraft" Foreground="{DynamicResource FP.Text.Secondary}"
                                                   VerticalAlignment="Center" FontSize="11" />
                                        <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                                                           Value="{Binding AnnotationOpacity}" Margin="6,0" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding AnnotationOpacity, StringFormat={}{0:F0}%}"
                                                   Foreground="{DynamicResource FP.Text.Secondary}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11" />
                                    </Grid>
                                    <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                        <TextBlock Text="Drehung" Foreground="{DynamicResource FP.Text.Secondary}"
                                                   VerticalAlignment="Center" FontSize="11" />
                                        <icons:RoundSlider Grid.Column="1" Minimum="-180" Maximum="180"
                                                           Value="{Binding AnnotationRotation}" WheelIncrement="0.1"
                                                           DragIncrement="0.1" Margin="6,0" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding AnnotationRotation, StringFormat={}{0:F1}°}"
                                                   Foreground="{DynamicResource FP.Text.Secondary}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11" />
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                        <Grid RowDefinitions="Auto,Auto" RowSpacing="6">
                                            <Grid ColumnDefinitions="16,*,44">
                                                <TextBlock Text="X" Foreground="{DynamicResource FP.Text.Secondary}"
                                                           VerticalAlignment="Center" FontSize="11" />
                                                <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="99"
                                                                   Value="{Binding AnnotationXPercent}" Margin="4,0" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding AnnotationXPixels, StringFormat={}{0}px}"
                                                           Foreground="{DynamicResource FP.Text.Secondary}"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="11" />
                                            </Grid>
                                            <Grid Grid.Row="1" ColumnDefinitions="16,*,44">
                                                <TextBlock Text="Y" Foreground="{DynamicResource FP.Text.Secondary}"
                                                           VerticalAlignment="Center" FontSize="11" />
                                                <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="99"
                                                                   Value="{Binding AnnotationYPercent}" Margin="4,0" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding AnnotationYPixels, StringFormat={}{0}px}"
                                                           Foreground="{DynamicResource FP.Text.Secondary}"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="11" />
                                            </Grid>
                                        </Grid>
                                        <Grid Grid.Column="1" RowDefinitions="Auto,Auto" RowSpacing="6">
                                            <Grid ColumnDefinitions="16,*,44">
                                                <TextBlock Text="B" Foreground="{DynamicResource FP.Text.Secondary}"
                                                           VerticalAlignment="Center" FontSize="11" />
                                                <icons:RoundSlider Grid.Column="1" Minimum="5" Maximum="90"
                                                                   Value="{Binding AnnotationWidthPercent}"
                                                                   Margin="4,0" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding AnnotationWidthPixels, StringFormat={}{0}px}"
                                                           Foreground="{DynamicResource FP.Text.Secondary}"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="11" />
                                            </Grid>
                                            <Grid Grid.Row="1" ColumnDefinitions="16,*,44">
                                                <TextBlock Text="H" Foreground="{DynamicResource FP.Text.Secondary}"
                                                           VerticalAlignment="Center" FontSize="11" />
                                                <icons:RoundSlider Grid.Column="1" Minimum="4" Maximum="90"
                                                                   Value="{Binding AnnotationHeightPercent}"
                                                                   Margin="4,0" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding AnnotationHeightPixels, StringFormat={}{0}px}"
                                                           Foreground="{DynamicResource FP.Text.Secondary}"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           FontSize="11" />
                                            </Grid>
                                        </Grid>
                                    </Grid>

                                    <CheckBox Content="Schatten" IsChecked="{Binding AnnotationShadowEnabled}"
                                              Margin="0,6,0,0" FontSize="11" />
                                    <StackPanel Spacing="2" IsVisible="{Binding AnnotationShadowEnabled}">
                                        <Grid ColumnDefinitions="74,*" VerticalAlignment="Top">
                                            <TextBlock Text="Farbe" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:ColorPickerButton Grid.Column="1"
                                                                     SelectedColor="{Binding AnnotationShadowColorValue, Mode=TwoWay}" />

                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Versatz X"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="-20" Maximum="20"
                                                               Value="{Binding AnnotationShadowOffsetX}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding AnnotationShadowOffsetX, StringFormat={}{0:F0}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Versatz Y"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="-20" Maximum="20"
                                                               Value="{Binding AnnotationShadowOffsetY}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding AnnotationShadowOffsetY, StringFormat={}{0:F0}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Weichzeichnen"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" TextWrapping="Wrap" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                                                               Value="{Binding AnnotationShadowBlur}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding AnnotationShadowBlur, StringFormat={}{0:F0}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Stärke" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                                                               Value="{Binding AnnotationShadowStrength}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding AnnotationShadowStrength, StringFormat={}{0:F0}%}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <CheckBox Content="Abgerundet" IsChecked="{Binding AnnotationShadowRounded}"
                                                  Margin="0,4,0,0" FontSize="11" />
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center"
                                              IsVisible="{Binding AnnotationShadowRounded}">
                                            <TextBlock Text="Rundung" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                                                               Value="{Binding AnnotationShadowCornerRadius}"
                                                               Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding AnnotationShadowCornerRadius, StringFormat={}{0:F0}%}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                    </StackPanel>

                                    <CheckBox Content="Glow" IsChecked="{Binding AnnotationGlowEnabled}"
                                              Margin="0,6,0,0" FontSize="11" />
                                    <StackPanel Spacing="2" IsVisible="{Binding AnnotationGlowEnabled}">
                                        <Grid ColumnDefinitions="74,*" VerticalAlignment="Top">
                                            <TextBlock Text="Farbe" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:ColorPickerButton Grid.Column="1"
                                                                     SelectedColor="{Binding AnnotationGlowColorValue, Mode=TwoWay}" />

                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Weichzeichnen"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" TextWrapping="Wrap" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                                                               Value="{Binding AnnotationGlowBlur}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding AnnotationGlowBlur, StringFormat={}{0:F0}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Stärke" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                                                               Value="{Binding AnnotationGlowStrength}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding AnnotationGlowStrength, StringFormat={}{0:F0}%}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowCropAdjustments}">
                                <Grid RowDefinitions="Auto,*">
                                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <icons:SvgIcon
                                                Source="avares://FerrumPix/Assets/Icons/03_Editor/01_Zuschneiden.svg"
                                                Width="14" Height="14" />
                                            <TextBlock Text="Zuschneiden" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Classes="icon-btn"
                                                Width="28"
                                                Height="28"
                                                Padding="0"
                                                Command="{Binding DataContext.ResetCropCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                ToolTip.Tip="Ausschnitt zurücksetzen">
                                            <icons:SvgIcon
                                                Source="avares://FerrumPix/Assets/Icons/01_Navigation/14_Aktualisieren.svg"
                                                Width="14" Height="14" />
                                        </Button>
                                    </Grid>
                                    <StackPanel Grid.Row="1" Spacing="8" Margin="0,8,0,0">
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Links" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="95"
                                                               Value="{Binding CropLeft}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding CropLeft, StringFormat={}{0:F0}%}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Oben" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="95"
                                                               Value="{Binding CropTop}" Margin="6,0" />
                                            <TextBlock Grid.Column="2" Text="{Binding CropTop, StringFormat={}{0:F0}%}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Rechts" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="95"
                                                               Value="{Binding CropRight}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding CropRight, StringFormat={}{0:F0}%}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Unten" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="95"
                                                               Value="{Binding CropBottom}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding CropBottom, StringFormat={}{0:F0}%}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,Auto" VerticalAlignment="Center">
                                            <TextBlock Text="Breite" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <NumericUpDown Classes="combo-like" Grid.Column="1"
                                                           Value="{Binding CropWidthPixels}" Minimum="1"
                                                           Maximum="50000" Increment="1" Margin="6,0,0,0" FontSize="11" />
                                            <TextBlock Grid.Column="2" Text="px"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,Auto" VerticalAlignment="Center">
                                            <TextBlock Text="Höhe" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <NumericUpDown Classes="combo-like" Grid.Column="1"
                                                           Value="{Binding CropHeightPixels}" Minimum="1"
                                                           Maximum="50000" Increment="1" Margin="6,0,0,0" FontSize="11" />
                                            <TextBlock Grid.Column="2" Text="px"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11" />
                                        </Grid>
                                        <WrapPanel>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetCropPresetCommand}"
                                                    CommandParameter="Original">
                                                <TextBlock Text="Original" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetCropPresetCommand}" CommandParameter="1:1">
                                                <TextBlock Text="1:1" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetCropPresetCommand}" CommandParameter="4:3">
                                                <TextBlock Text="4:3" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetCropPresetCommand}" CommandParameter="3:2">
                                                <TextBlock Text="3:2" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetCropPresetCommand}" CommandParameter="16:9">
                                                <TextBlock Text="16:9" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetCropPresetCommand}" CommandParameter="9:16">
                                                <TextBlock Text="9:16" FontSize="11" />
                                            </Button>
                                        </WrapPanel>
                                        <Button Classes="accent"
                                                HorizontalAlignment="Stretch"
                                                Padding="10,6"
                                                Command="{Binding ApplyCropCommand}"
                                                IsEnabled="{Binding HasCropChanges}"
                                                ToolTip.Tip="Ausschnitt auf die Vorschau anwenden">
                                            <StackPanel Orientation="Horizontal" Spacing="6"
                                                        HorizontalAlignment="Center">
                                                <icons:SvgIcon
                                                    Source="avares://FerrumPix/Assets/Icons/03_Editor/01_Zuschneiden.svg"
                                                    Width="16" Height="16" />
                                                <TextBlock Text="Zuschneiden anwenden" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="3" Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowResizeAdjustments}">
                                <Grid RowDefinitions="Auto,*">
                                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <icons:SvgIcon
                                                Source="avares://FerrumPix/Assets/Icons/04_Viewer/26_Seitenverhaeltnis.svg"
                                                Width="14" Height="14" />
                                            <TextBlock Text="Bildgröße" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Classes="icon-btn"
                                                Width="28"
                                                Height="28"
                                                Padding="0"
                                                Command="{Binding DataContext.ResetResizeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                ToolTip.Tip="Größe zurücksetzen">
                                            <icons:SvgIcon
                                                Source="avares://FerrumPix/Assets/Icons/01_Navigation/14_Aktualisieren.svg"
                                                Width="14" Height="14" />
                                        </Button>
                                    </Grid>
                                    <StackPanel Grid.Row="1" Spacing="8" Margin="0,8,0,0">
                                        <Grid ColumnDefinitions="74,*,Auto" VerticalAlignment="Center">
                                            <TextBlock Text="Breite" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <NumericUpDown Classes="combo-like" Grid.Column="1"
                                                           Value="{Binding ResizeWidth}" Minimum="0" Maximum="50000"
                                                           Increment="10" Margin="6,0,0,0" FontSize="11" />
                                            <TextBlock Grid.Column="2" Text="px"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,Auto" VerticalAlignment="Center">
                                            <TextBlock Text="Höhe" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <NumericUpDown Classes="combo-like" Grid.Column="1"
                                                           Value="{Binding ResizeHeight}" Minimum="0" Maximum="50000"
                                                           Increment="10" Margin="6,0,0,0" FontSize="11" />
                                            <TextBlock Grid.Column="2" Text="px"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11" />
                                        </Grid>
                                        <CheckBox Content="Seitenverhältnis beibehalten"
                                                  IsChecked="{Binding LockResizeAspect}" FontSize="11" />
                                        <Grid ColumnDefinitions="90,*" VerticalAlignment="Center">
                                            <TextBlock Text="Neuberechnung"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" TextWrapping="Wrap" />
                                            <ComboBox Grid.Column="1"
                                                      ItemsSource="{Binding ResizeInterpolationOptions}"
                                                      SelectedItem="{Binding ResizeInterpolationLabel}"
                                                      FontSize="11"
                                                      Margin="6,0,0,0"
                                                      HorizontalAlignment="Stretch"
                                                      DropDownOpened="OnMatchWidthDropDownOpened"
                                                      ToolTip.Tip="Berechnungsmethode für die Größenänderung" />
                                        </Grid>
                                        <WrapPanel>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetResizePresetCommand}"
                                                    CommandParameter="Original">
                                                <TextBlock Text="Original" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetResizePresetCommand}" CommandParameter="75%">
                                                <TextBlock Text="75%" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetResizePresetCommand}" CommandParameter="50%">
                                                <TextBlock Text="50%" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetResizePresetCommand}" CommandParameter="25%">
                                                <TextBlock Text="25%" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetResizePresetCommand}" CommandParameter="UHD">
                                                <TextBlock Text="UHD" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetResizePresetCommand}"
                                                    CommandParameter="Full-HD">
                                                <TextBlock Text="Full-HD" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetResizePresetCommand}" CommandParameter="SD">
                                                <TextBlock Text="SD" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetResizePresetCommand}" CommandParameter="1500">
                                                <TextBlock Text="1500" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetResizePresetCommand}" CommandParameter="1000">
                                                <TextBlock Text="1000" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetResizePresetCommand}" CommandParameter="800">
                                                <TextBlock Text="800" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetResizePresetCommand}" CommandParameter="500">
                                                <TextBlock Text="500" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetResizePresetCommand}" CommandParameter="256">
                                                <TextBlock Text="256" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetResizePresetCommand}" CommandParameter="128">
                                                <TextBlock Text="128" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetResizePresetCommand}" CommandParameter="64">
                                                <TextBlock Text="64" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetResizePresetCommand}" CommandParameter="32">
                                                <TextBlock Text="32" FontSize="11" />
                                            </Button>
                                        </WrapPanel>
                                        <Button Classes="accent"
                                                HorizontalAlignment="Stretch"
                                                Padding="10,6"
                                                Command="{Binding ApplyResizeCommand}"
                                                IsEnabled="{Binding HasImageResizeChanges}"
                                                ToolTip.Tip="Bildgröße auf die Vorschau anwenden">
                                            <StackPanel Orientation="Horizontal" Spacing="6"
                                                        HorizontalAlignment="Center">
                                                <icons:SvgIcon
                                                    Source="avares://FerrumPix/Assets/Icons/03_Editor/02_Groesse_aendern.svg"
                                                    Width="16" Height="16" />
                                                <TextBlock Text="Bildgröße anwenden" />
                                            </StackPanel>
                                        </Button>
                                        <Separator Margin="0,4" />
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="Leinwand" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       FontSize="11" VerticalAlignment="Center" />
                                            <Button Grid.Column="1"
                                                    Classes="icon-btn"
                                                    Width="26"
                                                    Height="26"
                                                    Padding="0"
                                                    Command="{Binding DataContext.ResetCanvasCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    ToolTip.Tip="Leinwand zurücksetzen">
                                                <icons:SvgIcon
                                                    Source="avares://FerrumPix/Assets/Icons/01_Navigation/14_Aktualisieren.svg"
                                                    Width="13" Height="13" />
                                            </Button>
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,Auto" VerticalAlignment="Center">
                                            <TextBlock Text="Breite" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <NumericUpDown Classes="combo-like" Grid.Column="1"
                                                           Value="{Binding CanvasWidth}" Minimum="0" Maximum="50000"
                                                           Increment="10" Margin="6,0,0,0" FontSize="11" />
                                            <TextBlock Grid.Column="2" Text="px"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,Auto" VerticalAlignment="Center">
                                            <TextBlock Text="Höhe" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <NumericUpDown Classes="combo-like" Grid.Column="1"
                                                           Value="{Binding CanvasHeight}" Minimum="0" Maximum="50000"
                                                           Increment="10" Margin="6,0,0,0" FontSize="11" />
                                            <TextBlock Grid.Column="2" Text="px"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11" />
                                        </Grid>
                                        <CheckBox Content="Seitenverhältnis beibehalten"
                                                  IsChecked="{Binding LockCanvasAspect}" FontSize="11" />
                                        <Grid ColumnDefinitions="74,*" VerticalAlignment="Top">
                                            <TextBlock Text="Hintergrund"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:ColorPickerButton Grid.Column="1"
                                                                     SelectedColor="{Binding CanvasBackgroundColorValue, Mode=TwoWay}" />

                                        </Grid>
                                        <Grid ColumnDefinitions="74,*" VerticalAlignment="Top">
                                            <TextBlock Text="Position" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       FontSize="11" VerticalAlignment="Top" Margin="0,10,0,0" />
                                            <Border Grid.Column="1" BorderBrush="{DynamicResource FP.Border.Normal}"
                                                    BorderThickness="1" CornerRadius="6" Padding="12,10"
                                                    HorizontalAlignment="Left">
                                                <Grid Width="72" Height="72">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*" />
                                                        <RowDefinition Height="*" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Row="0" Grid.Column="0" Classes="anchor-dot"
                                                            Command="{Binding SetCanvasAnchorCommand}"
                                                            CommandParameter="TopLeft" ToolTip.Tip="Anker oben links">
                                                        <Grid>
                                                            <Border Classes="anchor-dot-idle" />
                                                            <Border Classes="anchor-dot-active"
                                                                    IsVisible="{Binding CanvasAnchor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=TopLeft}" />
                                                        </Grid>
                                                    </Button>
                                                    <Button Grid.Row="0" Grid.Column="1" Classes="anchor-dot"
                                                            Command="{Binding SetCanvasAnchorCommand}"
                                                            CommandParameter="Top" ToolTip.Tip="Anker oben">
                                                        <Grid>
                                                            <Border Classes="anchor-dot-idle" />
                                                            <Border Classes="anchor-dot-active"
                                                                    IsVisible="{Binding CanvasAnchor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Top}" />
                                                        </Grid>
                                                    </Button>
                                                    <Button Grid.Row="0" Grid.Column="2" Classes="anchor-dot"
                                                            Command="{Binding SetCanvasAnchorCommand}"
                                                            CommandParameter="TopRight" ToolTip.Tip="Anker oben rechts">
                                                        <Grid>
                                                            <Border Classes="anchor-dot-idle" />
                                                            <Border Classes="anchor-dot-active"
                                                                    IsVisible="{Binding CanvasAnchor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=TopRight}" />
                                                        </Grid>
                                                    </Button>
                                                    <Button Grid.Row="1" Grid.Column="0" Classes="anchor-dot"
                                                            Command="{Binding SetCanvasAnchorCommand}"
                                                            CommandParameter="Left" ToolTip.Tip="Anker links">
                                                        <Grid>
                                                            <Border Classes="anchor-dot-idle" />
                                                            <Border Classes="anchor-dot-active"
                                                                    IsVisible="{Binding CanvasAnchor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Left}" />
                                                        </Grid>
                                                    </Button>
                                                    <Button Grid.Row="1" Grid.Column="1" Classes="anchor-dot"
                                                            Command="{Binding SetCanvasAnchorCommand}"
                                                            CommandParameter="Center" ToolTip.Tip="Anker Mitte">
                                                        <Grid>
                                                            <Border Classes="anchor-dot-idle" />
                                                            <Border Classes="anchor-dot-active"
                                                                    IsVisible="{Binding CanvasAnchor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Center}" />
                                                        </Grid>
                                                    </Button>
                                                    <Button Grid.Row="1" Grid.Column="2" Classes="anchor-dot"
                                                            Command="{Binding SetCanvasAnchorCommand}"
                                                            CommandParameter="Right" ToolTip.Tip="Anker rechts">
                                                        <Grid>
                                                            <Border Classes="anchor-dot-idle" />
                                                            <Border Classes="anchor-dot-active"
                                                                    IsVisible="{Binding CanvasAnchor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Right}" />
                                                        </Grid>
                                                    </Button>
                                                    <Button Grid.Row="2" Grid.Column="0" Classes="anchor-dot"
                                                            Command="{Binding SetCanvasAnchorCommand}"
                                                            CommandParameter="BottomLeft"
                                                            ToolTip.Tip="Anker unten links">
                                                        <Grid>
                                                            <Border Classes="anchor-dot-idle" />
                                                            <Border Classes="anchor-dot-active"
                                                                    IsVisible="{Binding CanvasAnchor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=BottomLeft}" />
                                                        </Grid>
                                                    </Button>
                                                    <Button Grid.Row="2" Grid.Column="1" Classes="anchor-dot"
                                                            Command="{Binding SetCanvasAnchorCommand}"
                                                            CommandParameter="Bottom" ToolTip.Tip="Anker unten">
                                                        <Grid>
                                                            <Border Classes="anchor-dot-idle" />
                                                            <Border Classes="anchor-dot-active"
                                                                    IsVisible="{Binding CanvasAnchor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Bottom}" />
                                                        </Grid>
                                                    </Button>
                                                    <Button Grid.Row="2" Grid.Column="2" Classes="anchor-dot"
                                                            Command="{Binding SetCanvasAnchorCommand}"
                                                            CommandParameter="BottomRight"
                                                            ToolTip.Tip="Anker unten rechts">
                                                        <Grid>
                                                            <Border Classes="anchor-dot-idle" />
                                                            <Border Classes="anchor-dot-active"
                                                                    IsVisible="{Binding CanvasAnchor, Converter={StaticResource StringEqualsConverter}, ConverterParameter=BottomRight}" />
                                                        </Grid>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                        <Button Classes="accent"
                                                HorizontalAlignment="Stretch"
                                                Padding="10,6"
                                                Command="{Binding ApplyCanvasCommand}"
                                                IsEnabled="{Binding HasCanvasSizeChanges}"
                                                ToolTip.Tip="Leinwandgröße auf die Vorschau anwenden">
                                            <StackPanel Orientation="Horizontal" Spacing="6"
                                                        HorizontalAlignment="Center">
                                                <icons:SvgIcon
                                                    Source="avares://FerrumPix/Assets/Icons/03_Editor/35_Rahmen.svg"
                                                    Width="16" Height="16" />
                                                <TextBlock Text="Leinwandgröße anwenden" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="4" Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowLightAdjustments}">
                                <Expander Header="Licht" IsExpanded="True">
                                    <Expander.HeaderTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="8"
                                                            VerticalAlignment="Center">
                                                    <icons:SvgIcon
                                                        Source="avares://FerrumPix/Assets/Icons/03_Editor/07_Belichtung.svg"
                                                        Width="14" Height="14" />
                                                    <TextBlock Text="{Binding}" FontWeight="SemiBold" />
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Classes="icon-btn"
                                                        Width="28"
                                                        Height="28"
                                                        Padding="0"
                                                        Command="{Binding DataContext.ResetLightCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        ToolTip.Tip="Licht zurücksetzen">
                                                    <icons:SvgIcon
                                                        Source="avares://FerrumPix/Assets/Icons/01_Navigation/14_Aktualisieren.svg"
                                                        Width="14" Height="14" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </Expander.HeaderTemplate>
                                    <StackPanel Spacing="2" Margin="0,8,0,0">
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Belichtung"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100"
                                                               Value="{Binding Exposure}" Margin="6,0" />
                                            <TextBlock Grid.Column="2" Text="{Binding Exposure, StringFormat={}{0:F0}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Helligkeit"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100"
                                                               Value="{Binding Brightness}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Brightness, StringFormat={}{0:F0}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Kontrast" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100"
                                                               Value="{Binding Contrast}" Margin="6,0" />
                                            <TextBlock Grid.Column="2" Text="{Binding Contrast, StringFormat={}{0:F0}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Lichter" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100"
                                                               Value="{Binding Highlights}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Highlights, StringFormat={}{0:F0}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Tiefen" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100"
                                                               Value="{Binding ShadowsLevel}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding ShadowsLevel, StringFormat={}{0:F0}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Weiß" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100"
                                                               Value="{Binding Whites}" Margin="6,0" />
                                            <TextBlock Grid.Column="2" Text="{Binding Whites, StringFormat={}{0:F0}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Schwarz" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100"
                                                               Value="{Binding Blacks}" Margin="6,0" />
                                            <TextBlock Grid.Column="2" Text="{Binding Blacks, StringFormat={}{0:F0}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                    </StackPanel>
                                </Expander>
                            </Border>

                            <Border Grid.Row="5" Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowColorAdjustments}">
                                <Expander Header="Farbe" IsExpanded="True">
                                    <Expander.HeaderTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="8"
                                                            VerticalAlignment="Center">
                                                    <icons:SvgIcon
                                                        Source="avares://FerrumPix/Assets/Icons/03_Editor/17_Farbmischer.svg"
                                                        Width="14" Height="14" />
                                                    <TextBlock Text="{Binding}" FontWeight="SemiBold" />
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Classes="icon-btn"
                                                        Width="28"
                                                        Height="28"
                                                        Padding="0"
                                                        Command="{Binding DataContext.ResetColorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        ToolTip.Tip="Farbe zurücksetzen">
                                                    <icons:SvgIcon
                                                        Source="avares://FerrumPix/Assets/Icons/01_Navigation/14_Aktualisieren.svg"
                                                        Width="14" Height="14" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </Expander.HeaderTemplate>
                                    <StackPanel Spacing="2" Margin="0,8,0,0">
                                        <Grid ColumnDefinitions="74,*" VerticalAlignment="Center">
                                            <TextBlock Text="Weißabgleich"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" TextWrapping="NoWrap" />
                                            <ComboBox Grid.Column="1"
                                                      ItemsSource="{Binding WhiteBalanceOptions}"
                                                      SelectedItem="{Binding WhiteBalance}"
                                                      HorizontalAlignment="Stretch"
                                                      FontSize="11"
                                                      Margin="6,0,0,0"
                                                      DropDownOpened="OnMatchWidthDropDownOpened" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Temperatur"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100"
                                                               Value="{Binding Temperature}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Temperature, StringFormat={}{0:F0}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Farbton" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100"
                                                               Value="{Binding Tint}" Margin="6,0" />
                                            <TextBlock Grid.Column="2" Text="{Binding Tint, StringFormat={}{0:F0}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Dynamik" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100"
                                                               Value="{Binding Vibrance}" Margin="6,0" />
                                            <TextBlock Grid.Column="2" Text="{Binding Vibrance, StringFormat={}{0:F0}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Sättigung"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100"
                                                               Value="{Binding Saturation}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Saturation, StringFormat={}{0:F0}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                    </StackPanel>
                                </Expander>
                            </Border>

                            <!-- DETAILS (ausklappbar) -->
                            <Border Grid.Row="6" Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowDetailAdjustments}">
                                <Expander Header="Details" IsExpanded="True">
                                    <Expander.HeaderTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="8"
                                                            VerticalAlignment="Center">
                                                    <icons:SvgIcon
                                                        Source="avares://FerrumPix/Assets/Icons/03_Editor/24_Klarheit.svg"
                                                        Width="14" Height="14" />
                                                    <TextBlock Text="{Binding}" FontWeight="SemiBold" />
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Classes="icon-btn"
                                                        Width="28"
                                                        Height="28"
                                                        Padding="0"
                                                        Command="{Binding DataContext.ResetDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        ToolTip.Tip="Details zurücksetzen">
                                                    <icons:SvgIcon
                                                        Source="avares://FerrumPix/Assets/Icons/01_Navigation/14_Aktualisieren.svg"
                                                        Width="14" Height="14" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </Expander.HeaderTemplate>
                                    <StackPanel Spacing="2" Margin="0,8,0,0">
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Klarheit" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100"
                                                               Value="{Binding Clarity}" Margin="6,0" />
                                            <TextBlock Grid.Column="2" Text="{Binding Clarity, StringFormat={}{0:F0}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Schärfe" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                                                               Value="{Binding Sharpness}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Sharpness, StringFormat={}{0:F0}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Weichz." Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                                                               Value="{Binding NoiseReduction}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding NoiseReduction, StringFormat={}{0:F0}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*" VerticalAlignment="Center">
                                            <TextBlock Text="Methode" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <ComboBox Name="NoiseReductionMethodComboBox"
                                                      Grid.Column="1"
                                                      ItemsSource="{Binding NoiseReductionMethodOptions}"
                                                      SelectedItem="{Binding NoiseReductionMethodLabel}"
                                                      FontSize="11"
                                                      Margin="6,0,0,0"
                                                      HorizontalAlignment="Stretch"
                                                      DropDownOpened="OnMatchWidthDropDownOpened"
                                                      ToolTip.Tip="Gaussian: gleichmäßiges Weichzeichnen. Median: kantenerhaltend, echte Rauschunterdrückung." />
                                        </Grid>
                                    </StackPanel>
                                </Expander>
                            </Border>

                            <!-- EFFEKTE (ausklappbar) -->
                            <Border Grid.Row="7" Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowFrameAdjustments}">
                                <Expander Header="Effekte" IsExpanded="True">
                                    <Expander.HeaderTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="8"
                                                            VerticalAlignment="Center">
                                                    <icons:SvgIcon
                                                        Source="avares://FerrumPix/Assets/Icons/03_Editor/35_Rahmen.svg"
                                                        Width="14" Height="14" />
                                                    <TextBlock Text="{Binding}" FontWeight="SemiBold" />
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Classes="icon-btn"
                                                        Width="28"
                                                        Height="28"
                                                        Padding="0"
                                                        Command="{Binding DataContext.ResetEffectsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        ToolTip.Tip="Effekte zurücksetzen">
                                                    <icons:SvgIcon
                                                        Source="avares://FerrumPix/Assets/Icons/01_Navigation/14_Aktualisieren.svg"
                                                        Width="14" Height="14" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </Expander.HeaderTemplate>
                                    <StackPanel Spacing="2" Margin="0,8,0,0">
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Vignette" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100"
                                                               Value="{Binding Vignette}" Margin="6,0" />
                                            <TextBlock Grid.Column="2" Text="{Binding Vignette, StringFormat={}{0:F0}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Korn" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                                                               Value="{Binding Grain}" Margin="6,0" />
                                            <TextBlock Grid.Column="2" Text="{Binding Grain, StringFormat={}{0:F0}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Rahmen" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="25"
                                                               Value="{Binding BorderSize}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding BorderSize, StringFormat={}{0:F0}%}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*" VerticalAlignment="Top">
                                            <TextBlock Text="Farbe" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <StackPanel Grid.Column="1" Margin="6,0,0,0" Spacing="6">
                                                <icons:ColorPickerButton
                                                    SelectedColor="{Binding BorderColorValue, Mode=TwoWay}" />

                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Expander>
                            </Border>

                            <Border Grid.Row="8" Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowFilterAdjustments}">
                                <Expander Header="Filter" IsExpanded="True">
                                    <Expander.HeaderTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <icons:SvgIcon
                                                    Source="avares://FerrumPix/Assets/Icons/07_Symbole/32_Filter.svg"
                                                    Width="14" Height="14" />
                                                <TextBlock Text="{Binding}" FontWeight="SemiBold" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </Expander.HeaderTemplate>
                                    <StackPanel Spacing="2" Margin="0,8,0,0">
                                        <ComboBox ItemsSource="{Binding FilterPresetOptions}"
                                                  SelectedItem="{Binding FilterPreset}"
                                                  HorizontalAlignment="Stretch"
                                                  FontSize="11"
                                                  DropDownOpened="OnMatchWidthDropDownOpened" />
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Stärke" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="100"
                                                               Value="{Binding FilterStrength}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding FilterStrength, StringFormat={}{0:F0}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <WrapPanel>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetFilterPresetCommand}" CommandParameter="Keine">
                                                <TextBlock Text="Keine" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetFilterPresetCommand}" CommandParameter="S/W">
                                                <TextBlock Text="S/W" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetFilterPresetCommand}" CommandParameter="Warm">
                                                <TextBlock Text="Warm" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetFilterPresetCommand}" CommandParameter="Kühl">
                                                <TextBlock Text="Kühl" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetFilterPresetCommand}" CommandParameter="Fade">
                                                <TextBlock Text="Fade" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetFilterPresetCommand}"
                                                    CommandParameter="Kontrast">
                                                <TextBlock Text="Kontrast" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetFilterPresetCommand}" CommandParameter="Sepia">
                                                <TextBlock Text="Sepia" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetFilterPresetCommand}" CommandParameter="Matt">
                                                <TextBlock Text="Matt" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetFilterPresetCommand}" CommandParameter="Cross">
                                                <TextBlock Text="Cross" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetFilterPresetCommand}"
                                                    CommandParameter="Dramatisch">
                                                <TextBlock Text="Dramatisch" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetFilterPresetCommand}" CommandParameter="Weich">
                                                <TextBlock Text="Weich" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetFilterPresetCommand}" CommandParameter="Noir">
                                                <TextBlock Text="Noir" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetFilterPresetCommand}"
                                                    CommandParameter="Duoton">
                                                <TextBlock Text="Duoton" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetFilterPresetCommand}"
                                                    CommandParameter="Polaroid">
                                                <TextBlock Text="Polaroid" FontSize="11" />
                                            </Button>
                                            <Button Classes="ghost" Padding="8,5" Margin="0,0,6,6"
                                                    Command="{Binding SetFilterPresetCommand}" CommandParameter="VHS">
                                                <TextBlock Text="VHS" FontSize="11" />
                                            </Button>
                                        </WrapPanel>
                                    </StackPanel>
                                </Expander>
                            </Border>

                            <!-- TONWERTKURVE (ausklappbar) -->
                            <Border Grid.Row="10" Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowLightAdjustments}">
                                <Grid RowDefinitions="Auto,*">
                                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <icons:SvgIcon
                                                Source="avares://FerrumPix/Assets/Icons/03_Editor/05_Kurven.svg"
                                                Width="14" Height="14" />
                                            <TextBlock Text="Tonwertkurve" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Classes="icon-btn"
                                                Width="28"
                                                Height="28"
                                                Padding="0"
                                                Command="{Binding DataContext.ResetCurveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                ToolTip.Tip="Kurve zurücksetzen">
                                            <icons:SvgIcon
                                                Source="avares://FerrumPix/Assets/Icons/01_Navigation/14_Aktualisieren.svg"
                                                Width="14" Height="14" />
                                        </Button>
                                    </Grid>
                                    <StackPanel Grid.Row="1" Spacing="8" Margin="0,8,0,0">
                                        <StackPanel Orientation="Horizontal" Spacing="14">
                                            <Button Classes="info-tab" Command="{Binding SetCurveChannelCommand}"
                                                    CommandParameter="Rgb" Classes.active="{Binding IsCurveChannelRgb}">
                                                <TextBlock Text="RGB" FontSize="11" />
                                            </Button>
                                            <Button Classes="info-tab" Command="{Binding SetCurveChannelCommand}"
                                                    CommandParameter="Red" Classes.active="{Binding IsCurveChannelRed}">
                                                <TextBlock Text="R" FontSize="11" />
                                            </Button>
                                            <Button Classes="info-tab" Command="{Binding SetCurveChannelCommand}"
                                                    CommandParameter="Green"
                                                    Classes.active="{Binding IsCurveChannelGreen}">
                                                <TextBlock Text="G" FontSize="11" />
                                            </Button>
                                            <Button Classes="info-tab" Command="{Binding SetCurveChannelCommand}"
                                                    CommandParameter="Blue"
                                                    Classes.active="{Binding IsCurveChannelBlue}">
                                                <TextBlock Text="B" FontSize="11" />
                                            </Button>
                                            <Button Classes="info-tab" Command="{Binding SetCurveChannelCommand}"
                                                    CommandParameter="Luminance"
                                                    Classes.active="{Binding IsCurveChannelLuminance}">
                                                <TextBlock Text="L" FontSize="11" />
                                            </Button>
                                        </StackPanel>
                                        <icons:CurveEditor Height="180"
                                                           Points="{Binding ActiveCurvePoints}"
                                                           HistogramCounts="{Binding ActiveCurveHistogramCounts}"
                                                           CurveBrush="{Binding ActiveCurveBrush}"
                                                           ToolTip.Tip="Linksklick: Punkt hinzufügen/verschieben. Rechtsklick: Punkt entfernen." />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- COLOR GRADING (ausklappbar) -->
                            <Border Grid.Row="11" Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowColorAdjustments}">
                                <Grid RowDefinitions="Auto,*">
                                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <icons:SvgIcon
                                                Source="avares://FerrumPix/Assets/Icons/03_Editor/17_Farbmischer.svg"
                                                Width="14" Height="14" />
                                            <TextBlock Text="Farbmischer" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Classes="icon-btn"
                                                Width="28"
                                                Height="28"
                                                Padding="0"
                                                Command="{Binding DataContext.ResetHslCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                ToolTip.Tip="Farbmischer zurücksetzen">
                                            <icons:SvgIcon
                                                Source="avares://FerrumPix/Assets/Icons/01_Navigation/14_Aktualisieren.svg"
                                                Width="14" Height="14" />
                                        </Button>
                                    </Grid>
                                    <StackPanel Grid.Row="1" Spacing="8" Margin="0,8,0,0">
                                        <icons:HslWheelPicker SelectedBand="{Binding SelectedHslBand, Mode=TwoWay}"
                                                              Width="150" Height="150"
                                                              HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding SelectedHslBandLabel}"
                                                   FontWeight="SemiBold"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center" />
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Farbton" Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="-60" Maximum="60"
                                                               Value="{Binding ActiveHslHue}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding ActiveHslHue, StringFormat={}{0:F0}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Sättigung"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="-100" Maximum="100"
                                                               Value="{Binding ActiveHslSaturation}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding ActiveHslSaturation, StringFormat={}{0:F0}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="12" Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowTransformAdjustments}">
                                <Expander Header="Drehen" IsExpanded="True">
                                    <Expander.HeaderTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="8"
                                                            VerticalAlignment="Center">
                                                    <icons:SvgIcon
                                                        Source="avares://FerrumPix/Assets/Icons/03_Editor/35_Rahmen.svg"
                                                        Width="14" Height="14" />
                                                    <TextBlock Text="{Binding}" FontWeight="SemiBold" />
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Classes="icon-btn"
                                                        Width="28"
                                                        Height="28"
                                                        Padding="0"
                                                        Command="{Binding DataContext.ResetTransformCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        ToolTip.Tip="Transformieren zurücksetzen">
                                                    <icons:SvgIcon
                                                        Source="avares://FerrumPix/Assets/Icons/01_Navigation/14_Aktualisieren.svg"
                                                        Width="14" Height="14" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </Expander.HeaderTemplate>
                                    <StackPanel Spacing="2" Margin="0,8,0,0">
                                        <Grid ColumnDefinitions="*,*">
                                            <Button Classes="ghost" Padding="10,7" Margin="0,0,4,0"
                                                    Command="{Binding RotateLeftCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <icons:SvgIcon
                                                        Source="avares://FerrumPix/Assets/Icons/04_Viewer/29_Nach_links_drehen.svg"
                                                        Width="20" Height="20" />
                                                    <TextBlock Text="Links" />
                                                </StackPanel>
                                            </Button>
                                            <Button Grid.Column="1" Classes="ghost" Padding="10,7" Margin="4,0,0,0"
                                                    Command="{Binding RotateRightCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <icons:SvgIcon
                                                        Source="avares://FerrumPix/Assets/Icons/04_Viewer/30_Nach_rechts_drehen.svg"
                                                        Width="20" Height="20" />
                                                    <TextBlock Text="Rechts" />
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                        <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center">
                                            <TextBlock Text="Ausrichten"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       VerticalAlignment="Center" FontSize="11" />
                                            <icons:RoundSlider Grid.Column="1" Minimum="-45" Maximum="45"
                                                               Value="{Binding StraightenDegrees}" Margin="6,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding StraightenDegrees, StringFormat={}{0:F1}}"
                                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontSize="11" />
                                        </Grid>
                                        <CheckBox Content="Leinwand automatisch vergrößern"
                                                  IsChecked="{Binding StraightenExpandCanvas}"
                                                  FontSize="11"
                                                  ToolTip.Tip="Vergrößert die Leinwand beim Ausrichten so, dass keine Bildecken abgeschnitten werden, statt das Bild zum Ausgleich hineinzuzoomen" />
                                        <Grid ColumnDefinitions="*,*">
                                            <Button Classes="ghost" Padding="10,7" Margin="0,0,4,0"
                                                    Command="{Binding FlipHorizontalCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <icons:SvgIcon
                                                        Source="avares://FerrumPix/Assets/Icons/04_Viewer/31_Horizontal_spiegeln.svg"
                                                        Width="20" Height="20" />
                                                    <TextBlock Text="Horizontal" />
                                                </StackPanel>
                                            </Button>
                                            <Button Grid.Column="1" Classes="ghost" Padding="10,7" Margin="4,0,0,0"
                                                    Command="{Binding FlipVerticalCommand}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <icons:SvgIcon
                                                        Source="avares://FerrumPix/Assets/Icons/04_Viewer/32_Vertikal_spiegeln.svg"
                                                        Width="20" Height="20" />
                                                    <TextBlock Text="Vertikal" />
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                        <Button Classes="accent"
                                                HorizontalAlignment="Stretch"
                                                Padding="10,6"
                                                Margin="0,6,0,0"
                                                Command="{Binding ApplyTransformCommand}"
                                                IsEnabled="{Binding HasTransformChanges}"
                                                ToolTip.Tip="Drehung auf die Vorschau anwenden">
                                            <StackPanel Orientation="Horizontal" Spacing="6"
                                                        HorizontalAlignment="Center">
                                                <icons:SvgIcon
                                                    Source="avares://FerrumPix/Assets/Icons/07_Symbole/15_Ausgewaehlt.svg"
                                                    Width="16" Height="16" />
                                                <TextBlock Text="Drehung annehmen" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Expander>
                            </Border>

                            <Border Grid.Row="9" Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowSelectionAdjustments}">
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <icons:SvgIcon
                                            Source="avares://FerrumPix/Assets/Icons/09_FormenSymbole/005_Rechteck.svg"
                                            Width="14" Height="14" />
                                        <TextBlock Text="Auswahl" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <TextBlock Text="Rechteck im Bild aufziehen, dann kopieren oder füllen."
                                               Foreground="{DynamicResource FP.Text.Secondary}"
                                               FontSize="11"
                                               TextWrapping="Wrap" />
                                    <Button Classes="ghost"
                                            HorizontalAlignment="Stretch"
                                            Padding="10,6"
                                            IsEnabled="{Binding HasActiveSelection}"
                                            Command="{Binding CopySelectionCommand}"
                                            ToolTip.Tip="Auswahlinhalt als neues, frei verschiebbares Bild-Objekt kopieren">
                                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                            <icons:SvgIcon
                                                Source="avares://FerrumPix/Assets/Icons/09_FormenSymbole/077_Bild.svg"
                                                Width="16" Height="16" />
                                            <TextBlock Text="Kopieren" />
                                        </StackPanel>
                                    </Button>

                                    <Border Height="1" Background="{DynamicResource FP.Border.Normal}" Margin="0,4,0,0" />
                                    <TextBlock Text="Füllen" Foreground="{DynamicResource FP.Text.Secondary}"
                                               FontSize="11" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Button Classes="ghost" Padding="8,4"
                                                Command="{Binding SetAnnotationFillKindCommand}"
                                                CommandParameter="Solid"
                                                Classes.active="{Binding AnnotationFillKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Solid}">
                                            <TextBlock Text="Vollfarbe" FontSize="11" />
                                        </Button>
                                        <Button Classes="ghost" Padding="8,4"
                                                Command="{Binding SetAnnotationFillKindCommand}"
                                                CommandParameter="LinearGradient"
                                                Classes.active="{Binding AnnotationFillKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=LinearGradient}">
                                            <TextBlock Text="Verlauf" FontSize="11" />
                                        </Button>
                                        <Button Classes="ghost" Padding="8,4"
                                                Command="{Binding SetAnnotationFillKindCommand}"
                                                CommandParameter="RadialGradient"
                                                Classes.active="{Binding AnnotationFillKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=RadialGradient}">
                                            <TextBlock Text="Radial" FontSize="11" />
                                        </Button>
                                    </StackPanel>
                                    <Grid ColumnDefinitions="74,*" VerticalAlignment="Top">
                                        <TextBlock Text="Farbe 1" Foreground="{DynamicResource FP.Text.Secondary}"
                                                   VerticalAlignment="Center" FontSize="11" />
                                        <icons:ColorPickerButton Grid.Column="1"
                                                                 SelectedColor="{Binding AnnotationFillColorValue, Mode=TwoWay}" />

                                    </Grid>
                                    <Grid ColumnDefinitions="74,*" VerticalAlignment="Top"
                                          IsVisible="{Binding ShowGradientFillControls}">
                                        <TextBlock Text="Farbe 2" Foreground="{DynamicResource FP.Text.Secondary}"
                                                   VerticalAlignment="Center" FontSize="11" />
                                        <icons:ColorPickerButton Grid.Column="1"
                                                                 SelectedColor="{Binding AnnotationFillColor2Value, Mode=TwoWay}" />

                                    </Grid>
                                    <Grid ColumnDefinitions="74,*,38" VerticalAlignment="Center"
                                          IsVisible="{Binding ShowLinearGradientAngleControl}">
                                        <TextBlock Text="Winkel" Foreground="{DynamicResource FP.Text.Secondary}"
                                                   VerticalAlignment="Center" FontSize="11" />
                                        <icons:RoundSlider Grid.Column="1" Minimum="0" Maximum="360"
                                                           Value="{Binding AnnotationGradientAngleDegrees}"
                                                           Margin="6,0" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding AnnotationGradientAngleDegrees, StringFormat={}{0:F0}°}"
                                                   Foreground="{DynamicResource FP.Text.Secondary}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11" />
                                    </Grid>
                                    <CheckBox Content="Verlauf invertieren"
                                              IsChecked="{Binding AnnotationGradientInverted}" FontSize="11"
                                              IsVisible="{Binding ShowRadialGradientControl}" />
                                    <Button Classes="accent"
                                            HorizontalAlignment="Stretch"
                                            Padding="10,6"
                                            IsEnabled="{Binding HasActiveSelection}"
                                            Command="{Binding FillSelectionCommand}"
                                            ToolTip.Tip="Auswahl mit der gewählten Füllung füllen">
                                        <TextBlock Text="Auswahl füllen" HorizontalAlignment="Center" />
                                    </Button>
                                </StackPanel>
                            </Border>

                        </Grid>
                    </ScrollViewer>

                    <Grid Margin="14,10,14,14" RowDefinitions="Auto,*" IsVisible="{Binding !IsToolTabSelected}">
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4"
                                    IsVisible="{Binding IsLayersTabSelected}">
                            <Button Classes="icon-btn" Width="30" Height="30" Padding="0"
                                    Command="{Binding DuplicateSelectedAnnotationCommand}"
                                    IsEnabled="{Binding HasSelectedAnnotation}"
                                    ToolTip.Tip="Objekt duplizieren (Strg+D)">
                                <TextBlock Text="⧉" FontSize="13" />
                            </Button>
                            <Button Classes="icon-btn" Width="30" Height="30" Padding="0"
                                    Command="{Binding MoveSelectedAnnotationUpCommand}"
                                    IsEnabled="{Binding HasSelectedAnnotation}"
                                    ToolTip.Tip="Objekt nach vorne">
                                <TextBlock Text="↑" FontSize="14" />
                            </Button>
                            <Button Classes="icon-btn" Width="30" Height="30" Padding="0"
                                    Command="{Binding MoveSelectedAnnotationDownCommand}"
                                    IsEnabled="{Binding HasSelectedAnnotation}"
                                    ToolTip.Tip="Objekt nach hinten">
                                <TextBlock Text="↓" FontSize="14" />
                            </Button>
                            <Button Classes="icon-btn" Width="30" Height="30" Padding="0"
                                    Command="{Binding DeleteSelectedAnnotationCommand}"
                                    IsEnabled="{Binding HasSelectedAnnotation}"
                                    ToolTip.Tip="Objekt löschen (Entf)">
                                <TextBlock Text="×" FontSize="16" Foreground="{DynamicResource FP.Text.Muted}" />
                            </Button>
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,7,0,0">
                            <Grid RowDefinitions="Auto,*" IsVisible="{Binding IsLayersTabSelected}">
                                <ListBox Grid.Row="1"
                                         Classes="layers-list"
                                         ItemsSource="{Binding TextAnnotations}"
                                         SelectedIndex="{Binding SelectedAnnotationIndex}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0"
                                         VerticalAlignment="Stretch"
                                         IsVisible="{Binding HasAnnotationChanges}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6"
                                                    Classes="layer-item"
                                                    BorderThickness="1"
                                                    BorderBrush="{DynamicResource FP.Border.Normal}"
                                                    Padding="4,2"
                                                    Margin="0,0,0,2"
                                                    MinHeight="34">
                                                <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                                                    <ToggleButton Grid.Column="0"
                                                                  Classes="ghost layer-eye"
                                                                  Width="22"
                                                                  Height="22"
                                                                  Padding="0"
                                                                  IsChecked="{Binding IsVisible, Mode=OneWay}"
                                                                  Command="{Binding DataContext.ToggleAnnotationVisibilityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  CommandParameter="{Binding}"
                                                                  ToolTip.Tip="Objekt ein-/ausblenden">
                                                        <icons:SvgIcon
                                                            Source="avares://FerrumPix/Assets/Icons/07_Symbole/11_Auge.svg"
                                                            Width="13" Height="13" />
                                                    </ToggleButton>
                                                    <Border Grid.Column="1"
                                                            Width="18"
                                                            Height="18"
                                                            Margin="4,0,0,0"
                                                            CornerRadius="4"
                                                            BorderThickness="1"
                                                            BorderBrush="{DynamicResource FP.Border.Normal}"
                                                            Background="{DynamicResource FP.Bg.Input}">
                                                        <icons:SvgIcon Source="{Binding IconSource}"
                                                                       Width="11"
                                                                       Height="11"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" />
                                                    </Border>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding LayerLabel}"
                                                               FontSize="11"
                                                               Margin="5,0,0,0"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center" />
                                                    <Button Grid.Column="3"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Padding="2"
                                                            VerticalAlignment="Center"
                                                            Command="{Binding DataContext.DeleteAnnotationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip.Tip="Objekt löschen">
                                                        <TextBlock Text="×" FontSize="14"
                                                                   Foreground="{DynamicResource FP.Text.Muted}" />
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>

                            <ScrollViewer IsVisible="{Binding IsHistoryTabSelected}" VerticalScrollBarVisibility="Auto"
                                          FocusAdorner="{x:Null}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Zuletzt zuerst"
                                               Foreground="{DynamicResource FP.Text.Muted}"
                                               FontSize="11"
                                               TextWrapping="Wrap" />
                                    <ListBox ItemsSource="{Binding HistoryItems}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="0"
                                             IsHitTestVisible="False"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontSize="11"
                                                           TextTrimming="CharacterEllipsis" Margin="0,3" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <views:InfoSidebarView Grid.Row="1" Grid.Column="3" />

        <Border Grid.Row="2"
                Grid.ColumnSpan="4"
                Background="{DynamicResource FP.Bg.Dark}"
                BorderBrush="{DynamicResource FP.Border.Subtle}"
                BorderThickness="0,1,0,0"
                Padding="24,8,24,8">
            <Grid RowDefinitions="Auto,28">
                <ListBox Name="FilmstripListBox"
                         Classes="filmstrip-list"
                         Height="110"
                         IsVisible="{Binding ShowFilmstrip}"
                         ItemsSource="{Binding FilmstripItems}"
                         SelectedIndex="{Binding CurrentFilmstripIndex, Mode=OneWay}"
                         SelectionMode="Single"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel Orientation="Horizontal" Margin="0,0,0,8" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ImageItem}">
                            <Border Width="148" Height="100"
                                    Classes="thumb-card"
                                    Classes.selected="{Binding IsSelected}"
                                    ClipToBounds="True"
                                    PointerPressed="OnFilmstripItemPressed">
                                <Border CornerRadius="6" ClipToBounds="True">
                                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                                           RenderOptions.BitmapInterpolationMode="LowQuality" />
                                </Border>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Grid Grid.Row="1" ColumnDefinitions="*,Auto,*" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentFileName}" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource FP.Text.Secondary}"
                                   FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding PositionText}" Foreground="{DynamicResource FP.Text.Secondary}"
                                   FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding MousePositionText}"
                                   IsVisible="{Binding MousePositionText, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}}"
                                   Foreground="{DynamicResource FP.Text.Muted}" FontSize="12"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="Zoom:" Foreground="{DynamicResource FP.Text.Secondary}"
                                   VerticalAlignment="Center" Margin="0,0,4,0" />
                        <Button Classes="ghost" Height="28" Padding="6,2" VerticalContentAlignment="Center"
                                Focusable="False"
                                Click="OnZoomOutClick" ToolTip.Tip="Verkleinern">
                            <TextBlock Text="−" FontSize="15" Foreground="{DynamicResource FP.Text.Secondary}" />
                        </Button>
                        <icons:RoundSlider Name="EditorZoomSlider" Width="110" Height="26" MinHeight="0" Minimum="0" Maximum="100"
                                           Value="{Binding ZoomSliderValue, Mode=TwoWay}" VerticalAlignment="Center" />
                        <Button Classes="ghost" Height="28" Padding="6,2" VerticalContentAlignment="Center"
                                Focusable="False"
                                Click="OnZoomInClick" ToolTip.Tip="Vergrößern">
                            <TextBlock Text="+" FontSize="15" Foreground="{DynamicResource FP.Text.Secondary}" />
                        </Button>
                        <Button Classes="ghost" Height="28" Padding="8,2" Margin="12,0,0,0" Focusable="False"
                                Classes.active="{Binding IsZoomActualActive}"
                                Click="OnZoomActualClick" ToolTip.Tip="Auf 100 Prozent springen">
                            <TextBlock Text="100%" Foreground="{DynamicResource FP.Text.Primary}"
                                       VerticalAlignment="Center" />
                        </Button>
                        <Button Classes="ghost" Height="28" Padding="8,2" Margin="8,0,0,0" Focusable="False"
                                Classes.active="{Binding IsZoomFitActive}"
                                Click="OnZoomFitClick"
                                ToolTip.Tip="Bild vollständig in die Vorschau einpassen">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/01_Navigation/26_Anpassen.svg"
                                               Width="20" Height="20" />
                                <TextBlock Text="Einpassen" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal" Spacing="1" VerticalAlignment="Center">
                            <Button Classes="star-btn" Background="Transparent" BorderThickness="0" Padding="2" 
                                    Classes.active="{Binding Rating, Converter={StaticResource RatingThresholdConverter}, ConverterParameter=1}"
                                    Command="{Binding SetRatingCommand}" CommandParameter="1">
                                <TextBlock FontSize="20" VerticalAlignment="Center"
                                           Text="{Binding Rating, Converter={StaticResource RatingStarGlyphConverter}, ConverterParameter=1}" />
                            </Button>
                            <Button Classes="star-btn" Background="Transparent" BorderThickness="0" Padding="2"
                                    Classes.active="{Binding Rating, Converter={StaticResource RatingThresholdConverter}, ConverterParameter=2}"
                                    Command="{Binding SetRatingCommand}" CommandParameter="2">
                                <TextBlock FontSize="20" VerticalAlignment="Center"
                                           Text="{Binding Rating, Converter={StaticResource RatingStarGlyphConverter}, ConverterParameter=2}" />
                            </Button>
                            <Button Classes="star-btn" Background="Transparent" BorderThickness="0" Padding="2"
                                    Classes.active="{Binding Rating, Converter={StaticResource RatingThresholdConverter}, ConverterParameter=3}"
                                    Command="{Binding SetRatingCommand}" CommandParameter="3">
                                <TextBlock FontSize="20" VerticalAlignment="Center"
                                           Text="{Binding Rating, Converter={StaticResource RatingStarGlyphConverter}, ConverterParameter=3}" />
                            </Button>
                            <Button Classes="star-btn" Background="Transparent" BorderThickness="0" Padding="2"
                                    Classes.active="{Binding Rating, Converter={StaticResource RatingThresholdConverter}, ConverterParameter=4}"
                                    Command="{Binding SetRatingCommand}" CommandParameter="4">
                                <TextBlock FontSize="20" VerticalAlignment="Center"
                                           Text="{Binding Rating, Converter={StaticResource RatingStarGlyphConverter}, ConverterParameter=4}" />
                            </Button>
                            <Button Classes="star-btn" Background="Transparent" BorderThickness="0" Padding="2"
                                    Classes.active="{Binding Rating, Converter={StaticResource RatingThresholdConverter}, ConverterParameter=5}"
                                    Command="{Binding SetRatingCommand}" CommandParameter="5">
                                <TextBlock FontSize="20" VerticalAlignment="Center"
                                           Text="{Binding Rating, Converter={StaticResource RatingStarGlyphConverter}, ConverterParameter=5}" />
                            </Button>
                            <Button Classes="icon-btn"
                                    Width="24" Height="24" VerticalAlignment="Center"
                                    Command="{Binding ToggleFavoriteCommand}"
                                    ToolTip.Tip="Favorit" Margin="6,0,0,0">
                                <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/07_Symbole/02_Herz.svg"
                                               Width="20" Height="20" 
                                               Classes="fav-heart" Classes.active="{Binding IsFavorite}" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Schnellvorschau-Overlay (Mausrad-Klick auf Filmstrip) -->
        <Panel Name="FilmstripPreviewOverlay"
               Grid.RowSpan="3" Grid.ColumnSpan="4"
               IsVisible="False"
               Background="#D9000000"
               ZIndex="100">
            <Image Name="FilmstripPreviewImage"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="60" />
        </Panel>

    </Grid>
</UserControl>