<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:FerrumPix.Controls"
             xmlns:views="clr-namespace:FerrumPix.Views"
             xmlns:vm="clr-namespace:FerrumPix.ViewModels"
             xmlns:services="clr-namespace:FerrumPix.Services"
             xmlns:models="clr-namespace:FerrumPix.Models"
             xmlns:panels="clr-namespace:FerrumPix.Controls.EditorPanels"
             xmlns:conv="clr-namespace:Avalonia.Data.Converters;assembly=Avalonia.Base"
             x:Class="FerrumPix.Views.EditorView"
             Classes="editor-view"
             Background="{DynamicResource FP.Bg.Root}"
             Focusable="True"
             FocusAdorner="{x:Null}"
             KeyDown="OnKeyDown"
             KeyUp="OnKeyUp"
             PointerReleased="OnGlobalPointerReleased">

    <Grid x:Name="EditorRootGrid" RowDefinitions="60,*,Auto" ColumnDefinitions="190,*,330,320,300">

        <Border Grid.Row="0" Grid.ColumnSpan="5" Classes="toolbar" Height="60" Padding="24,0">
            <Grid ColumnDefinitions="*,Auto,*" VerticalAlignment="Center">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Left">
                    <Button Classes="icon-btn" Width="38" Height="38"
                            Command="{Binding BackToViewerCommand}"
                            ToolTip.Tip="Zurück">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/home.svg"
                                       Width="20" Height="20" />
                    </Button>
                    <Button Classes="icon-btn" Width="38" Height="38"
                            Command="{Binding PreviousCommand}"
                            ToolTip.Tip="Vorheriges Bild">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/arrow-left.svg"
                                       Width="20" Height="20" />
                    </Button>
                    <Button Classes="icon-btn" Width="38" Height="38"
                            Command="{Binding NextCommand}"
                            ToolTip.Tip="Nächstes Bild">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/arrow-right.svg"
                                       Width="20" Height="20" />
                    </Button>
                    <StackPanel Margin="26,0,0,0" VerticalAlignment="Center" >
                        <TextBlock Text="{Binding CurrentFileName}" FontSize="{DynamicResource FP.Font.Subtitle}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding StatusText}"
                                   Classes="status-text"
                                   Classes.failed="{Binding PreviewFailed}"
                                   FontSize="{DynamicResource FP.Font.Caption}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="-110,0,0,0">
                    <Button Name="PanModeButton" Classes="ghost" Height="38" Padding="8,2"
                            Margin="0,0,0,0" ToolTip.Tip="Verschieben-Modus ein- oder ausschalten"
                            Focusable="False"
                            Click="OnPanModeToggleClick">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/pinned.svg"
                                           Width="20" Height="20" />
                            <TextBlock Text="Verschieben" />
                        </StackPanel>
                    </Button>

                    <Button Name="RulerModeButton" Classes="ghost" Height="38" Padding="8,2"
                            Margin="0,0,0,0" ToolTip.Tip="Lineale und Hilfslinien ein- oder ausblenden"
                            Focusable="False"
                            Click="OnRulerModeToggleClick">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/ruler-2.svg"
                                           Width="20" Height="20" />
                            <TextBlock Text="Lineale" />
                        </StackPanel>
                    </Button>

                    <Button Name="GridModeButton" Classes="ghost" Height="38" Padding="8,2"
                            Margin="0,0,0,0" ToolTip.Tip="Raster ein- oder ausblenden (Größe: Einstellungen → Editor)"
                            Focusable="False"
                            Click="OnGridModeToggleClick">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/grid-pattern.svg"
                                           Width="20" Height="20" />
                            <TextBlock Text="Raster" />
                        </StackPanel>
                    </Button>

                    <Button Classes="ghost"
                            Height="38"
                            Padding="8,2"
                            Margin="0,0,0,0"
                            IsEnabled="{Binding CanShowBeforeAfter}"
                            Classes.active="{Binding ShowBeforeImage}"
                            Click="OnToggleBeforeAfterClick"
                            ToolTip.Tip="Vergleich ein- oder ausblenden">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/eye.svg"
                                           Width="18" Height="18" />
                            <TextBlock Text="Vergleich" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                    
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Button Classes="icon-btn" Width="38" Height="38"
                            IsEnabled="{Binding CanUndo}"
                            Command="{Binding UndoCommand}"
                            ToolTip.Tip="Rückgängig">
                        <Canvas Width="20" Height="20">
                            <Path Stroke="{DynamicResource FP.Text.Secondary}"
                                  StrokeThickness="2"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round"
                                  Data="M 8 5 L 4 9 L 8 13 M 5 9 H 12 C 15 9 17 11 17 14 C 17 17 15 19 12 19 H 8" />
                        </Canvas>
                    </Button>
                    <Button Classes="icon-btn" Width="38" Height="38"
                            IsEnabled="{Binding CanRedo}"
                            Command="{Binding RedoCommand}"
                            ToolTip.Tip="Wiederholen">
                        <Canvas Width="20" Height="20">
                            <Path Stroke="{DynamicResource FP.Text.Secondary}"
                                  StrokeThickness="2"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round"
                                  Data="M 12 5 L 16 9 L 12 13 M 15 9 H 8 C 5 9 3 11 3 14 C 3 17 5 19 8 19 H 12" />
                        </Canvas>
                    </Button>
                    <Button Classes="accent" Height="38" Padding="16,7" Command="{Binding SaveCommand}"
                            IsEnabled="{Binding CanSaveInPlace}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/device-floppy.svg"
                                           Width="20" Height="20" />
                            <TextBlock Text="Speichern" />
                        </StackPanel>
                    </Button>
                    <Button Classes="ghost active" Height="38" Padding="12,7" Command="{Binding SaveAsCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/file-export.svg"
                                           Width="20" Height="20" />
                            <TextBlock Text="Speichern unter..." />
                        </StackPanel>
                    </Button>
                    <Button Classes="icon-btn"
                            Width="38" Height="38"
                            Command="{Binding DeleteCurrentCommand}"
                            ToolTip.Tip="Löschen">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/trash.svg"
                                       Width="18" Height="18" />
                    </Button>
                    <Button Classes="icon-btn" Width="38" Height="38"
                            Classes.active="{Binding IsLayersPanelVisible}"
                            Command="{Binding ToggleLayersPanelCommand}"
                            ToolTip.Tip="Ebenen-Panel">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/stack-2.svg" Width="20"
                                       Height="20" />
                    </Button>
                    <Button Classes="icon-btn"
                            Width="38" Height="38"
                            Click="OnToggleFilmstripClick"
                            Classes.active="{Binding ShowFilmstrip}"
                            ToolTip.Tip="Filmstreifen ein- oder ausblenden">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/eye.svg"
                                       Width="18" Height="18" />
                    </Button>
                    <Button Classes="icon-btn" Width="38" Height="38"
                            Classes.active="{Binding IsInfoSidebarVisible}"
                            Command="{Binding ToggleInfoSidebarCommand}"
                            ToolTip.Tip="Info-Seitenleiste">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/info-circle.svg" Width="20"
                                       Height="20" />
                    </Button>
                    <Button Classes="icon-btn"
                            Width="38" Height="38"
                            Click="OnSettingsClick"
                            ToolTip.Tip="Einstellungen">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/settings.svg"
                                       Width="18" Height="18" />
                    </Button>
                    <Button Classes="icon-btn" Width="38" Height="38"
                            Click="OnFullscreenClick"
                            ToolTip.Tip="Vollbild">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/maximize.svg"
                                       Width="20" Height="20" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Classes="sidebar" Padding="8,8">
            <ScrollViewer VerticalScrollBarVisibility="Auto" FocusAdorner="{x:Null}">
                <StackPanel Spacing="2">
                    <TextBlock Text="TRANSFORMIEREN" Foreground="{DynamicResource FP.Text.Muted}" FontSize="{DynamicResource FP.Font.Caption}"
                               FontWeight="SemiBold" Margin="10,0,0,4" />
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Zuschneiden"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Crop"
                            Classes.active="{Binding CurrentTool, Converter={StaticResource EditorToolEqualsConverter}, ConverterParameter=Crop}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/crop.svg"
                                           Width="18" Height="18" />
                            <TextBlock Text="Zuschneiden" FontSize="{DynamicResource FP.Font.Body}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Bildgröße"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Resize"
                            Classes.active="{Binding CurrentTool, Converter={StaticResource EditorToolEqualsConverter}, ConverterParameter=Resize}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/aspect-ratio.svg"
                                           Width="18" Height="18" />
                            <TextBlock Text="Bildgröße" FontSize="{DynamicResource FP.Font.Body}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Drehen"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Rotate"
                            Classes.active="{Binding CurrentTool, Converter={StaticResource EditorToolEqualsConverter}, ConverterParameter=Rotate}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/rotate-2.svg"
                                           Width="18" Height="18" />
                            <TextBlock Text="Drehen" FontSize="{DynamicResource FP.Font.Body}" />
                        </StackPanel>
                    </Button>

                    <TextBlock Text="ANPASSUNGEN" Foreground="{DynamicResource FP.Text.Muted}" FontSize="{DynamicResource FP.Font.Caption}"
                               FontWeight="SemiBold" Margin="10,10,0,4" />
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Anpassen"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Adjust"
                            Classes.active="{Binding CurrentTool, Converter={StaticResource EditorToolEqualsConverter}, ConverterParameter=Adjust}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/exposure.svg"
                                           Width="18" Height="18" />
                            <TextBlock Text="Anpassen" FontSize="{DynamicResource FP.Font.Body}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Farbe"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Color"
                            Classes.active="{Binding CurrentTool, Converter={StaticResource EditorToolEqualsConverter}, ConverterParameter=Color}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/color-filter.svg"
                                           Width="18" Height="18" />
                            <TextBlock Text="Farbe" FontSize="{DynamicResource FP.Font.Body}" />
                        </StackPanel>
                    </Button>

                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Details und Effekte"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Effects"
                            Classes.active="{Binding CurrentTool, Converter={StaticResource EditorToolEqualsConverter}, ConverterParameter=Effects}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/adjustments.svg"
                                           Width="18" Height="18" />
                            <TextBlock Text="Details und Effekte" FontSize="{DynamicResource FP.Font.Body}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Filter"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Filters"
                            Classes.active="{Binding CurrentTool, Converter={StaticResource EditorToolEqualsConverter}, ConverterParameter=Filters}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/palette.svg"
                                           Width="18" Height="18" />
                            <TextBlock Text="Filter" FontSize="{DynamicResource FP.Font.Body}" />
                        </StackPanel>
                    </Button>
                    <!-- Die Werkzeuge stehen hier einzeln, statt hinter den Sammelknöpfen "Text und Bild"
                         und "Malen" zu liegen: ein Klick wählt direkt das Werkzeug, mit dem gearbeitet
                         wird. Die zugehörigen Panels rechts zeigen nur noch dessen Einstellungen. -->
                    <TextBlock Text="WERKZEUGE" Foreground="{DynamicResource FP.Text.Muted}" FontSize="{DynamicResource FP.Font.Caption}"
                               FontWeight="SemiBold" Margin="10,10,0,4" />
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Auswahl"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Selection"
                            Classes.active="{Binding CurrentTool, Converter={StaticResource EditorToolEqualsConverter}, ConverterParameter=Selection}"
                            Classes.selected-kind="{Binding SelectedAnnotationToolbarKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Selection}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/pointer.svg"
                                           Width="18" Height="18" />
                            <TextBlock Text="Auswahl" FontSize="{DynamicResource FP.Font.Body}" />
                        </StackPanel>
                    </Button>

                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Text"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Text"
                            Classes.active="{Binding PendingInsertKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Text}"
                            Classes.selected-kind="{Binding SelectedAnnotationToolbarKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Text}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/text-size.svg" Width="18" Height="18" />
                            <TextBlock Text="Text" FontSize="{DynamicResource FP.Font.Body}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Bild"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Image"
                            Classes.active="{Binding PendingInsertKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Image}"
                            Classes.selected-kind="{Binding SelectedAnnotationToolbarKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Image}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/photo.svg" Width="18" Height="18" />
                            <TextBlock Text="Bild" FontSize="{DynamicResource FP.Font.Body}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="QR-Code"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="QR"
                            Classes.active="{Binding PendingInsertKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=QR}"
                            Classes.selected-kind="{Binding SelectedAnnotationToolbarKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=QR}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/qrcode.svg" Width="18" Height="18" />
                            <TextBlock Text="QR-Code" FontSize="{DynamicResource FP.Font.Body}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Wasserzeichen"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Watermark"
                            Classes.active="{Binding PendingInsertKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Watermark}"
                            Classes.selected-kind="{Binding SelectedAnnotationToolbarKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Watermark}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/copyright.svg" Width="18" Height="18" />
                            <TextBlock Text="Wasserzeichen" FontSize="{DynamicResource FP.Font.Body}" />
                        </StackPanel>
                    </Button>

                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Pinsel"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Brush"
                            Classes.active="{Binding SelectedPaintMode, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Brush}"
                            Classes.selected-kind="{Binding SelectedAnnotationToolbarKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Brush}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/brush.svg" Width="18" Height="18" />
                            <TextBlock Text="Pinsel" FontSize="{DynamicResource FP.Font.Body}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Radiergummi"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Eraser"
                            Classes.active="{Binding SelectedPaintMode, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Eraser}"
                            Classes.selected-kind="{Binding SelectedAnnotationToolbarKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Eraser}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/eraser.svg" Width="18" Height="18" />
                            <TextBlock Text="Radiergummi" FontSize="{DynamicResource FP.Font.Body}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Verwischen"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Blur"
                            Classes.active="{Binding SelectedPaintMode, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Blur}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/blur.svg" Width="18" Height="18" />
                            <TextBlock Text="Verwischen" FontSize="{DynamicResource FP.Font.Body}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Reparaturpinsel"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Repair"
                            Classes.active="{Binding SelectedPaintMode, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Repair}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/bandage.svg" Width="18" Height="18" />
                            <TextBlock Text="Reparaturpinsel" FontSize="{DynamicResource FP.Font.Body}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Stempel (Alt+Klick setzt die Quelle)"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Clone"
                            Classes.active="{Binding SelectedPaintMode, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Clone}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/rubber-stamp.svg" Width="18" Height="18" />
                            <TextBlock Text="Stempel" FontSize="{DynamicResource FP.Font.Body}" />
                        </StackPanel>
                    </Button>

                    <Button Classes="tool-btn-row"
                            ToolTip.Tip="Formen und Symbole"
                            Command="{Binding SetToolCommand}"
                            CommandParameter="Insert"
                            Classes.active="{Binding IsGeometryToolSelected}"
                            Classes.selected-kind="{Binding SelectedAnnotationToolbarKind, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Insert}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/shape.svg"
                                           Width="18" Height="18" />
                            <TextBlock Text="Formen und Symbole" FontSize="{DynamicResource FP.Font.Body}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource FP.Bg.Root}" Padding="2">
            <Grid>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10"
                            IsVisible="{Binding CurrentImage, Converter={x:Static ObjectConverters.IsNull}}">
                    <TextBlock Text="Kein Bild zum Bearbeiten" Foreground="{DynamicResource FP.Text.Muted}"
                               FontSize="{DynamicResource FP.Font.Subtitle}" HorizontalAlignment="Center" />
                    <TextBlock Text="Öffne ein Bild aus dem Betrachter" Foreground="{DynamicResource FP.Text.Muted}"
                               FontSize="{DynamicResource FP.Font.Small}" HorizontalAlignment="Center" />
                </StackPanel>

                <Grid RowDefinitions="*,Auto"
                      IsVisible="{Binding CurrentImage, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <!-- Die Lineale teilen sich Spalte bzw. Zeile mit dem Vorschau-Canvas; ihre lokalen
                         Koordinaten entlang der Skala sind damit identisch mit denen des Canvas. Sind sie
                         ausgeblendet, kollabieren die Auto-Spur und der Canvas nutzt die volle Fläche. -->
                    <Grid Grid.Row="0" RowDefinitions="Auto,*" ColumnDefinitions="Auto,*">
                        <Button x:Name="RulerCornerButton"
                                Grid.Row="0" Grid.Column="0"
                                Width="18" Height="18"
                                MinWidth="0" MinHeight="0" Padding="0"
                                CornerRadius="0"
                                Focusable="False"
                                IsVisible="False"
                                Background="{DynamicResource FP.Bg.Elevated}"
                                BorderBrush="{DynamicResource FP.Border.Normal}"
                                BorderThickness="0,0,1,1"
                                Click="OnClearGuidesClick"
                                ToolTip.Tip="Alle Hilfslinien entfernen" />
                        <icons:RulerControl x:Name="TopRuler"
                                            Grid.Row="0" Grid.Column="1"
                                            Height="18"
                                            IsHorizontal="True"
                                            IsVisible="False"
                                            Cursor="Hand"
                                            RulerBackground="{DynamicResource FP.Bg.Elevated}"
                                            ImageAreaBrush="{DynamicResource FP.Bg.Panel}"
                                            TickBrush="{DynamicResource FP.Border.Strong}"
                                            LabelBrush="{DynamicResource FP.Text.Muted}"
                                            MarkerBrush="{DynamicResource FP.Accent}"
                                            PointerPressed="OnRulerPointerPressed"
                                            PointerMoved="OnRulerPointerMoved"
                                            PointerReleased="OnRulerPointerReleased" />
                        <icons:RulerControl x:Name="LeftRuler"
                                            Grid.Row="1" Grid.Column="0"
                                            Width="18"
                                            IsHorizontal="False"
                                            IsVisible="False"
                                            Cursor="Hand"
                                            RulerBackground="{DynamicResource FP.Bg.Elevated}"
                                            ImageAreaBrush="{DynamicResource FP.Bg.Panel}"
                                            TickBrush="{DynamicResource FP.Border.Strong}"
                                            LabelBrush="{DynamicResource FP.Text.Muted}"
                                            MarkerBrush="{DynamicResource FP.Accent}"
                                            PointerPressed="OnRulerPointerPressed"
                                            PointerMoved="OnRulerPointerMoved"
                                            PointerReleased="OnRulerPointerReleased" />
                    <Canvas x:Name="PreviewCanvas"
                            PointerWheelChanged="OnCanvasWheelZoom"
                            Grid.Row="1" Grid.Column="1"
                            Background="Transparent"
                            ClipToBounds="True"
                            SizeChanged="OnPreviewCanvasSizeChanged"
                            PointerPressed="OnSliderPointerPressed"
                            PointerMoved="OnSliderPointerMoved"
                            PointerReleased="OnSliderPointerReleased"
                            PointerExited="OnPreviewCanvasPointerExited">
                        <Border x:Name="ImageBackgroundBorder"
                                Background="{Binding TransparencyBackgroundBrush}"
                                IsHitTestVisible="False" />
                        <Image x:Name="AfterImageControl"
                               Source="{Binding DisplayImage}"
                               Stretch="Fill"
                               RenderOptions.BitmapInterpolationMode="HighQuality" />
                        <!-- STUFE 3 (Zoom-Detail): hochaufgeloester Viewport-Ausschnitt ueber dem
                             AfterImage, sobald der Zoom die Szenen-Aufloesung uebersteigt. Quelle
                             und Position setzt UpdateZoomDetailOverlay (Code-Behind), damit
                             Ausschnitt und Layout im selben Durchlauf konsistent bleiben. -->
                        <Image x:Name="ZoomDetailImageControl"
                               Stretch="Fill"
                               IsHitTestVisible="False"
                               IsVisible="False"
                               RenderOptions.BitmapInterpolationMode="HighQuality" />
                        <Image x:Name="BeforeImageControl"
                               Source="{Binding BeforeDisplayImage}"
                               Stretch="Fill"
                               RenderOptions.BitmapInterpolationMode="HighQuality" />
                        <!-- Vorher-Seite des Zoom-Details (Original, nur Geometrie): liegt ueber dem
                             BeforeImage und wird wie dieses an der Vergleichslinie geclippt. -->
                        <Image x:Name="ZoomDetailBeforeImageControl"
                               Stretch="Fill"
                               IsHitTestVisible="False"
                               IsVisible="False"
                               RenderOptions.BitmapInterpolationMode="HighQuality" />
                        <Image x:Name="RetouchLivePatchImage"
                               Source="{Binding RetouchLivePatchImage}"
                               Stretch="Fill"
                               IsHitTestVisible="False"
                               IsVisible="{Binding HasRetouchLivePatch}"
                               RenderOptions.BitmapInterpolationMode="HighQuality" />
                        <Border x:Name="ImageFrameBorder"
                                Background="Transparent"
                                BorderBrush="{DynamicResource FP.Border.Strong}"
                                BorderThickness="1"
                                IsHitTestVisible="False" />
                        <!-- Raster und Hilfslinien liegen über dem Bild, aber unter Zuschnitt- und
                             Objekt-Overlay, damit sie deren Anfasspunkte nicht verdecken. -->
                        <icons:PixelGridOverlay x:Name="GridOverlay" IsVisible="False" IsHitTestVisible="False" />
                        <Canvas x:Name="GuideLayer" IsHitTestVisible="False" ClipToBounds="True" />
                        <Border x:Name="SliderDivider"
                                Width="2"
                                Background="{DynamicResource FP.Accent}"
                                Opacity="0.9" />
                        <!-- Unsichtbare, breite Griffzone über der 2-px-Trennlinie: die Linie selbst
                             ist praktisch nicht greifbar (Nutzerwunsch 2026-07-17: Linie ziehen +
                             Größenänderungs-Cursor wie bei den Hilfslinien). -->
                        <Border x:Name="SliderDividerHit"
                                Width="14"
                                Background="Transparent"
                                Cursor="SizeWestEast" />
                        <Border x:Name="SliderHandleCircle"
                                Width="36" Height="36"
                                Background="#F2F2F2"
                                CornerRadius="18"
                                BorderBrush="{DynamicResource FP.Border.Normal}"
                                BorderThickness="1"
                                Cursor="SizeWestEast">
                            <StackPanel Orientation="Horizontal" Spacing="3"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path Width="7" Height="12"
                                      Stretch="Uniform"
                                      Stroke="#1A1A1A"
                                      StrokeThickness="2"
                                      StrokeLineCap="Round"
                                      StrokeJoin="Round"
                                      Data="M 10 0 L 0 10 L 10 20" />
                                <Path Width="7" Height="12"
                                      Stretch="Uniform"
                                      Stroke="#1A1A1A"
                                      StrokeThickness="2"
                                      StrokeLineCap="Round"
                                      StrokeJoin="Round"
                                      Data="M 0 0 L 10 10 L 0 20" />
                            </StackPanel>
                        </Border>
                        <Border x:Name="BeforeLabel" Background="#262933" CornerRadius="6" Padding="10,5">
                            <TextBlock Text="Vorher" FontSize="{DynamicResource FP.Font.Small}" Foreground="White" />
                        </Border>
                        <Border x:Name="AfterLabel" Background="#262933" CornerRadius="6" Padding="10,5">
                            <TextBlock Text="Nachher" FontSize="{DynamicResource FP.Font.Small}" Foreground="White" />
                        </Border>
                        <Border x:Name="CropOverlay"
                                BorderThickness="0"
                                Background="Transparent"
                                Cursor="SizeAll"
                                IsVisible="False">
                            <Grid RowDefinitions="*,*,*" ColumnDefinitions="*,*,*">
                                <Rectangle Grid.RowSpan="3"
                                           Grid.ColumnSpan="3"
                                           Fill="#12008CFF"
                                           Stroke="{DynamicResource FP.Accent}"
                                           StrokeThickness="1.5"
                                           StrokeDashArray="5,3" />
                                <Border Grid.RowSpan="3" Grid.Column="1" Width="1" Background="#CCFFFFFF"
                                        HorizontalAlignment="Left" />
                                <Border Grid.RowSpan="3" Grid.Column="1" Width="1" Background="#CCFFFFFF"
                                        HorizontalAlignment="Right" />
                                <Border Grid.Row="1" Grid.ColumnSpan="3" Height="1" Background="#CCFFFFFF"
                                        VerticalAlignment="Top" />
                                <Border Grid.Row="1" Grid.ColumnSpan="3" Height="1" Background="#CCFFFFFF"
                                        VerticalAlignment="Bottom" />
                                <Border Grid.RowSpan="3" Grid.Column="1" Width="1" Background="#66000000"
                                        HorizontalAlignment="Left" Margin="1,0,0,0" />
                                <Border Grid.RowSpan="3" Grid.Column="1" Width="1" Background="#66000000"
                                        HorizontalAlignment="Right" Margin="0,0,1,0" />
                                <Border Grid.Row="1" Grid.ColumnSpan="3" Height="1" Background="#66000000"
                                        VerticalAlignment="Top" Margin="0,1,0,0" />
                                <Border Grid.Row="1" Grid.ColumnSpan="3" Height="1" Background="#66000000"
                                        VerticalAlignment="Bottom" Margin="0,0,0,1" />
                                <Border Grid.RowSpan="3"
                                        Grid.ColumnSpan="3"
                                        Background="#CC1A1D24"
                                        CornerRadius="4"
                                        Padding="6,3"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Margin="6,6,0,0">
                                    <TextBlock x:Name="CropSizeBadgeText"
                                               Text=""
                                               Foreground="White"
                                               FontSize="{DynamicResource FP.Font.Small}"
                                               FontWeight="SemiBold" />
                                </Border>
                                <Border Width="16" Height="16" CornerRadius="8"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Top"
                                        Margin="-9,-9,0,0" />
                                <Border Grid.Column="1" Width="14" Height="14" CornerRadius="7"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top"
                                        Margin="0,-8,0,0" />
                                <Border Grid.Column="2" Width="16" Height="16" CornerRadius="8"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,-9,-9,0" />
                                <Border Grid.Row="1" Width="14" Height="14" CornerRadius="7"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Center"
                                        Margin="-8,0,0,0" />
                                <Border Grid.Row="1" Grid.Column="2" Width="14" Height="14" CornerRadius="7"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Margin="0,0,-8,0" />
                                <Border Grid.Row="2" Width="16" Height="16" CornerRadius="8"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                        Margin="-9,0,0,-9" />
                                <Border Grid.Row="2" Grid.Column="1" Width="14" Height="14" CornerRadius="7"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                        Margin="0,0,0,-8" />
                                <Border Grid.Row="2" Grid.Column="2" Width="16" Height="16" CornerRadius="8"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        Margin="0,0,-9,-9" />
                            </Grid>
                        </Border>
                        <Image x:Name="SelectionMaskOverlay"
                               Source="{Binding SelectionMaskPreviewImage}"
                               Stretch="Fill"
                               IsHitTestVisible="False"
                               IsVisible="False" />
                        <icons:SelectionOverlayControl x:Name="SelectionOverlay"
                                                       FillBrush="{Binding SelectionFillPreviewBrush}"
                                                       StrokeBrush="{DynamicResource FP.Accent}"
                                                       IsHitTestVisible="False"
                                                       IsVisible="False" />
                        <icons:SelectionOverlayControl x:Name="SelectionDragOverlay"
                                                       FillBrush="#33FFFFFF"
                                                       StrokeBrush="{DynamicResource FP.Accent}"
                                                       IsHitTestVisible="False"
                                                       IsVisible="False" />
                        <Border x:Name="TextOverlay"
                                BorderThickness="0"
                                Background="Transparent"
                                Cursor="SizeAll"
                                IsVisible="False"
                                PointerPressed="OnTextOverlayPointerPressed"
                                PointerMoved="OnTextOverlayPointerMoved"
                                PointerReleased="OnTextOverlayPointerReleased"
                                PointerCaptureLost="OnTextOverlayCaptureLost">
                            <Grid>
                                <Rectangle x:Name="TextOverlayFrame"
                                           Fill="Transparent"
                                           Stroke="{DynamicResource FP.Accent}"
                                           StrokeThickness="1.5"
                                           StrokeDashArray="5,3"
                                           IsHitTestVisible="False" />
                                <Image x:Name="SelectedAnnotationOverlayImage"
                                       Source="{Binding SelectedAnnotationOverlayImage}"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       Stretch="Fill"
                                       IsHitTestVisible="False"
                                       IsVisible="{Binding ShowSelectedSvgOverlay}" />
                                <TextBox x:Name="TextOverlayEditor"
                                         Classes="overlay-editor"
                                         Text="{Binding AnnotationText}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0"
                                         VerticalContentAlignment="Top"
                                         IsHitTestVisible="False"
                                         FocusAdorner="{x:Null}" />
                                <Border x:Name="TextSizeBadge"
                                        IsVisible="False"
                                        IsHitTestVisible="False"
                                        Background="#CC1A1D24"
                                        CornerRadius="4"
                                        Padding="6,3"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Margin="0,-30,0,0">
                                    <TextBlock x:Name="TextSizeBadgeText" Text="" Foreground="White" FontSize="{DynamicResource FP.Font.Small}"
                                               FontWeight="SemiBold" />
                                </Border>
                                <Border Width="1" Height="20" Background="{DynamicResource FP.Accent}"
                                        HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-20,0,0"
                                        IsHitTestVisible="False" />
                                <Border Width="16" Height="16" CornerRadius="8"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top"
                                        Margin="0,-36,0,0" IsHitTestVisible="False"
                                        ToolTip.Tip="Ziehen zum Drehen (Shift = 15°-Schritte)" />
                                <Border Width="14" Height="14" CornerRadius="7"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Top"
                                        Margin="-8,-8,0,0" IsHitTestVisible="False" />
                                <Border Width="12" Height="12" CornerRadius="6"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Top"
                                        Margin="0,-7,0,0" IsHitTestVisible="False" />
                                <Border Width="14" Height="14" CornerRadius="7"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,-8,-8,0" IsHitTestVisible="False" />
                                <Border Width="12" Height="12" CornerRadius="6"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Center"
                                        Margin="-7,0,0,0" IsHitTestVisible="False" />
                                <Border Width="12" Height="12" CornerRadius="6"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Margin="0,0,-7,0" IsHitTestVisible="False" />
                                <Border Width="14" Height="14" CornerRadius="7"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                        Margin="-8,0,0,-8" IsHitTestVisible="False" />
                                <Border Width="12" Height="12" CornerRadius="6"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                        Margin="0,0,0,-7" IsHitTestVisible="False" />
                                <Border Width="14" Height="14" CornerRadius="7"
                                        Background="{DynamicResource FP.Accent}" BorderBrush="White"
                                        BorderThickness="1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                        Margin="0,0,-8,-8" IsHitTestVisible="False" />
                            </Grid>
                        </Border>
                        <Line x:Name="SnapGuideV" IsVisible="False" IsHitTestVisible="False" Stroke="#FFFF3B8D"
                              StrokeThickness="1" StrokeDashArray="4,3" />
                        <Line x:Name="SnapGuideH" IsVisible="False" IsHitTestVisible="False" Stroke="#FFFF3B8D"
                              StrokeThickness="1" StrokeDashArray="4,3" />
                        <Polyline x:Name="BrushPreviewOutlineLine"
                                  IsVisible="False"
                                  IsHitTestVisible="False"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round" />
                        <Polyline x:Name="BrushPreviewLine"
                                  IsVisible="False"
                                  IsHitTestVisible="False"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round" />
                        <Ellipse x:Name="BrushCursorPreview"
                                 IsVisible="False"
                                 IsHitTestVisible="False"
                                 Stroke="{DynamicResource FP.Accent}"
                                 StrokeThickness="1.5" />
                        <!-- Zeigt beim Klonen, von welcher Stelle die Textur kopiert wird. -->
                        <Ellipse x:Name="CloneSourceMarker"
                                 IsVisible="False"
                                 IsHitTestVisible="False"
                                 Stroke="{DynamicResource FP.Accent}"
                                 StrokeThickness="1.5"
                                 StrokeDashArray="3,3" />
                    </Canvas>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="2" Classes="panel-right">
            <Grid RowDefinitions="*">
                <Grid Grid.Row="0">
                    <ScrollViewer HorizontalContentAlignment="Stretch"
                                  VerticalScrollBarVisibility="Auto"
                                  AllowAutoHide="True"
                                  FocusAdorner="{x:Null}"
                                  Margin="0,0,8,0">
                        <StackPanel x:Name="AdjustmentsStackPanel"
                                    Margin="10,2,10,10"
                                    HorizontalAlignment="Stretch">
                            <Border Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowTransformAdjustments}">
                                <panels:TransformPanel />
                            </Border>

                            <!-- DrawPanel bringt seine eigenen adjustment-group-Rahmen mit (Farbe, Pinsel,
                                 Werkzeug getrennt), daher hier kein umschließender Rahmen. -->
                            <panels:DrawPanel IsVisible="{Binding ShowDrawControls}" />

                            <!-- Schatten und Glühen auch für den Pinsel (wie beim Text-Objekt). -->
                            <Border Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding IsBrushPaintMode}">
                                <panels:AnnotationShadowPanel />
                            </Border>

                            <Border Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding IsBrushPaintMode}">
                                <panels:AnnotationGlowPanel />
                            </Border>

                            <Border Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowLayerToolOptions}">
                                <panels:InsertPanel />
                            </Border>

                            <Border Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowSelectionAdjustments}">
                                <panels:SelectionPanel />
                            </Border>

                            <Border Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowCropAdjustments}">
                                <panels:CropPanel />
                            </Border>

                            <panels:ResizePanel Margin="0,7,0,0"
                                                IsVisible="{Binding ShowResizeAdjustments}" />

                            <Border Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowLightAdjustments}">
                                <panels:LightPanel />
                            </Border>

                            <Border Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowColorAdjustments}">
                                <panels:ColorPanel />
                            </Border>

                            <!-- DETAILS (ausklappbar) -->
                            <Border Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowDetailAdjustments}">
                                <panels:DetailsPanel />
                            </Border>

                            <Border Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowDetailAdjustments}">
                                <panels:SharpnessPanel />
                            </Border>

                            <Border Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowDetailAdjustments}">
                                <panels:EffectsPanel />
                            </Border>

                            <Border Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowDetailAdjustments}">
                                <panels:FramePanel />
                            </Border>

                            <Border Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowFilterAdjustments}">
                                <panels:FilterPanel />
                            </Border>

                            <!-- TONWERTKURVE (ausklappbar) -->
                            <Border Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowFilterAdjustments}">
                                <panels:LightroomPresetPanel />
                            </Border>

                            <Border Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowFilterAdjustments}">
                                <panels:LutPresetPanel />
                            </Border>

                            <!-- TONWERTKURVE (ausklappbar) -->
                            <Border Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowLightAdjustments}">
                                <panels:CurvePanel />
                            </Border>

                            <!-- FILMNEGATIV (ausklappbar) - gehört zu "Anpassen": die Umkehr ist eine
                                 Dichteoperation, auf der Belichtung und Kurve erst aufsetzen. -->
                            <Border Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowLightAdjustments}">
                                <panels:FilmNegativePanel />
                            </Border>

                            <!-- COLOR GRADING (ausklappbar) -->
                            <Border Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowColorAdjustments}">
                                <panels:HslPanel />
                            </Border>

                            <Border Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowColorAdjustments}">
                                <panels:SplitToningPanel />
                            </Border>

                            <Border Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowAnnotationProperties}">
                                <panels:AnnotationPropertiesPanel />
                            </Border>

                            <Border Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowAnnotationProperties}">
                                <panels:AnnotationShadowPanel />
                            </Border>

                            <Border Classes="adjustment-group" Margin="0,7,0,0"
                                    IsVisible="{Binding ShowAnnotationProperties}">
                                <panels:AnnotationGlowPanel />
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <views:InfoSidebarView Grid.Row="1" Grid.Column="3" Width="320" />

        <views:LayersPanelView Grid.Row="1" Grid.Column="4" Width="300" />

        <Border Grid.Row="2"
                Grid.ColumnSpan="5"
                Background="{DynamicResource FP.Bg.Dark}"
                BorderBrush="{DynamicResource FP.Border.Subtle}"
                BorderThickness="0,1,0,0"
                Padding="24,8,24,8">
            <Grid RowDefinitions="Auto,28">
                <ListBox Name="FilmstripListBox"
                         Classes="filmstrip-list"
                         Height="110"
                         IsVisible="{Binding ShowFilmstrip}"
                         ItemsSource="{Binding FilmstripItems}"
                         SelectedIndex="{Binding CurrentFilmstripIndex, Mode=OneWay}"
                         SelectionMode="Single"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel Orientation="Horizontal" Margin="0,0,0,8" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ImageItem}">
                            <Border Width="148" Height="100"
                                    Classes="thumb-card"
                                    Classes.selected="{Binding IsSelected}"
                                    ClipToBounds="True"
                                    PointerPressed="OnFilmstripItemPressed">
                                <Border CornerRadius="6" ClipToBounds="True">
                                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                                           RenderOptions.BitmapInterpolationMode="LowQuality" />
                                </Border>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Grid Grid.Row="1" ColumnDefinitions="*,Auto,*" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                        <!-- Farbetikett des Bildes (gleiche Darstellung wie auf der Galerie-Kachel). -->
                        <Ellipse Width="10" Height="10" Fill="{Binding ColorLabelBrush}"
                                 IsVisible="{Binding HasColorLabel}" VerticalAlignment="Center" Margin="0,0,-10,0"/>
                        <TextBlock Text="{Binding CurrentFileName}" FontSize="{DynamicResource FP.Font.Body}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding StatusText}"
                                   Classes="status-text"
                                   Classes.failed="{Binding PreviewFailed}"
                                   FontSize="{DynamicResource FP.Font.Body}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding PositionText}" Foreground="{DynamicResource FP.Text.Secondary}"
                                   FontSize="{DynamicResource FP.Font.Body}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <Button Classes="ghost" Height="20" Padding="4,0,4,2" VerticalContentAlignment="Center"
                                Focusable="False"
                                Click="OnZoomOutClick" ToolTip.Tip="Verkleinern">
                            <TextBlock Text="−" FontSize="{DynamicResource FP.Glyph.Large}" Foreground="{DynamicResource FP.Text.Secondary}" VerticalAlignment="Center" />
                        </Button>
                        <icons:RoundSlider Name="EditorZoomSlider" Width="110" Height="26" MinHeight="0" Minimum="0" Maximum="100"
                                           VerticalAlignment="Center" />
                        <Button Classes="ghost" Height="20" Padding="4,0,4,2" VerticalContentAlignment="Center"
                                Focusable="False"
                                Click="OnZoomInClick" ToolTip.Tip="Vergrößern">
                            <TextBlock Text="+" FontSize="{DynamicResource FP.Glyph.Large}" Foreground="{DynamicResource FP.Text.Secondary}" VerticalAlignment="Center" />
                        </Button>
                        <Button Classes="ghost" Height="26" Padding="8,2" Margin="12,0,0,0" Focusable="False"
                                Classes.active="{Binding IsZoomActualActive}"
                                Click="OnZoomActualClick" ToolTip.Tip="Auf 100 Prozent springen">
                            <TextBlock Name="ZoomPercentText" Text="100%" Foreground="{DynamicResource FP.Text.Primary}"
                                       VerticalAlignment="Center" />
                        </Button>
                        <Button Classes="ghost" Height="26" Padding="8,2" Margin="8,0,0,0" Focusable="False"
                                Classes.active="{Binding IsZoomFitActive}"
                                Click="OnZoomFitClick"
                                ToolTip.Tip="Bild vollständig in die Vorschau einpassen">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/aspect-ratio.svg"
                                               Width="20" Height="20" />
                                <TextBlock Text="Einpassen" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding MousePositionText}"
                                       IsVisible="{Binding MousePositionText, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}}"
                                       Foreground="{DynamicResource FP.Text.Muted}" FontSize="{DynamicResource FP.Font.Body}"
                                       VerticalAlignment="Center" Margin="0,0,20,0" />
                            <Button Classes="star-btn" Background="Transparent" BorderThickness="0" Padding="2,0,2,2" VerticalAlignment="Center" 
                                    Classes.active="{Binding Rating, Converter={StaticResource RatingThresholdConverter}, ConverterParameter=1}"
                                    Command="{Binding SetRatingCommand}" CommandParameter="1">
                                <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/star.svg"
                                               Classes="rating-star"
                                               Width="18" Height="18"
                                               VerticalAlignment="Center" />
                            </Button>
                            <Button Classes="star-btn" Background="Transparent" BorderThickness="0" Padding="2,0,2,2" VerticalAlignment="Center"
                                    Classes.active="{Binding Rating, Converter={StaticResource RatingThresholdConverter}, ConverterParameter=2}"
                                    Command="{Binding SetRatingCommand}" CommandParameter="2">
                                <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/star.svg"
                                               Classes="rating-star"
                                               Width="18" Height="18"
                                               VerticalAlignment="Center" />
                            </Button>
                            <Button Classes="star-btn" Background="Transparent" BorderThickness="0" Padding="2,0,2,2" VerticalAlignment="Center"
                                    Classes.active="{Binding Rating, Converter={StaticResource RatingThresholdConverter}, ConverterParameter=3}"
                                    Command="{Binding SetRatingCommand}" CommandParameter="3">
                                <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/star.svg"
                                               Classes="rating-star"
                                               Width="18" Height="18"
                                               VerticalAlignment="Center" />
                            </Button>
                            <Button Classes="star-btn" Background="Transparent" BorderThickness="0" Padding="2,0,2,2" VerticalAlignment="Center"
                                    Classes.active="{Binding Rating, Converter={StaticResource RatingThresholdConverter}, ConverterParameter=4}"
                                    Command="{Binding SetRatingCommand}" CommandParameter="4">
                                <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/star.svg"
                                               Classes="rating-star"
                                               Width="18" Height="18"
                                               VerticalAlignment="Center" />
                            </Button>
                            <Button Classes="star-btn" Background="Transparent" BorderThickness="0" Padding="2,0,2,2" VerticalAlignment="Center"
                                    Classes.active="{Binding Rating, Converter={StaticResource RatingThresholdConverter}, ConverterParameter=5}"
                                    Command="{Binding SetRatingCommand}" CommandParameter="5">
                                <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/star.svg"
                                               Classes="rating-star"
                                               Width="18" Height="18"
                                               VerticalAlignment="Center" />
                            </Button>
                            <Button Classes="icon-btn"
                                    Width="24" Height="24" VerticalAlignment="Center"
                                    Command="{Binding ToggleFavoriteCommand}"
                                    ToolTip.Tip="Favorit" Margin="6,0,0,0">
                                <Grid Width="20" Height="20">
                                    <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/heart.svg"
                                                   Width="20" Height="20"
                                                   Classes="fav-heart"
                                                   IsVisible="{Binding !IsFavorite}" />
                                    <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/heart.svg"
                                                   Width="20" Height="20"
                                                   Classes="fav-heart active"
                                                   IsVisible="{Binding IsFavorite}" />
                                </Grid>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Schnellvorschau-Overlay (Mausrad-Klick auf Filmstrip) -->
        <Panel Name="FilmstripPreviewOverlay"
               Grid.RowSpan="3" Grid.ColumnSpan="4"
               IsVisible="False"
               Background="#D9000000"
               ZIndex="100">
            <Image Name="FilmstripPreviewImage"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="60" />
        </Panel>

    </Grid>
</UserControl>
