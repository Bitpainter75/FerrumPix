<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FerrumPix.Views.BatchRenameDialogView">

    <Grid RowDefinitions="Auto,*"
          RowSpacing="14">
        <Grid ColumnDefinitions="*,110,110"
              ColumnSpacing="12">
            <StackPanel Spacing="7">
                <TextBlock Text="Namensvorlage"
                           Foreground="{DynamicResource FP.Text.Secondary}"
                           FontSize="{DynamicResource FP.Font.Body}"/>
                <TextBox Name="PatternTextBox"
                         Text="{Binding DialogBatchRenamePattern, Mode=TwoWay}"
                         MinHeight="36"/>
                <!-- Platzhalter als Klick-Auswahl statt Hilfetext (Nutzerwunsch 2026-07-17):
                     ein Klick fügt den Platzhalter an der Cursorposition der Vorlage ein. -->
                <WrapPanel Name="PlaceholderChips" ItemSpacing="4" LineSpacing="4">
                    <Button Classes="ghost" Padding="8,3" Content="###" Tag="###" Click="OnInsertPlaceholder" ToolTip.Tip="Laufende Nummer (Stellen = Anzahl #)"/>
                    <Button Classes="ghost" Padding="8,3" Content="{}{name}" Tag="{}{name}" Click="OnInsertPlaceholder" ToolTip.Tip="Ursprünglicher Dateiname"/>
                    <Button Classes="ghost" Padding="8,3" Content="{}{date:yyyyMMdd}" Tag="{}{date:yyyyMMdd}" Click="OnInsertPlaceholder" ToolTip.Tip="Dateidatum"/>
                    <Button Classes="ghost" Padding="8,3" Content="{}{datetaken:yyyyMMdd}" Tag="{}{datetaken:yyyyMMdd}" Click="OnInsertPlaceholder" ToolTip.Tip="Aufnahmedatum (EXIF)"/>
                    <Button Classes="ghost" Padding="8,3" Content="{}{width}" Tag="{}{width}" Click="OnInsertPlaceholder" ToolTip.Tip="Bildbreite in Pixeln"/>
                    <Button Classes="ghost" Padding="8,3" Content="{}{height}" Tag="{}{height}" Click="OnInsertPlaceholder" ToolTip.Tip="Bildhöhe in Pixeln"/>
                    <Button Classes="ghost" Padding="8,3" Content="{}{camera}" Tag="{}{camera}" Click="OnInsertPlaceholder" ToolTip.Tip="Kameramodell (EXIF)"/>
                    <Button Classes="ghost" Padding="8,3" Content="{}{iso}" Tag="{}{iso}" Click="OnInsertPlaceholder" ToolTip.Tip="ISO-Wert (EXIF)"/>
                    <Button Classes="ghost" Padding="8,3" Content="{}{aperture}" Tag="{}{aperture}" Click="OnInsertPlaceholder" ToolTip.Tip="Blende (EXIF)"/>
                    <Button Classes="ghost" Padding="8,3" Content="{}{focal}" Tag="{}{focal}" Click="OnInsertPlaceholder" ToolTip.Tip="Brennweite (EXIF)"/>
                </WrapPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="7">
                <TextBlock Text="Startwert"
                           Foreground="{DynamicResource FP.Text.Secondary}"
                           FontSize="{DynamicResource FP.Font.Body}"/>
                <NumericUpDown Classes="combo-like"
                               Value="{Binding DialogBatchRenameStart, Mode=TwoWay}"
                               Minimum="0"
                               Maximum="999999"
                               Increment="1"
                               MinHeight="36"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="7">
                <TextBlock Text="Schrittweite"
                           Foreground="{DynamicResource FP.Text.Secondary}"
                           FontSize="{DynamicResource FP.Font.Body}"/>
                <NumericUpDown Classes="combo-like"
                               Value="{Binding DialogBatchRenameStep, Mode=TwoWay}"
                               Minimum="1"
                               Maximum="999999"
                               Increment="1"
                               MinHeight="36"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Background="{DynamicResource FP.Bg.Content}"
                BorderBrush="{DynamicResource FP.Border.Normal}"
                BorderThickness="1"
                CornerRadius="7"
                Padding="0"
                MinHeight="260"
                MaxHeight="360">
            <Grid RowDefinitions="36,*">
                <Grid ColumnDefinitions="*,*"
                      Background="{DynamicResource FP.Bg.Input}"
                      ColumnSpacing="10">
                    <TextBlock Text="Alter Name" VerticalAlignment="Center" FontWeight="SemiBold" Margin="12,0,0,0"/>
                    <TextBlock Grid.Column="1" Text="Neuer Name" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </Grid>
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding DialogBatchRenamePreview}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource FP.Border.Normal}"
                                        BorderThickness="0,0,0,1"
                                        Padding="12,8"
                                        ToolTip.Tip="{Binding StatusText}">
                                    <Grid ColumnDefinitions="*,*"
                                          ColumnSpacing="10">
                                        <TextBlock Text="{Binding OldName}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding NewName}" TextTrimming="CharacterEllipsis"
                                                   IsVisible="{Binding !HasProblem}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding NewName}" TextTrimming="CharacterEllipsis"
                                                   Foreground="IndianRed"
                                                   IsVisible="{Binding HasProblem}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
