<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:FerrumPix.Controls"
             xmlns:services="clr-namespace:FerrumPix.Services"
             x:Class="FerrumPix.Views.InfoSidebarView">

    <!-- Gemeinsame Info-Seitenleiste (Allgemein/EXIF/IPTC/XMP) für Viewer und Editor - beide
         ViewModels exponieren dieselben Property-/Command-Namen (ExifInfo, Tags, HistogramImage,
         IsInfoTab*, ToggleFavoriteCommand, SetRatingCommand, SetColorLabelCommand, AddTagCommand,
         RemoveTagCommand, Rating, IsFavorite, ColorLabel/IsColorLabel*, IsInfoSidebarVisible),
         daher genügt ein einziges, DataContext-loses UserControl statt der zuvor doppelt
         gepflegten Markup-Kopie in ViewerView/EditorView. -->
    <Border x:Name="InfoSidebarBorder" Classes="panel-right" Padding="14,14"
            IsVisible="{Binding IsInfoSidebarVisible}">
        <Grid RowDefinitions="Auto,*" RowSpacing="14">
            <StackPanel Spacing="0">
                <TextBlock Text="Info" FontSize="{DynamicResource FP.Font.Title}" FontWeight="SemiBold"/>
                <!-- Spacing knapper als sonst: fünf Reiter müssen in die 320px breite Seitenleiste passen,
                     auch bei längeren Übersetzungen von "Allgemein". -->
                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,14,0,0">
                    <Button Classes="info-tab" Command="{Binding SetInfoTabCommand}" CommandParameter="General" Classes.active="{Binding IsInfoTabGeneral}">
                        <TextBlock Text="Allgemein"/>
                    </Button>
                    <Button Classes="info-tab" Command="{Binding SetInfoTabCommand}" CommandParameter="Exif" Classes.active="{Binding IsInfoTabExif}">
                        <TextBlock Text="EXIF"/>
                    </Button>
                    <Button Classes="info-tab" Command="{Binding SetInfoTabCommand}" CommandParameter="Iptc" Classes.active="{Binding IsInfoTabIptc}">
                        <TextBlock Text="IPTC"/>
                    </Button>
                    <Button Classes="info-tab" Command="{Binding SetInfoTabCommand}" CommandParameter="Xmp" Classes.active="{Binding IsInfoTabXmp}">
                        <TextBlock Text="XMP"/>
                    </Button>
                    <Button Classes="info-tab" Command="{Binding SetInfoTabCommand}" CommandParameter="Icc" Classes.active="{Binding IsInfoTabIcc}">
                        <TextBlock Text="ICC"/>
                    </Button>
                </StackPanel>
                <Border Height="1" Background="{DynamicResource FP.Border.Normal}" Margin="0,7,0,0"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" FocusAdorner="{x:Null}">
                <StackPanel Spacing="18">
                    <StackPanel Spacing="18" IsVisible="{Binding IsInfoTabGeneral}" Margin="0,0,12,0">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Bild" FontSize="{DynamicResource FP.Font.Subtitle}" FontWeight="SemiBold"/>
                            <!-- Dateiname ohne Beschriftung über die volle Breite: er ist die
                                 Überschrift des Blocks, keine Wertzeile - und lange Namen haben so
                                 die ganze Spaltenbreite zum Umbrechen statt der halben. Darunter
                                 eine Leerzeile Abstand zu den Wertzeilen. -->
                            <TextBlock Text="{Binding ExifInfo.FileName}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10">
                                <TextBlock Text="Abmessungen" Foreground="{DynamicResource FP.Text.Muted}"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding ExifInfo.ImageWidth}"/>
                                    <TextBlock Text="x" Foreground="{DynamicResource FP.Text.Secondary}"/>
                                    <TextBlock Text="{Binding ExifInfo.ImageHeight}"/>
                                </StackPanel>
                                <TextBlock Grid.Row="1" Text="Megapixel" Foreground="{DynamicResource FP.Text.Muted}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ExifInfo.Megapixels}" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Row="2" Text="Seitenverhältnis" Foreground="{DynamicResource FP.Text.Muted}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ExifInfo.AspectRatio}" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Row="3" Text="Farbraum" Foreground="{DynamicResource FP.Text.Muted}"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ExifInfo.ColorSpace}" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Row="4" Text="Dateigröße" Foreground="{DynamicResource FP.Text.Muted}"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ExifInfo.FileSize}" HorizontalAlignment="Right"/>
                                <!-- Dateidatum, nicht EXIF-Aufnahmedatum. Beide Zeilen blenden sich aus,
                                     wo es keinen Zeitstempel gibt (Immich, Dateisystem ohne Geburtszeit). -->
                                <TextBlock Grid.Row="5" Text="Erstellt" Foreground="{DynamicResource FP.Text.Muted}"
                                           IsVisible="{Binding ExifInfo.FileCreated, Converter={StaticResource StringNotEmptyToBoolConverter}}"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" HorizontalAlignment="Right"
                                           Text="{Binding ExifInfo.FileCreated, Converter={StaticResource ExifDateConverter}}"
                                           IsVisible="{Binding ExifInfo.FileCreated, Converter={StaticResource StringNotEmptyToBoolConverter}}"/>
                                <TextBlock Grid.Row="6" Text="Geändert" Foreground="{DynamicResource FP.Text.Muted}"
                                           IsVisible="{Binding ExifInfo.FileModified, Converter={StaticResource StringNotEmptyToBoolConverter}}"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" HorizontalAlignment="Right"
                                           Text="{Binding ExifInfo.FileModified, Converter={StaticResource ExifDateConverter}}"
                                           IsVisible="{Binding ExifInfo.FileModified, Converter={StaticResource StringNotEmptyToBoolConverter}}"/>
                            </Grid>
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource FP.Border.Normal}"/>

                        <StackPanel Spacing="10">
                            <TextBlock Text="Histogramm" FontSize="{DynamicResource FP.Font.Subtitle}" FontWeight="SemiBold"/>
                            <Border Height="92" Background="{DynamicResource FP.Bg.Input}" CornerRadius="6" ClipToBounds="True">
                                <Image Source="{Binding HistogramImage}"
                                       Stretch="Fill"
                                       RenderOptions.BitmapInterpolationMode="LowQuality"/>
                            </Border>
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource FP.Border.Normal}"/>

                        <!-- Bewertung, Favorit und Farbetikett direkt am Bild pflegen - dieselben
                             Sterne wie in der Werkzeugleiste, dieselben Akzentfarben-Punkte wie im
                             Galerie-Kontextmenü (gleiche Farbe erneut = Etikett entfernen). -->
                        <StackPanel Spacing="10">
                            <TextBlock Text="Bewertung &amp; Etikett" FontSize="{DynamicResource FP.Font.Subtitle}" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" Spacing="1">
                                <Button Classes="star-btn" Background="Transparent" BorderThickness="0" Padding="2,0,2,2" VerticalAlignment="Center"
                                        Classes.active="{Binding Rating, Converter={StaticResource RatingThresholdConverter}, ConverterParameter=1}"
                                        Command="{Binding SetRatingCommand}" CommandParameter="1">
                                    <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/star.svg" Classes="rating-star"
                                                   Width="18" Height="18" VerticalAlignment="Center"/>
                                </Button>
                                <Button Classes="star-btn" Background="Transparent" BorderThickness="0" Padding="2,0,2,2" VerticalAlignment="Center"
                                        Classes.active="{Binding Rating, Converter={StaticResource RatingThresholdConverter}, ConverterParameter=2}"
                                        Command="{Binding SetRatingCommand}" CommandParameter="2">
                                    <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/star.svg" Classes="rating-star"
                                                   Width="18" Height="18" VerticalAlignment="Center"/>
                                </Button>
                                <Button Classes="star-btn" Background="Transparent" BorderThickness="0" Padding="2,0,2,2" VerticalAlignment="Center"
                                        Classes.active="{Binding Rating, Converter={StaticResource RatingThresholdConverter}, ConverterParameter=3}"
                                        Command="{Binding SetRatingCommand}" CommandParameter="3">
                                    <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/star.svg" Classes="rating-star"
                                                   Width="18" Height="18" VerticalAlignment="Center"/>
                                </Button>
                                <Button Classes="star-btn" Background="Transparent" BorderThickness="0" Padding="2,0,2,2" VerticalAlignment="Center"
                                        Classes.active="{Binding Rating, Converter={StaticResource RatingThresholdConverter}, ConverterParameter=4}"
                                        Command="{Binding SetRatingCommand}" CommandParameter="4">
                                    <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/star.svg" Classes="rating-star"
                                                   Width="18" Height="18" VerticalAlignment="Center"/>
                                </Button>
                                <Button Classes="star-btn" Background="Transparent" BorderThickness="0" Padding="2,0,2,2" VerticalAlignment="Center"
                                        Classes.active="{Binding Rating, Converter={StaticResource RatingThresholdConverter}, ConverterParameter=5}"
                                        Command="{Binding SetRatingCommand}" CommandParameter="5">
                                    <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/star.svg" Classes="rating-star"
                                                   Width="18" Height="18" VerticalAlignment="Center"/>
                                </Button>
                                <Button Classes="icon-btn" Width="24" Height="24" VerticalAlignment="Center"
                                        Command="{Binding ToggleFavoriteCommand}" ToolTip.Tip="Favorit" Margin="8,0,0,0">
                                    <Grid Width="20" Height="20">
                                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/heart.svg"
                                                       Width="20" Height="20" Classes="fav-heart" IsVisible="{Binding !IsFavorite}"/>
                                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/heart.svg"
                                                       Width="20" Height="20" Classes="fav-heart active" IsVisible="{Binding IsFavorite}"/>
                                    </Grid>
                                </Button>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Button Classes="ghost" Width="24" Height="24" Padding="0" CornerRadius="12"
                                        Command="{Binding SetColorLabelCommand}" CommandParameter="#F08A1A" ToolTip.Tip="Orange">
                                    <Grid>
                                        <Ellipse Width="16" Height="16" Fill="#F08A1A"/>
                                        <TextBlock Text="✓" IsVisible="{Binding IsColorLabelOrange}" Foreground="White"
                                                   FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                                <Button Classes="ghost" Width="24" Height="24" Padding="0" CornerRadius="12"
                                        Command="{Binding SetColorLabelCommand}" CommandParameter="#E74C3C" ToolTip.Tip="Rot">
                                    <Grid>
                                        <Ellipse Width="16" Height="16" Fill="#E74C3C"/>
                                        <TextBlock Text="✓" IsVisible="{Binding IsColorLabelRed}" Foreground="White"
                                                   FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                                <Button Classes="ghost" Width="24" Height="24" Padding="0" CornerRadius="12"
                                        Command="{Binding SetColorLabelCommand}" CommandParameter="#F03B88" ToolTip.Tip="Pink">
                                    <Grid>
                                        <Ellipse Width="16" Height="16" Fill="#F03B88"/>
                                        <TextBlock Text="✓" IsVisible="{Binding IsColorLabelPink}" Foreground="White"
                                                   FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                                <Button Classes="ghost" Width="24" Height="24" Padding="0" CornerRadius="12"
                                        Command="{Binding SetColorLabelCommand}" CommandParameter="#8B5CF6" ToolTip.Tip="Lila">
                                    <Grid>
                                        <Ellipse Width="16" Height="16" Fill="#8B5CF6"/>
                                        <TextBlock Text="✓" IsVisible="{Binding IsColorLabelPurple}" Foreground="White"
                                                   FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                                <Button Classes="ghost" Width="24" Height="24" Padding="0" CornerRadius="12"
                                        Command="{Binding SetColorLabelCommand}" CommandParameter="#3B82F6" ToolTip.Tip="Blau">
                                    <Grid>
                                        <Ellipse Width="16" Height="16" Fill="#3B82F6"/>
                                        <TextBlock Text="✓" IsVisible="{Binding IsColorLabelBlue}" Foreground="White"
                                                   FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                                <Button Classes="ghost" Width="24" Height="24" Padding="0" CornerRadius="12"
                                        Command="{Binding SetColorLabelCommand}" CommandParameter="#0891B2" ToolTip.Tip="Cyan">
                                    <Grid>
                                        <Ellipse Width="16" Height="16" Fill="#0891B2"/>
                                        <TextBlock Text="✓" IsVisible="{Binding IsColorLabelCyan}" Foreground="White"
                                                   FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                                <Button Classes="ghost" Width="24" Height="24" Padding="0" CornerRadius="12"
                                        Command="{Binding SetColorLabelCommand}" CommandParameter="#0F766E" ToolTip.Tip="Türkis">
                                    <Grid>
                                        <Ellipse Width="16" Height="16" Fill="#0F766E"/>
                                        <TextBlock Text="✓" IsVisible="{Binding IsColorLabelTeal}" Foreground="White"
                                                   FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                                <Button Classes="ghost" Width="24" Height="24" Padding="0" CornerRadius="12"
                                        Command="{Binding SetColorLabelCommand}" CommandParameter="#22C55E" ToolTip.Tip="Grün">
                                    <Grid>
                                        <Ellipse Width="16" Height="16" Fill="#22C55E"/>
                                        <TextBlock Text="✓" IsVisible="{Binding IsColorLabelGreen}" Foreground="White"
                                                   FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                                <Button Classes="ghost" Width="24" Height="24" Padding="0" CornerRadius="12"
                                        Command="{Binding SetColorLabelCommand}" CommandParameter="#FACC15" ToolTip.Tip="Gelb">
                                    <Grid>
                                        <Ellipse Width="16" Height="16" Fill="#FACC15"/>
                                        <TextBlock Text="✓" IsVisible="{Binding IsColorLabelYellow}" Foreground="Black"
                                                   FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                                <Button Classes="ghost" Width="24" Height="24" Padding="0" CornerRadius="12"
                                        Command="{Binding SetColorLabelCommand}" CommandParameter="" ToolTip.Tip="Kein Etikett">
                                    <TextBlock Text="×" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{DynamicResource FP.Text.Secondary}"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource FP.Border.Normal}"/>

                        <StackPanel Spacing="10">
                            <TextBlock Text="Stichwörter" FontSize="{DynamicResource FP.Font.Subtitle}" FontWeight="SemiBold"/>
                            <ItemsControl ItemsSource="{Binding Tags}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Classes="metric-pill" Margin="0,0,6,6">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding}"
                                                           Foreground="{DynamicResource FP.Text.Secondary}"
                                                           VerticalAlignment="Center" FontSize="{DynamicResource FP.Font.Small}"/>
                                                <Button Background="Transparent" BorderThickness="0" Padding="0"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding DataContext.RemoveTagCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="×" FontSize="{DynamicResource FP.Glyph.Medium}"
                                                               Foreground="{DynamicResource FP.Text.Muted}"/>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid ColumnDefinitions="*,Auto">
                                <AutoCompleteBox Text="{Binding NewTagText, Mode=TwoWay}"
                                                 ItemsSource="{Binding TagSuggestions}"
                                                 PlaceholderText="Stichwort hinzufügen…"
                                                 FilterMode="Contains"
                                                 MinimumPrefixLength="0"
                                                 FontSize="{DynamicResource FP.Font.Small}"
                                                 Padding="8,5"/>
                                <Button Grid.Column="1" Classes="ghost" Padding="10,5" Margin="6,0,0,0"
                                        Command="{Binding AddTagCommand}">
                                    <TextBlock Text="+ Hinzufügen" FontSize="{DynamicResource FP.Font.Small}"/>
                                </Button>
                            </Grid>
                        </StackPanel>

                    </StackPanel>

                    <StackPanel Spacing="10" IsVisible="{Binding IsInfoTabExif}" Margin="0,0,12,0">
                        <TextBlock Text="EXIF" FontSize="{DynamicResource FP.Font.Subtitle}" FontWeight="SemiBold"/>
                        <ItemsControl ItemsSource="{Binding ExifInfo.ExifTags}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type services:ExifTag}">
                                    <Border BorderBrush="{DynamicResource FP.Border.Normal}" BorderThickness="0,0,0,1" Padding="0,8">
                                        <Grid ColumnDefinitions="170,*">
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource FP.Text.Muted}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Spacing="10" IsVisible="{Binding IsInfoTabIptc}" Margin="0,0,12,0">
                        <TextBlock Text="IPTC" FontSize="{DynamicResource FP.Font.Subtitle}" FontWeight="SemiBold"/>
                        <ItemsControl ItemsSource="{Binding ExifInfo.IptcTags}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type services:ExifTag}">
                                    <Border BorderBrush="{DynamicResource FP.Border.Normal}" BorderThickness="0,0,0,1" Padding="0,8">
                                        <Grid ColumnDefinitions="170,*">
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource FP.Text.Muted}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Spacing="10" IsVisible="{Binding IsInfoTabXmp}" Margin="0,0,12,0">
                        <TextBlock Text="XMP" FontSize="{DynamicResource FP.Font.Subtitle}" FontWeight="SemiBold"/>
                        <ItemsControl ItemsSource="{Binding ExifInfo.XmpTags}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type services:ExifTag}">
                                    <Border BorderBrush="{DynamicResource FP.Border.Normal}" BorderThickness="0,0,0,1" Padding="0,8">
                                        <Grid ColumnDefinitions="170,*">
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource FP.Text.Muted}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Spacing="10" IsVisible="{Binding IsInfoTabIcc}" Margin="0,0,12,0">
                        <TextBlock Text="ICC-Farbprofil" FontSize="{DynamicResource FP.Font.Subtitle}" FontWeight="SemiBold"/>
                        <ItemsControl ItemsSource="{Binding ExifInfo.IccTags}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type services:ExifTag}">
                                    <Border BorderBrush="{DynamicResource FP.Border.Normal}" BorderThickness="0,0,0,1" Padding="0,8">
                                        <Grid ColumnDefinitions="170,*">
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource FP.Text.Muted}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
