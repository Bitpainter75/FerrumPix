<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:FerrumPix.Controls"
             xmlns:views="clr-namespace:FerrumPix.Views"
             x:Class="FerrumPix.Views.DialogOverlayView">

    <Border Background="#B8000000"
            IsVisible="{Binding IsDialogOpen}"
            ZIndex="500">
        <Border Width="{Binding DialogUsesWideLayout, Converter={StaticResource BoolToWidthConverter}, ConverterParameter='820|440'}"
                MaxWidth="820"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource FP.Bg.Panel}"
                BorderBrush="{DynamicResource FP.Border.Strong}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="22">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                <TextBlock Text="{Binding DialogTitle}"
                           FontSize="{DynamicResource FP.Font.Heading}"
                           FontWeight="SemiBold"/>
                <TextBlock Grid.Row="1"
                           Text="{Binding DialogMessage}"
                           Foreground="{DynamicResource FP.Text.Secondary}"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"
                           LineHeight="18"/>

                <views:FileConflictDialogView Grid.Row="2"
                                              Margin="0,18,0,0"
                                              IsVisible="{Binding DialogShowsFileConflict}"/>

                <!-- Einfache Texteingabe -->
                <TextBox x:Name="DialogInputBox"
                         Grid.Row="2"
                         Text="{Binding DialogInputText, Mode=TwoWay}"
                         IsVisible="{Binding DialogShowsInput}"
                         Margin="0,18,0,0"
                         MinHeight="36"/>

                <views:SearchDialogView Grid.Row="3"
                                        Margin="0,16,0,0"
                                        IsVisible="{Binding DialogShowsSearch}"/>

                <views:BatchResizeDialogView x:Name="BatchResizeDialog"
                                             Grid.Row="3"
                                             Margin="0,16,0,0"
                                             IsVisible="{Binding DialogShowsBatchResize}"/>

                <StackPanel Grid.Row="3"
                            Margin="0,16,0,0"
                            Spacing="8"
                            IsVisible="{Binding DialogShowsWatermarkPreset}">
                    <TextBlock Text="Wasserzeichen"
                               Foreground="{DynamicResource FP.Text.Secondary}"/>
                    <ComboBox ItemsSource="{Binding DialogWatermarkPresetNames}"
                              SelectedItem="{Binding DialogSelectedWatermarkPresetName, Mode=TwoWay}"
                              MinHeight="36"
                              HorizontalAlignment="Stretch"/>
                </StackPanel>

                <!-- Speichern unter -->
                <StackPanel Grid.Row="3"
                            Spacing="14"
                            Margin="0,14,0,0"
                            IsVisible="{Binding DialogShowsSaveAsOptions}">
                    <Grid ColumnDefinitions="Auto,*"
                          RowDefinitions="Auto,Auto,Auto,Auto"
                          ColumnSpacing="14"
                          RowSpacing="12">
                        <TextBlock Text="Format"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource FP.Text.Secondary}"/>
                        <Button Grid.Column="1"
                                Classes="dropdown-btn"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch">
                            <Button.Flyout>
                                <Flyout Placement="BottomEdgeAlignedLeft" VerticalOffset="2">
                                    <ItemsControl ItemsSource="{Binding DialogFormatOptions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Classes="dropdown-item"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Stretch"
                                                        Click="OnDialogFormatOptionClick">
                                                    <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Flyout>
                            </Button.Flyout>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="{Binding DialogSelectedFormat}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <icons:SvgIcon Grid.Column="1"
                                               Source="avares://FerrumPix/Assets/Icons/outline/chevron-down.svg"
                                               Width="14"
                                               Height="14"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <TextBlock Grid.Row="1"
                                   Text="JPG-Qualität"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource FP.Text.Secondary}"
                                   IsVisible="{Binding IsDialogJpgQualityVisible}"/>
                        <Grid Grid.Row="1"
                              Grid.Column="1"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="12"
                              IsVisible="{Binding IsDialogJpgQualityVisible}">
                            <icons:RoundSlider Minimum="1"
                                               Maximum="100"
                                               Value="{Binding DialogJpgQuality, Mode=TwoWay}"
                                               VerticalAlignment="Center"
                                               Height="28"
                                               MinHeight="0"
                                               Width="220"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding DialogJpgQuality, StringFormat={}{0}%}"
                                       MinWidth="42"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource FP.Text.Secondary}"/>
                        </Grid>

                        <TextBlock Grid.Row="2" Text="Ziel"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding IsSaveAsImmichAvailable}"
                                   Foreground="{DynamicResource FP.Text.Secondary}"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                    IsVisible="{Binding IsSaveAsImmichAvailable}">
                            <Button Classes="segmented"
                                    Classes.active="{Binding IsSaveAsTargetLocal}"
                                    Click="OnDialogSaveTargetClick"
                                    Tag="Local">Ordner</Button>
                            <Button Classes="segmented"
                                    Classes.active="{Binding IsSaveAsTargetImmich}"
                                    Click="OnDialogSaveTargetClick"
                                    Tag="Immich">Immich</Button>
                        </StackPanel>

                        <TextBlock Grid.Row="3"
                                   Text="Zielordner"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding IsSaveAsTargetFolderVisible}"
                                   Foreground="{DynamicResource FP.Text.Secondary}"/>
                        <Grid Grid.Row="3"
                              Grid.Column="1"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="8"
                              IsVisible="{Binding IsSaveAsTargetFolderVisible}">
                            <TextBox Text="{Binding DialogSaveAsTargetFolder, Mode=TwoWay}"
                                     MinHeight="36"/>
                            <Button Grid.Column="1"
                                    Classes="icon-btn"
                                    Width="38"
                                    Height="36"
                                    Click="OnBrowseSaveTargetFolderClick"
                                    ToolTip.Tip="Ordner wählen">
                                <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/folder-open.svg"
                                               Width="18"
                                               Height="18"/>
                            </Button>
                        </Grid>
                    </Grid>
                </StackPanel>

                <views:BatchRenameDialogView Grid.Row="3"
                                             Margin="0,16,0,0"
                                             IsVisible="{Binding DialogShowsBatchRename}"/>

                <!-- Aktionsbuttons -->
                <StackPanel Grid.Row="5"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="10"
                            Margin="0,22,0,0"
                            IsVisible="{Binding DialogShowsStandardActions}">
                    <Button Classes="ghost"
                            Command="{Binding DialogCancelCommand}"
                            IsVisible="{Binding IsDialogCancelVisible}">
                        <TextBlock Text="{Binding DialogCancelText}"/>
                    </Button>
                    <Button Classes="accent"
                            Command="{Binding DialogConfirmCommand}">
                        <TextBlock Text="{Binding DialogConfirmText}"/>
                    </Button>
                </StackPanel>

                <Grid Grid.Row="5"
                      ColumnDefinitions="Auto,*,Auto"
                      Margin="0,22,0,0"
                      IsVisible="{Binding DialogShowsFileConflict}">
                    <StackPanel Orientation="Horizontal"
                                Spacing="10"
                                HorizontalAlignment="Left">
                        <Button Classes="ghost"
                                Command="{Binding DialogSkipAllCommand}">
                            <TextBlock Text="Alle überspringen"/>
                        </Button>
                        <Button Classes="ghost"
                                Command="{Binding DialogOverwriteAllCommand}">
                            <TextBlock Text="Alle überschreiben"/>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="10"
                                HorizontalAlignment="Right">
                        <Button Classes="ghost"
                                Command="{Binding DialogRenameCommand}">
                            <TextBlock Text="Umbenennen"/>
                        </Button>
                        <Button Classes="ghost"
                                Command="{Binding DialogSkipCommand}">
                            <TextBlock Text="Überspringen"/>
                        </Button>
                        <Button Classes="accent"
                                Command="{Binding DialogConfirmCommand}">
                            <TextBlock Text="{Binding DialogConfirmText}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Border>

</UserControl>
