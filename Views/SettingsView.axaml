<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="clr-namespace:FerrumPix.Controls"
             xmlns:vm="clr-namespace:FerrumPix.ViewModels"
             x:Class="FerrumPix.Views.SettingsView"
             Classes="settings-view"
             Background="{DynamicResource FP.Bg.Root}"
             Focusable="True"
             KeyDown="OnKeyDown">

    <Grid ColumnDefinitions="250,*">

        <Border Grid.Column="0" Classes="sidebar" Padding="12,16,10,16">
            <StackPanel Spacing="10">
                <TextBlock Text="Einstellungen" FontSize="{DynamicResource FP.Font.Title}" FontWeight="SemiBold" Margin="6,0,0,8"/>

                <Button Classes="ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="14,10"
                        Tag="GeneralSection"
                        Click="OnSectionNavClick">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/settings.svg" Width="16" Height="16"/>
                        <TextBlock Text="Allgemein"/>
                    </StackPanel>
                </Button>
                <Button Classes="ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="14,10"
                        Tag="AppearanceSection"
                        Click="OnSectionNavClick">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/palette.svg" Width="16" Height="16"/>
                        <TextBlock Text="Darstellung"/>
                    </StackPanel>
                </Button>
                <Button Classes="ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="14,10"
                        Tag="GallerySection"
                        Click="OnSectionNavClick">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/photo.svg" Width="16" Height="16"/>
                        <TextBlock Text="Galerie"/>
                    </StackPanel>
                </Button>
                <Button Classes="ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="14,10"
                        Tag="ViewerSection"
                        Click="OnSectionNavClick">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/player-play.svg" Width="16" Height="16"/>
                        <TextBlock Text="Betrachter"/>
                    </StackPanel>
                </Button>
                <Button Classes="ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="14,10"
                        Tag="EditorSection"
                        Click="OnSectionNavClick">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/exposure.svg" Width="16" Height="16"/>
                        <TextBlock Text="Editor"/>
                    </StackPanel>
                </Button>
                <Button Classes="ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="14,10"
                        Tag="ImmichSection"
                        Click="OnSectionNavClick">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/cloud.svg" Width="16" Height="16"/>
                        <TextBlock Text="Immich"/>
                    </StackPanel>
                </Button>
                <Button Classes="ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="14,10"
                        Tag="PerformanceSection"
                        Click="OnSectionNavClick">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/settings-bolt.svg" Width="16" Height="16"/>
                        <TextBlock Text="Leistung"/>
                    </StackPanel>
                </Button>
                <Button Classes="ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="14,10"
                        Tag="ShortcutsSection"
                        Click="OnSectionNavClick">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/keyboard.svg" Width="16" Height="16"/>
                        <TextBlock Text="Tastenkürzel"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="*,74">
        <ScrollViewer x:Name="SettingsScrollViewer" Grid.Row="0" Padding="28,26,24,32"
                      Margin="0,0,8,0"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="18" MaxWidth="960" Margin="0,0,0,0">

                <Border x:Name="GeneralSection" Classes="section">
                    <StackPanel Spacing="16">
                        <Border Height="180" BorderThickness="0" Padding="0, 20" Margin="-22,0,0,0" >
                            <Grid HorizontalAlignment="Center">
                                <Image Source="avares://FerrumPix/Assets/FerrumPix_SettingsDark.png"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Left"
                                       IsVisible="{Binding IsDarkOrGrayDarkThemeMode}"/>
                                <Image Source="avares://FerrumPix/Assets/FerrumPix_SettingsLight.png"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Left"
                                       IsVisible="{Binding IsLightOrGrayLightThemeMode}"/>
                            </Grid>
                        </Border>

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto" ColumnSpacing="12" >
                            <TextBlock Text="Version" Foreground="{DynamicResource FP.Text.Muted}"/>
                            <TextBlock Grid.Column="1" Text="{Binding DisplayVersion}"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Homepage" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="https://ferrumpix.app" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <Button Grid.Column="1" Classes="ghost" Padding="12,7" Click="OnHomepageClick">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/external-link.svg" Width="14" Height="14"/>
                                    <TextBlock Text="Öffnen"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="GitHub Repository" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="https://github.com/Bitpainter75/FerrumPix" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <Button Grid.Column="1" Classes="ghost" Padding="12,7" Click="OnGitHubClick">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/external-link.svg" Width="14" Height="14"/>
                                    <TextBlock Text="Öffnen"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource FP.Border.Normal}"/>

                        <StackPanel Spacing="2">
                            <TextBlock Text="Allgemein" FontSize="{DynamicResource FP.Font.Title}" FontWeight="SemiBold"/>
                            <TextBlock Text="Grundlegende Einstellungen für Startverhalten und Sprache." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Start mit Bilddatei" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Legt fest, welcher Modus verwendet wird, wenn FerrumPix mit einem Bild als Parameter geöffnet wird." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <Button Classes="ghost"
                                        Classes.active="{Binding IsStartupGalleryMode}"
                                        Padding="10,6"
                                        Command="{Binding SetStartupImageModeCommand}"
                                        CommandParameter="Gallery">Galerie</Button>
                                <Button Classes="ghost"
                                        Classes.active="{Binding IsStartupViewerMode}"
                                        Padding="10,6"
                                        Command="{Binding SetStartupImageModeCommand}"
                                        CommandParameter="Viewer">Viewer</Button>
                                <Button Classes="ghost"
                                        Classes.active="{Binding IsStartupEditorMode}"
                                        Padding="10,6"
                                        Command="{Binding SetStartupImageModeCommand}"
                                        CommandParameter="Editor">Editor</Button>
                                <Button Classes="ghost"
                                        Classes.active="{Binding IsStartupFullscreenMode}"
                                        Padding="10,6"
                                        Command="{Binding SetStartupImageModeCommand}"
                                        CommandParameter="Fullscreen">Vollbild</Button>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Sprache" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Verwendet standardmäßig die Systemsprache; falls nicht unterstützt, Englisch." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <Button Classes="ghost"
                                        Classes.active="{Binding IsLanguageSystem}"
                                        Padding="10,6"
                                        Command="{Binding SetLanguageModeCommand}"
                                        CommandParameter="System">System</Button>
                                <Button Classes="ghost"
                                        Classes.active="{Binding IsLanguageGerman}"
                                        Padding="10,6"
                                        Command="{Binding SetLanguageModeCommand}"
                                        CommandParameter="German">Deutsch</Button>
                                <Button Classes="ghost"
                                        Classes.active="{Binding IsLanguageEnglish}"
                                        Padding="10,6"
                                        Command="{Binding SetLanguageModeCommand}"
                                        CommandParameter="English">Englisch</Button>
                                <Button Classes="ghost"
                                        Classes.active="{Binding IsLanguageSpanish}"
                                        Padding="10,6"
                                        Command="{Binding SetLanguageModeCommand}"
                                        CommandParameter="Spanish">Spanisch</Button>
                                <Button Classes="ghost"
                                        Classes.active="{Binding IsLanguageFrench}"
                                        Padding="10,6"
                                        Command="{Binding SetLanguageModeCommand}"
                                        CommandParameter="French">Französisch</Button>
                                <Button Classes="ghost"
                                        Classes.active="{Binding IsLanguageItalian}"
                                        Padding="10,6"
                                        Command="{Binding SetLanguageModeCommand}"
                                        CommandParameter="Italian">Italienisch</Button>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Papierkorb überspringen" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Löscht Dateien und Ordner dauerhaft, statt sie in den Papierkorb zu verschieben." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding DeleteSkipTrash}"
                                          OnContent=""
                                          OffContent=""
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Sicherheitsabfrage beim Löschen überspringen" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Löscht Dateien und Ordner ohne vorherige Bestätigung." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding DeleteSkipConfirmation}"
                                          OnContent=""
                                          OffContent=""
                                          VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:Name="AppearanceSection" Classes="section">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Darstellung" FontSize="{DynamicResource FP.Font.Title}" FontWeight="SemiBold"/>
                            <TextBlock Text="Wählen Sie das Erscheinungsbild der Benutzeroberfläche." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                        </StackPanel>
                        <Grid ColumnDefinitions="*,*,*,*">
                            <Button Grid.Column="0"
                                    Classes="theme-choice"
                                    Classes.active="{Binding IsDarkThemeMode}"
                                    Command="{Binding SetThemeModeCommand}"
                                    CommandParameter="Dark"
                                    Margin="0,0,6,0">
                                <StackPanel Spacing="10">
                                    <Border Height="92" CornerRadius="6" ClipToBounds="True" Background="#11161B">
                                        <Image Source="avares://FerrumPix/Assets/Gallery.png"
                                               Stretch="UniformToFill"
                                               Opacity="0.78"/>
                                    </Border>
                                    <TextBlock Text="Dunkel" Foreground="{DynamicResource FP.Text.Secondary}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1"
                                    Classes="theme-choice"
                                    Classes.active="{Binding IsLightThemeMode}"
                                    Command="{Binding SetThemeModeCommand}"
                                    CommandParameter="Light"
                                    Margin="6,0">
                                <StackPanel Spacing="10">
                                    <Border Height="92" CornerRadius="6" ClipToBounds="True" Background="#E9EDF2">
                                        <Image Source="avares://FerrumPix/Assets/Gallery_Light.png"
                                               Stretch="UniformToFill"
                                               Opacity="0.9"/>
                                    </Border>
                                    <TextBlock Text="Hell" Foreground="{DynamicResource FP.Text.Secondary}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2"
                                    Classes="theme-choice"
                                    Classes.active="{Binding IsGrayDarkThemeMode}"
                                    Command="{Binding SetThemeModeCommand}"
                                    CommandParameter="GrayDark"
                                    Margin="6,0">
                                <StackPanel Spacing="10">
                                    <Border Height="92" CornerRadius="6" ClipToBounds="True" Background="#232628">
                                        <Image Source="avares://FerrumPix/Assets/Gallery_GrayDark.png"
                                               Stretch="UniformToFill"
                                               Opacity="0.88"/>
                                    </Border>
                                    <TextBlock Text="Grau Dunkel" Foreground="{DynamicResource FP.Text.Secondary}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="3"
                                    Classes="theme-choice"
                                    Classes.active="{Binding IsGrayLightThemeMode}"
                                    Command="{Binding SetThemeModeCommand}"
                                    CommandParameter="GrayLight"
                                    Margin="6,0,0,0">
                                <StackPanel Spacing="10">
                                    <Border Height="92" CornerRadius="6" ClipToBounds="True" Background="#4A5057">
                                        <Image Source="avares://FerrumPix/Assets/Gallery_GrayLight.png"
                                               Stretch="UniformToFill"
                                               Opacity="0.92"/>
                                    </Border>
                                    <TextBlock Text="Grau Hell" Foreground="{DynamicResource FP.Text.Secondary}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <StackPanel Spacing="12" Margin="0,4,0,0">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Akzentfarbe" FontSize="{DynamicResource FP.Font.Title}" FontWeight="SemiBold"/>
                            <TextBlock Text="Wählen Sie eine Akzentfarbe für Hervorhebungen und aktive Elemente." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Classes="swatch" Classes.active="{Binding IsOrangeAccent}" Background="#F08A1A" Command="{Binding SetAccentColorCommand}" CommandParameter="#F08A1A"/>
                            <Button Classes="swatch" Classes.active="{Binding IsRedAccent}" Background="#E74C3C" Command="{Binding SetAccentColorCommand}" CommandParameter="#E74C3C"/>
                            <Button Classes="swatch" Classes.active="{Binding IsPinkAccent}" Background="#F03B88" Command="{Binding SetAccentColorCommand}" CommandParameter="#F03B88"/>
                            <Button Classes="swatch" Classes.active="{Binding IsPurpleAccent}" Background="#8B5CF6" Command="{Binding SetAccentColorCommand}" CommandParameter="#8B5CF6"/>
                            <Button Classes="swatch" Classes.active="{Binding IsBlueAccent}" Background="#3B82F6" Command="{Binding SetAccentColorCommand}" CommandParameter="#3B82F6"/>
                            <Button Classes="swatch" Classes.active="{Binding IsCyanAccent}" Background="#0891B2" Command="{Binding SetAccentColorCommand}" CommandParameter="#0891B2"/>
                            <Button Classes="swatch" Classes.active="{Binding IsTealAccent}" Background="#0F766E" Command="{Binding SetAccentColorCommand}" CommandParameter="#0F766E"/>
                            <Button Classes="swatch" Classes.active="{Binding IsGreenAccent}" Background="#22C55E" Command="{Binding SetAccentColorCommand}" CommandParameter="#22C55E"/>
                            <Button Classes="swatch" Classes.active="{Binding IsYellowAccent}" Background="#FACC15" Command="{Binding SetAccentColorCommand}" CommandParameter="#FACC15"/>
                        </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="12" Margin="0,4,0,0">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Transparenz-Hintergrund" FontSize="{DynamicResource FP.Font.Title}" FontWeight="SemiBold"/>
                                <TextBlock Text="Legt fest, wie transparente Bildbereiche in Viewer und Editor dargestellt werden." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>

                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Darstellung" FontSize="{DynamicResource FP.Font.Body}"/>
                                    <TextBlock Text="Schachbrettmuster (Standard), echt durchsichtig oder eine feste Farbe." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <Button Classes="ghost"
                                            Classes.active="{Binding IsTransparencyCheckerboardMode}"
                                            Padding="10,6"
                                            Command="{Binding SetTransparencyBackgroundModeCommand}"
                                            CommandParameter="Checkerboard">Schachbrett</Button>
                                    <Button Classes="ghost"
                                            Classes.active="{Binding IsTransparencyNoneMode}"
                                            Padding="10,6"
                                            Command="{Binding SetTransparencyBackgroundModeCommand}"
                                            CommandParameter="None">Transparent</Button>
                                    <Button Classes="ghost"
                                            Classes.active="{Binding IsTransparencySolidMode}"
                                            Padding="10,6"
                                            Command="{Binding SetTransparencyBackgroundModeCommand}"
                                            CommandParameter="Solid">Farbe</Button>
                                </StackPanel>
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding IsTransparencySolidMode}">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Hintergrundfarbe" FontSize="{DynamicResource FP.Font.Body}"/>
                                    <TextBlock Text="Volltonfarbe hinter transparenten Bereichen." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                </StackPanel>
                                <Button Grid.Column="1" Classes="ghost" Height="34" Padding="6,4" Width="140" ToolTip.Tip="Hintergrundfarbe wählen">
                                    <Grid ColumnDefinitions="28,*" ColumnSpacing="8">
                                        <Border Width="26"
                                                Height="22"
                                                Background="{Binding TransparencyBackgroundColorBrush}"
                                                BorderBrush="{DynamicResource FP.Border.Strong}"
                                                BorderThickness="1"
                                                CornerRadius="4"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding TransparencyBackgroundColor}"
                                                   Foreground="{DynamicResource FP.Text.Secondary}"
                                                   FontSize="{DynamicResource FP.Font.Small}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <Button.Flyout>
                                        <Flyout Placement="Bottom">
                                            <Border Background="{DynamicResource FP.Bg.Panel}"
                                                    BorderBrush="{DynamicResource FP.Border.Normal}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="10">
                                                <StackPanel Spacing="2" Width="230">
                                                    <ColorPicker Color="{Binding TransparencyBackgroundColorValue, Mode=TwoWay}"
                                                                 ColorModel="Rgba"
                                                                 HorizontalAlignment="Stretch"/>
                                                    <TextBox Text="{Binding TransparencyBackgroundColor, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                             PlaceholderText="#AARRGGBB"
                                                             FontSize="{DynamicResource FP.Font.Small}"/>
                                                </StackPanel>
                                            </Border>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Schriftgrad" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Vergrößert oder verkleinert die Schrift der Oberfläche in ganzen Stufen. Wirkt sofort."
                                           Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <icons:RoundSlider Width="150"
                                                   Minimum="{Binding FontSizeOffsetMinimum}"
                                                   Maximum="{Binding FontSizeOffsetMaximum}"
                                                   DefaultValue="0"
                                                   DragIncrement="1"
                                                   WheelIncrement="1"
                                                   Value="{Binding FontSizeOffset}"/>
                                <TextBlock Text="{Binding FontSizeOffsetText}"
                                           Foreground="{DynamicResource FP.Text.Secondary}"
                                           FontSize="{DynamicResource FP.Font.Small}"
                                           Width="56"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Anwendungsskalierung wirkt nur auf Avalonias X11-Backend, siehe
                             IsApplicationScaleSupported - unter Windows skaliert das OS selbst. -->
                        <StackPanel Spacing="14" IsVisible="{Binding IsApplicationScaleSupported}">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Anwendungsskalierung" FontSize="{DynamicResource FP.Font.Body}"/>
                                    <TextBlock Text="Skaliert die komplette Oberfläche beim nächsten Start." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <icons:RoundSlider Width="150"
                                                       Minimum="100"
                                                       Maximum="250"
                                                       Value="{Binding ApplicationScalePercent}"/>
                                    <TextBlock Text="{Binding ApplicationScaleText}"
                                               Foreground="{DynamicResource FP.Text.Secondary}"
                                               FontSize="{DynamicResource FP.Font.Small}"
                                               Width="42"
                                               TextAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <Grid ColumnDefinitions="*,220">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Bildschirm für Skalierung" FontSize="{DynamicResource FP.Font.Body}"/>
                                    <TextBlock Text="Legt fest, auf welchem Bildschirm die gewählte Skalierung angewendet wird." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Classes="dropdown-btn"
                                        Width="220"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch">
                                    <Button.Flyout>
                                        <Flyout Placement="BottomEdgeAlignedLeft" VerticalOffset="2">
                                            <ItemsControl ItemsSource="{Binding ApplicationScaleScreens}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Classes="dropdown-item"
                                                                MinWidth="220"
                                                                HorizontalAlignment="Stretch"
                                                                HorizontalContentAlignment="Stretch"
                                                                Padding="10,8"
                                                                Click="OnScaleScreenOptionClick">
                                                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Flyout>
                                    </Button.Flyout>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="{Binding ApplicationScaleScreen}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <icons:SvgIcon Grid.Column="1"
                                                       Source="avares://FerrumPix/Assets/Icons/outline/chevron-down.svg"
                                                       Width="16"
                                                       Height="16"
                                                       Margin="10,0,0,0"
                                                       VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                            </Grid>

                            <TextBlock Text="Änderung wird nach einem Neustart aktiv."
                                       Foreground="{DynamicResource FP.Accent}"
                                       FontSize="{DynamicResource FP.Font.Caption}"
                                       IsVisible="{Binding IsApplicationScaleRestartRequired}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border x:Name="GallerySection" Classes="section">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Galerie" FontSize="{DynamicResource FP.Font.Title}" FontWeight="SemiBold"/>
                            <TextBlock Text="Einstellungen für die Ordner- und Dateiansicht im Seitenbereich." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Versteckte Ordner anzeigen" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Zeigt Ordner an, deren Name mit einem Punkt beginnt (z. B. .config, .local)." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowHiddenFolders}" OnContent="" OffContent="" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Ordner in der Galerie anzeigen" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Zeigt Unterordner neben Bildern an; Doppelklick öffnet den Ordner." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding GalleryShowFolders}" OnContent="" OffContent="" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Übergeordnete Ordner anzeigen" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Blendet in der Galerie zusätzlich einen Eintrag für den übergeordneten Ordner ein." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding GalleryShowParentFolder}" OnContent="" OffContent="" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Ansicht" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Legt fest, ob die Galerie als Raster oder als Liste angezeigt wird." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <Button Classes="ghost"
                                        Classes.active="{Binding IsGalleryViewModeGrid}"
                                        Padding="10,6"
                                        Command="{Binding SetGalleryViewModeCommand}"
                                        CommandParameter="Grid">Raster</Button>
                                <Button Classes="ghost"
                                        Classes.active="{Binding IsGalleryViewModeList}"
                                        Padding="10,6"
                                        Command="{Binding SetGalleryViewModeCommand}"
                                        CommandParameter="List">Liste</Button>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Zeitleiste am rechten Rand" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Zeigt Jahre bzw. Anfangsbuchstaben passend zur Sortierung; Klick oder Ziehen springt an die Stelle." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <Button Classes="ghost"
                                        Classes.active="{Binding IsGalleryTimelineAll}"
                                        Padding="10,6"
                                        Command="{Binding SetGalleryTimelineModeCommand}"
                                        CommandParameter="All">Immich und Ordner</Button>
                                <Button Classes="ghost"
                                        Classes.active="{Binding IsGalleryTimelineImmich}"
                                        Padding="10,6"
                                        Command="{Binding SetGalleryTimelineModeCommand}"
                                        CommandParameter="Immich">Nur Immich</Button>
                                <Button Classes="ghost"
                                        Classes.active="{Binding IsGalleryTimelineFolders}"
                                        Padding="10,6"
                                        Command="{Binding SetGalleryTimelineModeCommand}"
                                        CommandParameter="Folders">Nur Ordner</Button>
                                <Button Classes="ghost"
                                        Classes.active="{Binding IsGalleryTimelineOff}"
                                        Padding="10,6"
                                        Command="{Binding SetGalleryTimelineModeCommand}"
                                        CommandParameter="Off">Aus</Button>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Startordner der Galerie" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Bestimmt, welcher Ordner beim Start der Anwendung geöffnet wird." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                                    <Button Classes="ghost"
                                            Classes.active="{Binding IsGalleryStartupPicturesFolder}"
                                            Padding="10,6"
                                            Command="{Binding SetGalleryStartupFolderModeCommand}"
                                            CommandParameter="Pictures">Bilder-Ordner</Button>
                                    <Button Classes="ghost"
                                            Classes.active="{Binding IsGalleryStartupLastFolder}"
                                            Padding="10,6"
                                            Command="{Binding SetGalleryStartupFolderModeCommand}"
                                            CommandParameter="Last">Letzter Ordner</Button>
                                    <Button Classes="ghost"
                                            Classes.active="{Binding IsGalleryStartupCustomFolder}"
                                            Padding="10,6"
                                            Command="{Binding SetGalleryStartupFolderModeCommand}"
                                            CommandParameter="Custom">Benutzerdefiniert</Button>
                                    <Button Classes="ghost"
                                            Classes.active="{Binding IsGalleryStartupImmich}"
                                            Padding="10,6"
                                            IsVisible="{Binding IsGalleryStartupImmichAvailable}"
                                            Command="{Binding SetGalleryStartupFolderModeCommand}"
                                            CommandParameter="Immich"
                                            ToolTip.Tip="Startet in Immich „Alle Fotos“; ohne Verbindung greift der Bilder-Ordner">Immich (Alle Fotos)</Button>
                                </StackPanel>
                                <Grid ColumnDefinitions="260,Auto" ColumnSpacing="6" IsVisible="{Binding IsGalleryStartupCustomFolder}">
                                    <TextBox Text="{Binding GalleryStartupCustomFolder, Mode=TwoWay}"
                                             PlaceholderText="Ordner auswählen"
                                             IsReadOnly="True"/>
                                    <Button Grid.Column="1"
                                            Classes="ghost"
                                            Padding="10,6"
                                            Click="OnBrowseGalleryStartupFolderClick">Auswählen</Button>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:Name="ViewerSection" Classes="section">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Betrachter" FontSize="{DynamicResource FP.Font.Title}" FontWeight="SemiBold"/>
                            <TextBlock Text="Legt fest, wie Bilder beim Öffnen dargestellt werden." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Bilder an Fenstergröße anpassen" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Öffnet Bilder skaliert auf die verfügbare Fensterfläche statt in Originalgröße." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding ViewerOpenFitToWindow}"
                                          OnContent=""
                                          OffContent=""
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Einpassen-Verhalten" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Gilt für Viewer und Editor: nur verkleinern, wenn das Bild größer als die Darstellungsfläche ist, oder immer auf die Fläche skalieren." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <Button Classes="ghost"
                                        Classes.active="{Binding IsViewerFitBehaviorOnlyWhenLarger}"
                                        Padding="10,6"
                                        Command="{Binding SetViewerFitBehaviorCommand}"
                                        CommandParameter="OnlyWhenLarger">Nur wenn größer</Button>
                                <Button Classes="ghost"
                                        Classes.active="{Binding IsViewerFitBehaviorAlways}"
                                        Padding="10,6"
                                        Command="{Binding SetViewerFitBehaviorCommand}"
                                        CommandParameter="Always">Immer einpassen</Button>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Filmstrip im Viewer anzeigen" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Zeigt die Bildleiste am unteren Rand des Viewers an." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding ViewerShowFilmstrip}"
                                          OnContent=""
                                          OffContent=""
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Info-Seitenleiste im Viewer anzeigen" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Blendet die rechte Metadatenleiste ein oder aus." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding ViewerInfoSidebarExpanded}"
                                          OnContent=""
                                          OffContent=""
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Diashow-Dauer" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Legt fest, wie lange ein Bild in der Diashow sichtbar bleibt." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <icons:RoundSlider Width="150"
                                                   Minimum="1"
                                                   Maximum="30"
                                                   Value="{Binding ViewerSlideshowIntervalSeconds}"/>
                                <TextBlock Text="{Binding ViewerSlideshowIntervalSeconds, StringFormat={}{0}s}"
                                           Foreground="{DynamicResource FP.Text.Secondary}"
                                           FontSize="{DynamicResource FP.Font.Small}"
                                           Width="34"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Hardwarebeschleunigung für Videowiedergabe" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Nutzt die Grafikhardware zur Videodekodierung. Bei Bildfehlern in der Videowiedergabe deaktivieren (Software-Decoding). Wirkt beim nächsten Öffnen eines Videos." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding VideoHardwareAcceleration}"
                                          OnContent=""
                                          OffContent=""
                                          VerticalAlignment="Center"/>
                        </Grid>

                    </StackPanel>
                </Border>

                <Border x:Name="EditorSection" Classes="section">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Editor" FontSize="{DynamicResource FP.Font.Title}" FontWeight="SemiBold"/>
                            <TextBlock Text="Einstellungen für Bearbeitung und Vorschau." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Filmstrip im Editor anzeigen" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Zeigt die Bildleiste am unteren Rand des Editors an." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding EditorShowFilmstrip}"
                                          OnContent=""
                                          OffContent=""
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Info-Seitenleiste im Editor anzeigen" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Blendet die rechte Metadatenleiste ein oder aus." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding EditorInfoSidebarExpanded}"
                                          OnContent=""
                                          OffContent=""
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Ebenen-Seitenleiste im Editor anzeigen" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Blendet das Ebenen-Panel neben der Info-Leiste ein oder aus." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding EditorLayersPanelExpanded}"
                                          OnContent=""
                                          OffContent=""
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Einrast-Abstand zum Bildrand" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Abstand der Einrast-Linien zu den Bildrändern beim Verschieben von Objekten, in Prozent. 0 = deaktiviert; an Rändern, Mitte und anderen Objekten rasten Objekte immer." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <icons:RoundSlider Width="150"
                                                   Minimum="0"
                                                   Maximum="20"
                                                   Value="{Binding EditorSnapMarginPercent}"/>
                                <TextBlock Text="{Binding EditorSnapMarginPercent, StringFormat={}{0}%}"
                                           MinWidth="42"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource FP.Text.Secondary}"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="JPG-Qualität" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Wird für das Speichern und Exportieren als JPG verwendet." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <icons:RoundSlider Width="150"
                                                   Minimum="1"
                                                   Maximum="100"
                                                   Value="{Binding JpgSaveQuality}"/>
                                <TextBlock Text="{Binding JpgSaveQuality, StringFormat={}{0}%}"
                                           Foreground="{DynamicResource FP.Text.Secondary}"
                                           FontSize="{DynamicResource FP.Font.Small}"
                                           Width="34"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Metadaten beim Speichern übernehmen" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Übernimmt EXIF/XMP beim Speichern unter, Exportieren und Konvertieren." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding PreserveMetadataOnSave}"
                                          OnContent=""
                                          OffContent=""
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Lineale im Editor anzeigen" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Blendet die Pixel-Lineale am oberen und linken Rand der Vorschau ein." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding EditorShowRulers}"
                                          OnContent=""
                                          OffContent=""
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Raster im Editor anzeigen" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Zeigt ein Pixelraster über dem Bild an." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding EditorShowGrid}"
                                          OnContent=""
                                          OffContent=""
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Rastergröße" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Kantenlänge einer Rasterzelle im Editor, in Bildpixeln." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <icons:RoundSlider Width="150"
                                                   Minimum="2"
                                                   Maximum="500"
                                                   Value="{Binding EditorGridSize}"/>
                                <TextBlock Text="{Binding EditorGridSize, StringFormat={}{0} px}"
                                           Foreground="{DynamicResource FP.Text.Secondary}"
                                           FontSize="{DynamicResource FP.Font.Small}"
                                           Width="52"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:Name="ImmichSection" Classes="section">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Immich" FontSize="{DynamicResource FP.Font.Title}" FontWeight="SemiBold"/>
                            <TextBlock Text="Bindet einen self-hosted Immich-Server ein. Alben erscheinen im Navigationsbereich der Galerie; Bilder lassen sich betrachten und (als Kopie) bearbeiten." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Immich aktivieren" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Zeigt den Immich-Zweig mit deinen Alben im Galeriebaum an." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding ImmichEnabled}" OnContent="" OffContent="" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto" IsEnabled="{Binding ImmichEnabled}">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Server-URL" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Basis-Adresse deiner Immich-Instanz, z. B. http://nas:2283" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <TextBox Grid.Column="1" Width="320"
                                     PlaceholderText="http://nas:2283"
                                     Text="{Binding ImmichServerUrl, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto" IsEnabled="{Binding ImmichEnabled}">
                            <StackPanel Spacing="2">
                                <TextBlock Text="API-Key" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Im Immich-Webinterface unter Konto → API-Keys erzeugen." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <TextBox Grid.Column="1" Width="320"
                                     PasswordChar="•"
                                     Text="{Binding ImmichApiKey, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto" IsEnabled="{Binding ImmichEnabled}">
                            <TextBlock Text="{Binding ImmichConnectionMessage}"
                                       Foreground="{DynamicResource FP.Text.Secondary}"
                                       FontSize="{DynamicResource FP.Font.Small}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                            <Button Grid.Column="1" Classes="ghost" Padding="12,7"
                                    IsEnabled="{Binding !ImmichIsTesting}"
                                    Command="{Binding TestImmichConnectionCommand}">Verbindung testen</Button>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto" IsEnabled="{Binding ImmichEnabled}">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Sterne in Beschreibung speichern" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Speichert FerrumPix-Bewertungen in einem abgegrenzten Block der Immich-Beschreibung statt im Immich-Rating-Feld." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding ImmichStoreRatingInDescription}" OnContent="" OffContent="" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto" IsEnabled="{Binding ImmichEnabled}">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Stichwörter in Beschreibung speichern" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Speichert FerrumPix-Stichwörter in einem abgegrenzten Block der Immich-Beschreibung statt als Immich-Tags." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding ImmichStoreTagsInDescription}" OnContent="" OffContent="" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource FP.Border.Normal}" Margin="0,4"/>

                        <Grid ColumnDefinitions="*,Auto" IsEnabled="{Binding ImmichEnabled}">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Vorhandene Assets aktualisieren" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Bearbeitungen ersetzen das Immich-Asset, aus dem sie stammen (Alben, Stichwörter, Bewertung und Favorit bleiben erhalten; das Original wandert in den Immich-Papierkorb). Gilt für Speichern UND für Speichern unter mit Ziel Immich. Aus: jede Bearbeitung legt ein neues Asset an." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding ImmichUpdateExistingAssets}" OnContent="" OffContent="" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto" IsEnabled="{Binding ImmichEnabled}">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Löschen in Immich erlauben" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Löschen wirkt in Galerie und Betrachter auch auf Immich-Assets - also auf den Server, nicht nur auf die lokale Ansicht. Aus: Immich-Bilder lassen sich nicht löschen." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding ImmichAllowDelete}" OnContent="" OffContent="" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto" IsEnabled="{Binding ImmichAllowDelete}">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Endgültig löschen" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Umgeht den Immich-Papierkorb: gelöschte Assets sind sofort weg und lassen sich auch im Immich-Webinterface nicht wiederherstellen." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding ImmichDeletePermanently}" OnContent="" OffContent="" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="{DynamicResource FP.Border.Normal}" Margin="0,4"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Immich-Cache leeren" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Löscht die lokal zwischengespeicherten Immich-Vorschaubilder und den Metadaten-Index. Beides wird bei Bedarf neu geladen." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ImmichCacheMessage}" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Small}" VerticalAlignment="Center"/>
                                <Button Classes="ghost" Padding="12,7" Command="{Binding ClearImmichCacheCommand}">Cache leeren</Button>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:Name="PerformanceSection" Classes="section">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Leistung" FontSize="{DynamicResource FP.Font.Title}" FontWeight="SemiBold"/>
                            <TextBlock Text="Cache und Verarbeitung." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Vorschaubilder zwischenspeichern" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Speichert Vorschaubilder auf dem Gerät, damit Ordner beim nächsten Öffnen schneller geladen werden." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding ThumbnailCacheEnabled}"
                                          OnContent=""
                                          OffContent=""
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Vorschaubild-Qualität" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Bestimmt die JPEG-Qualität neu erzeugter zwischengespeicherter Vorschaubilder." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <icons:RoundSlider Width="150"
                                                   Minimum="45"
                                                   Maximum="95"
                                                   Value="{Binding ThumbnailQuality}"/>
                                <TextBlock Text="{Binding ThumbnailQuality, StringFormat={}{0}%}"
                                           Foreground="{DynamicResource FP.Text.Secondary}"
                                           FontSize="{DynamicResource FP.Font.Small}"
                                           Width="34"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Vorschaubild-Speichercache" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Wie viele Vorschaubilder maximal gleichzeitig im Arbeitsspeicher gehalten werden. Höhere Werte verringern erneutes Laden beim Scrollen, benötigen aber mehr Arbeitsspeicher." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <icons:RoundSlider Width="150"
                                                   Minimum="50"
                                                   Maximum="5000"
                                                   Value="{Binding ThumbnailMemoryCacheCapacity}"/>
                                <TextBlock Text="{Binding ThumbnailMemoryCacheCapacity}"
                                           Foreground="{DynamicResource FP.Text.Secondary}"
                                           FontSize="{DynamicResource FP.Font.Small}"
                                           Width="34"
                                           TextAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Datenbank bereinigen" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Entfernt Metadaten (Bewertungen, Favoriten, Tags) von Bildern, die nicht mehr existieren." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CleanupResultMessage}" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Small}" VerticalAlignment="Center"/>
                                <Button Classes="ghost" Padding="12,7" Command="{Binding CleanupDatabaseCommand}">Bereinigen</Button>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Fehlerdiagnose-Protokoll" FontSize="{DynamicResource FP.Font.Body}"/>
                                <TextBlock Text="Schreibt Details zu Vorschau-/Wiedergabe-Fehlern nach %LocalAppData%/FerrumPix/logs/diagnostics.log. Nur bei Bedarf zur Fehlersuche einschalten." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1"
                                          IsChecked="{Binding EnableDiagnosticLogging}"
                                          OnContent=""
                                          OffContent=""
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Vorschaubild-Cache nach Ordnern" FontSize="{DynamicResource FP.Font.Body}"/>
                                    <TextBlock Text="{Binding ThumbnailCacheSummaryText}" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ThumbnailCacheResultMessage}" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Small}" VerticalAlignment="Center"/>
                                    <Button Classes="ghost" Padding="12,7" Command="{Binding RefreshThumbnailCacheCommand}">Aktualisieren</Button>
                                    <Button Classes="ghost" Padding="12,7" Command="{Binding DeleteAllThumbnailCacheCommand}">Alle löschen</Button>
                                </StackPanel>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding ThumbnailCacheFolders}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource FP.Bg.Input}"
                                                BorderBrush="{DynamicResource FP.Border.Normal}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10,8"
                                                Margin="0,0,0,6">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontSize="{DynamicResource FP.Font.Body}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding DetailText}"
                                                               Foreground="{DynamicResource FP.Text.Secondary}"
                                                               FontSize="{DynamicResource FP.Font.Caption}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Classes="ghost"
                                                        Padding="10,6"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding DataContext.DeleteThumbnailCacheFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">Löschen</Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Rein informative Übersicht der Belegungen (Nutzerwunsch 2026-07-17). Die Texte
                     beschreiben die tatsächliche Behandlung in GalleryView/ViewerView/EditorView/
                     MainWindow - bei Änderungen an den Key-Handlern hier nachziehen. -->
                <Border x:Name="ShortcutsSection" Classes="section">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Tastenkürzel" FontSize="{DynamicResource FP.Font.Title}" FontWeight="SemiBold"/>
                            <TextBlock Text="Übersicht der Tasten- und Mausbelegung in Galerie, Betrachter und Editor." Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                        </StackPanel>

                        <TextBlock Text="Überall" FontWeight="SemiBold" FontSize="{DynamicResource FP.Font.Body}"/>
                        <StackPanel Spacing="6">
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="F11" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Vollbild ein/aus" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Strg+1–5" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Bewertung setzen (dieselbe Zahl erneut oder Strg+0 entfernt sie)" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Strg+Q" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Favorit ein/aus" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>

                        <TextBlock Text="Galerie" FontWeight="SemiBold" FontSize="{DynamicResource FP.Font.Body}" Margin="0,6,0,0"/>
                        <StackPanel Spacing="6">
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Pfeiltasten, Bild auf/ab, Pos1, Ende" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Column="1" Text="Auswahl bewegen (Umschalt: Bereich erweitern)" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Eingabe oder Doppelklick" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Bild öffnen" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Leertaste (halten)" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Schnellvorschau" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Strg+A" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Alles auswählen" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Strg+C / Strg+X / Strg+V" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Kopieren / Ausschneiden / Einfügen" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Strg+F" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Suche" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Strg+W" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Filter anwenden" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Strg+R" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Bildgröße ändern" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Strg+D" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Konvertieren nach" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Entf" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Löschen" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="F2" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Umbenennen" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="F5" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Aktualisieren" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Esc" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Auswahl aufheben" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Strg+Mausrad oder Rechtsklick+Mausrad" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Column="1" Text="Kachelgröße ändern" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>

                        <TextBlock Text="Betrachter" FontWeight="SemiBold" FontSize="{DynamicResource FP.Font.Body}" Margin="0,6,0,0"/>
                        <StackPanel Spacing="6">
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Pfeil links/rechts, Bild auf/ab" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Column="1" Text="Voriges / nächstes Bild" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Plus / Minus" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Zoomen" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="0" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Bild einpassen" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Leertaste" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Diashow starten/stoppen" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Strg+L / Strg+R" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Nach links / rechts drehen" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Strg+I" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Info-Leiste ein/aus" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Strg+E" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Im Editor öffnen" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Entf" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Löschen" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="F2" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Umbenennen" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Esc" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Zurück zur Galerie (im Vollbild: Vollbild verlassen)" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Strg+Mausrad oder Rechtsklick+Mausrad" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Column="1" Text="Am Mauszeiger zoomen" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>

                        <TextBlock Text="Editor" FontWeight="SemiBold" FontSize="{DynamicResource FP.Font.Body}" Margin="0,6,0,0"/>
                        <StackPanel Spacing="6">
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Strg+Z / Strg+Y" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Rückgängig / Wiederholen" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Strg+S" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Speichern (wenn nicht möglich: Speichern unter)" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Strg+A" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Alles auswählen (bei Auswahl-Werkzeugen)" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Strg+C / Strg+V" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Auswahl kopieren / einfügen" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Strg+D" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Objekt duplizieren; ohne Objekt: Auswahl aufheben" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Strg+P" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Vorschau anwenden" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Strg+R / Strg+T / Strg+B / Strg+G" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Column="1" Text="Werkzeug: Drehen / Text / Zeichnen / Einfügen" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Strg+E" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Radierer umschalten (im Zeichnen-Werkzeug)" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Pfeiltasten" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Objekt verschieben (Umschalt: größere Schritte)" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Alt (beim Ziehen von Objekten)" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Column="1" Text="Einrasten vorübergehend aus" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Eckige Klammern [ ]" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Werkzeuggröße kleiner / größer" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Leertaste (halten)" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Bildausschnitt verschieben" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Entf" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Objekt löschen; ohne Objekt: Bild löschen" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Esc" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}"/>
                                <TextBlock Grid.Column="1" Text="Auswahl abwählen, Zug abbrechen, Editor verlassen" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid ColumnDefinitions="230,*" ColumnSpacing="12">
                                <TextBlock Text="Strg+Mausrad oder Rechtsklick+Mausrad" Foreground="{DynamicResource FP.Text.Secondary}" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Column="1" Text="Am Mauszeiger zoomen" FontSize="{DynamicResource FP.Font.Caption}" TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Height="150" Background="Transparent"/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Background="{DynamicResource FP.Bg.Dark}" BorderBrush="{DynamicResource FP.Border.Subtle}" BorderThickness="0,1,0,0" Padding="16,0">
            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                <Button Classes="ghost" Padding="12,8" Command="{Binding ResetCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <icons:SvgIcon Source="avares://FerrumPix/Assets/Icons/outline/history.svg" Width="16" Height="16"/>
                        <TextBlock Text="Auf Standardeinstellungen zurücksetzen"/>
                    </StackPanel>
                </Button>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Button Classes="ghost" Padding="18,8" Command="{Binding CancelCommand}">Abbrechen</Button>
                    <Button Classes="accent" Padding="18,8" Command="{Binding ApplyCommand}">Speichern</Button>
                </StackPanel>
            </Grid>
        </Border>
        </Grid>
    </Grid>
</UserControl>
